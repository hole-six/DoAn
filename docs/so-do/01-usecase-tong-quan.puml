@startuml
left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam actorStyle stick
skinparam usecase {
  BackgroundColor White
  BorderColor Black
  ArrowColor Black
}

actor "Khach vang lai" as Guest
actor "Ung vien" as Candidate
actor "Nha tuyen dung" as Employer
actor "Quan tri vien" as Admin

Candidate --|> Guest
Employer --|> Guest

rectangle "He thong tuyen dung IT EffortIT" {
  usecase "Xem trang chu" as UC_Home
  usecase "Tim kiem viec lam" as UC_SearchJob
  usecase "Loc viec lam" as UC_FilterJob
  usecase "Xem chi tiet viec lam" as UC_JobDetail
  usecase "Xem cong ty" as UC_Company
  usecase "Dang ky" as UC_Register
  usecase "Dang nhap" as UC_Login
  usecase "Quen mat khau" as UC_Forgot

  usecase "Quan ly CV/ho so nang luc" as UC_CV
  usecase "Upload CV PDF" as UC_UploadCV
  usecase "Luu viec lam" as UC_SaveJob
  usecase "Ung tuyen" as UC_Apply
  usecase "Theo doi ho so ung tuyen" as UC_TrackApp
  usecase "Xem lich phong van" as UC_CandidateInterview
  usecase "Chat voi nha tuyen dung" as UC_CandidateChat
  usecase "Nhan goi y viec lam AI" as UC_AI

  usecase "Cap nhat ho so cong ty" as UC_CompanyProfile
  usecase "Dang tin tuyen dung" as UC_PostJob
  usecase "Quan ly tin tuyen dung" as UC_ManageJob
  usecase "Xem pipeline ung vien" as UC_Pipeline
  usecase "Moi phong van" as UC_Schedule
  usecase "Cap nhat ket qua phong van" as UC_Result
  usecase "Chat voi ung vien/Admin" as UC_EmployerChat

  usecase "Dashboard quan tri" as UC_AdminDashboard
  usecase "Quan ly nguoi dung" as UC_UserManage
  usecase "Duyet cong ty" as UC_ApproveCompany
  usecase "Duyet tin tuyen dung" as UC_ApproveJob
  usecase "Quan ly ky nang" as UC_Skill
  usecase "Quan ly review cong ty" as UC_Review
  usecase "Xu ly thong bao can duyet" as UC_AdminNotification
}

Guest --> UC_Home
Guest --> UC_SearchJob
Guest --> UC_FilterJob
Guest --> UC_JobDetail
Guest --> UC_Company
Guest --> UC_Register
Guest --> UC_Login
Guest --> UC_Forgot

Candidate --> UC_CV
Candidate --> UC_UploadCV
Candidate --> UC_SaveJob
Candidate --> UC_Apply
Candidate --> UC_TrackApp
Candidate --> UC_CandidateInterview
Candidate --> UC_CandidateChat
Candidate --> UC_AI

Employer --> UC_CompanyProfile
Employer --> UC_PostJob
Employer --> UC_ManageJob
Employer --> UC_Pipeline
Employer --> UC_Schedule
Employer --> UC_Result
Employer --> UC_EmployerChat

Admin --> UC_AdminDashboard
Admin --> UC_UserManage
Admin --> UC_ApproveCompany
Admin --> UC_ApproveJob
Admin --> UC_Skill
Admin --> UC_Review
Admin --> UC_AdminNotification

UC_FilterJob ..> UC_SearchJob : <<extend>>
UC_UploadCV ..> UC_CV : <<extend>>
UC_Apply ..> UC_CV : <<include>>
UC_PostJob ..> UC_CompanyProfile : <<include>>
UC_PostJob ..> UC_ApproveCompany : <<precondition>>
UC_Schedule ..> UC_Pipeline : <<include>>
UC_Result ..> UC_Schedule : <<include>>
UC_ApproveJob ..> UC_AdminNotification : <<include>>
UC_ApproveCompany ..> UC_AdminNotification : <<include>>
@enduml

