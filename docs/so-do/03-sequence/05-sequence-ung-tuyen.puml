@startuml
skinparam shadowing false
title Sequence - Ứng tuyển việc làm

actor "Ứng viên" as Candidate
boundary "ChiTiếtViệcLàm" as UI
control "ỨngTuyểnController" as ApplyController
entity "HồSơNăngLực" as CV
entity "HồSơỨngTuyển" as Application
entity "ThôngBáo" as Notify
database "MongoDB" as DB

Candidate -> UI : Bấm ứng tuyển
UI -> UI : Chọn CV/hồ sơ năng lực
UI -> ApplyController : POST /api/hosoungtuyen
ApplyController -> CV : kiểm tra CV thuộc ứng viên
CV -> DB : findById
DB --> CV : CV
ApplyController -> Application : kiểm tra trùng ứng tuyển
Application -> DB : findOne(ungVien, tin)
alt Chưa ứng tuyển
  ApplyController -> Application : tạo hồ sơ ứng tuyển
  Application -> DB : insert
  ApplyController -> Notify : tạo thông báo cho NTD
  Notify -> DB : insert
  ApplyController --> UI : 201 thành công
else Đã ứng tuyển
  ApplyController --> UI : 409 đã tồn tại
end
UI --> Candidate : Hiển thị kết quả
@enduml

