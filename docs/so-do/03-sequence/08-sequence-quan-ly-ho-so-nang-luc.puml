@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam titleFontSize 18
skinparam shadowing false
skinparam linetype ortho
skinparam sequenceMessageAlign center
skinparam sequence {
  ArrowColor #222222
  LifeLineBorderColor #666666
  LifeLineBackgroundColor #F7F7F7
  ParticipantBorderColor #222222
  ParticipantBackgroundColor White
  ActorBorderColor #222222
  ActorBackgroundColor White
  BoxBorderColor #888888
  GroupBorderColor #222222
  GroupHeaderFontColor #222222
}
title Sơ đồ Quản lý hồ sơ năng lực

actor "Actor: Ứng viên" as Actor
boundary "UI: ho-so-nang-luc" as UI
boundary "UI: cv-studio" as Form
control "Controller: HoSoNangLucController" as Controller
entity "Entity: HoSoNangLuc" as MainEntity

Actor -> UI : 1. Mở hồ sơ năng lực
activate UI
UI -> Form : 2. Mở cv-studio
activate Form
Actor -> Form : 3. Tạo, chỉnh sửa, upload hoặc chọn CV chính
note over Form, Controller
  Upload ảnh/CV gọi riêng:
  POST /hosonangluc/upload-anh, POST /hosonangluc/upload-file;
  file lưu ra đĩa qua multer, trả về đường dẫn (anhDaiDien, fileCvPath)
end note
Form -> Controller : 4. GET/POST/PATCH/DELETE /hosonangluc
activate Controller
Controller -> MainEntity : 5. Kiểm tra dữ liệu CV
activate MainEntity
MainEntity --> Controller : 6. return kết quả kiểm tra
deactivate MainEntity

alt Dữ liệu hợp lệ
  Controller -> MainEntity : 7. Lưu hồ sơ năng lực (kèm anhDaiDien/fileCvPath)
  activate MainEntity
  MainEntity --> Controller : 8. return dữ liệu đã cập nhật
  deactivate MainEntity
  Controller --> Form : 9. Thông báo lưu CV thành công
  Form --> UI : 10. Cập nhật giao diện
  UI --> Actor : 11. Hiển thị kết quả thành công
else Dữ liệu không hợp lệ
  Controller --> Form : 9. Thông báo dữ liệu CV không hợp lệ
  Form --> UI : 10. Hiển thị lỗi tại màn hình
  UI --> Actor : 11. Yêu cầu kiểm tra lại thông tin
end
deactivate Controller
deactivate Form
deactivate UI
@enduml
