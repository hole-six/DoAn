@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam titleFontSize 18
skinparam shadowing false
skinparam linetype ortho
skinparam sequenceMessageAlign center
skinparam ParticipantPadding 24
skinparam BoxPadding 8
skinparam sequence {
  ArrowColor #222222
  LifeLineBorderColor #666666
  LifeLineBackgroundColor #F7F7F7
  ParticipantBorderColor #222222
  ParticipantBackgroundColor White
  ActorBorderColor #222222
  ActorBackgroundColor White
  BoxBorderColor #888888
}
title sd Quản lý hồ sơ năng lực

actor "Actor: Ứng viên" as Actor
boundary "UI: ho-so-nang-luc" as UI
boundary "UI: form-cv-studio" as Form
control "Controller: HoSoNangLucController" as Controller
entity "Entity: HoSoNangLuc" as MainEntity
entity "Entity: UngVien" as E1
entity "Entity: TepCV" as E2

Actor -> UI : 1. Mở hồ sơ năng lực
activate UI
UI -> Form : 2. Hiển thị form-cv-studio
activate Form
Actor -> Form : 3. Tạo, chỉnh sửa, upload hoặc chọn CV chính
Form -> Controller : 4. luuHoSoNangLuc(request)
activate Controller
Controller -> MainEntity : 5. Kiểm tra hồ sơ ứng viên và dữ liệu CV
activate MainEntity
MainEntity --> Controller : 6. return kết quả kiểm tra
deactivate MainEntity

alt [Dữ liệu hợp lệ]
  Controller -> MainEntity : 7. Lưu hồ sơ năng lực
  activate MainEntity
  MainEntity --> Controller : 8. return dữ liệu đã cập nhật
  deactivate MainEntity
  Controller -> E1 : 9. Cập nhật CV chính hoặc file CV
  Controller --> Form : 10. Thông báo lưu CV thành công
  Form --> UI : 11. Cập nhật giao diện
  UI --> Actor : 12. Hiển thị kết quả thành công
else [Dữ liệu không hợp lệ]
  Controller --> Form : 10. Thông báo thiếu hồ sơ hoặc dữ liệu CV lỗi
  Form --> UI : 11. Hiển thị lỗi tại màn hình
  UI --> Actor : 12. Yêu cầu kiểm tra lại thông tin
end
deactivate Controller
deactivate Form
deactivate UI
@enduml
