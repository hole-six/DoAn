@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam titleFontSize 18
skinparam shadowing false
skinparam linetype ortho
skinparam sequenceMessageAlign center
skinparam sequence {
  ArrowColor #222222
  LifeLineBorderColor #666666
  LifeLineBackgroundColor #F7F7F7
  ParticipantBorderColor #222222
  ParticipantBackgroundColor White
  ActorBorderColor #222222
  ActorBackgroundColor White
  BoxBorderColor #888888
  GroupBorderColor #222222
  GroupHeaderFontColor #222222
}
title Sơ đồ Duyệt hồ sơ công ty

actor "Actor: Quản trị viên" as Actor
boundary "UI: quan-tri-cong-ty" as UI
boundary "UI: form-duyet-cong-ty" as Form
control "Controller: NhaTuyenDungController" as Controller
entity "Entity: NhaTuyenDung" as MainEntity
entity "Entity: ThongBao" as E1

Actor -> UI : 1. Mở danh sách công ty chờ duyệt
activate UI
UI -> Form : 2. Hiển thị form-duyet-cong-ty
activate Form
Actor -> Form : 3. Xem hồ sơ và chọn duyệt hoặc từ chối
Form -> Controller : 4. PATCH /nhatuyendung/:ma {trangThaiDuyet}
activate Controller
Controller -> MainEntity : 5. Kiểm tra hồ sơ công ty hiện tại
activate MainEntity
MainEntity --> Controller : 6. return kết quả kiểm tra
deactivate MainEntity

alt Dữ liệu hợp lệ
  Controller -> MainEntity : 7. Cập nhật trạng thái duyệt công ty (lý do từ chối không bắt buộc)
  activate MainEntity
  MainEntity --> Controller : 8. return dữ liệu đã cập nhật
  deactivate MainEntity
  Controller -> E1 : 9. Tạo ThôngBáo kết quả duyệt cho nhà tuyển dụng
  Controller --> Form : 10. Thông báo xử lý hồ sơ công ty thành công
  Form --> UI : 11. Cập nhật giao diện
  UI --> Actor : 12. Hiển thị kết quả thành công
else Dữ liệu không hợp lệ
  Controller --> Form : 10. Thông báo hồ sơ công ty không hợp lệ
  Form --> UI : 11. Hiển thị lỗi tại màn hình
  UI --> Actor : 12. Yêu cầu kiểm tra lại thông tin
end
deactivate Controller
deactivate Form
deactivate UI
@enduml
