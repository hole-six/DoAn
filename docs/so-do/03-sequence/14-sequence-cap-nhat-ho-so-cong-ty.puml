@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam titleFontSize 18
skinparam shadowing false
skinparam linetype ortho
skinparam sequenceMessageAlign center
skinparam sequence {
  ArrowColor #222222
  LifeLineBorderColor #666666
  LifeLineBackgroundColor #F7F7F7
  ParticipantBorderColor #222222
  ParticipantBackgroundColor White
  ActorBorderColor #222222
  ActorBackgroundColor White
  BoxBorderColor #888888
  GroupBorderColor #222222
  GroupHeaderFontColor #222222
}
title Sơ đồ Cập nhật hồ sơ công ty

actor "Actor: Nhà tuyển dụng" as Actor
boundary "UI: thong-tin-cong-ty" as UI
boundary "UI: form-ho-so-cong-ty" as Form
control "Controller: NhaTuyenDungController" as Controller
entity "Entity: NhaTuyenDung" as MainEntity
entity "Entity: ThongBao" as ThongBao

Actor -> UI : 1. Mở trang thông tin công ty
activate UI
UI -> Form : 2. Hiển thị form-ho-so-cong-ty
activate Form
Actor -> Form : 3. Cập nhật mã số thuế, địa chỉ, logo, mô tả
Form -> Controller : 4. PATCH /nhatuyendung/:ma capNhat(request)
activate Controller
note over Controller : Route /nhatuyendung chỉ gắn người dùng nếu có\nController generic, không kiểm tra quyền sở hữu
Controller -> MainEntity : 5. Lấy hồ sơ hiện tại (trangThaiCu)
activate MainEntity
MainEntity --> Controller : 6. return hồ sơ và trạng thái duyệt
deactivate MainEntity

alt Dữ liệu hợp lệ
  Controller -> MainEntity : 7. Cập nhật hồ sơ công ty
  activate MainEntity
  MainEntity --> Controller : 8. return dữ liệu đã cập nhật
  deactivate MainEntity
  opt trangThaiCu == 'tu_choi' và có cập nhật nội dung và trangThaiMoi != 'da_duyet'
    Controller -> MainEntity : 9. Đặt lại trạng thái về cho_duyet
    Controller -> ThongBao : 10. Gửi thông báo admin duyệt lại hồ sơ
  end
  Controller --> Form : 11. Thông báo cập nhật thành công
  Form --> UI : 12. Cập nhật giao diện
  UI --> Actor : 13. Hiển thị kết quả thành công
else Dữ liệu không hợp lệ
  Controller --> Form : 11. Thông báo lỗi dữ liệu / trạng thái
  Form --> UI : 12. Hiển thị lỗi tại màn hình
  UI --> Actor : 13. Yêu cầu kiểm tra lại thông tin
end
deactivate Controller
deactivate Form
deactivate UI
@enduml
