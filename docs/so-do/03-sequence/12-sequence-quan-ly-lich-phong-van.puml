@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam titleFontSize 18
skinparam shadowing false
skinparam linetype ortho
skinparam sequenceMessageAlign center
skinparam sequence {
  ArrowColor #222222
  LifeLineBorderColor #666666
  LifeLineBackgroundColor #F7F7F7
  ParticipantBorderColor #222222
  ParticipantBackgroundColor White
  ActorBorderColor #222222
  ActorBackgroundColor White
  BoxBorderColor #888888
  GroupBorderColor #222222
  GroupHeaderFontColor #222222
}
title Sơ đồ Quản lý lịch phỏng vấn

actor "Actor: Ứng viên" as Actor
boundary "UI: lich-phong-van" as UI
boundary "UI: form-phan-hoi-lich" as Form
control "Controller: LichPhongVanController" as Controller
entity "Entity: LichPhongVan" as LichPhongVan
entity "Entity: HoSoUngTuyen" as HoSoUngTuyen
entity "Entity: UngVien" as UngVien
entity "Entity: ThongBao" as ThongBao

Actor -> UI : 1. Mở trang lịch phỏng vấn
activate UI
Form -> Controller : 2. GET /lichphongvan
activate Controller
Controller -> LichPhongVan : 3. Lấy lịch của ứng viên hiện tại
Controller -> HoSoUngTuyen : 4. Populate hồ sơ ứng tuyển
Controller -> UngVien : 5. Kiểm tra hồ sơ thuộc ứng viên
Controller --> Form : 6. Trả danh sách lịch
deactivate Controller
UI -> Form : 7. Hiển thị lịch và nút phản hồi
activate Form

alt Xác nhận lịch
  Actor -> Form : 8. Nhấn xác nhận
  Form -> Controller : 9. POST /lichphongvan/:ma/xac-nhan
  activate Controller
  Controller -> LichPhongVan : 10. Cập nhật trạng thái da_xac_nhan
  Controller -> ThongBao : 11. Báo nhà tuyển dụng
  Controller --> Form : 12. Trả lịch đã cập nhật
else Yêu cầu đổi lịch
  Actor -> Form : 8. Nhập ghi chú đổi lịch
  Form -> Controller : 9. POST /lichphongvan/:ma/doi-lich
  activate Controller
  Controller -> LichPhongVan : 10. Cập nhật trạng thái yeu_cau_doi_lich
  Controller -> ThongBao : 11. Báo nhà tuyển dụng
  Controller --> Form : 12. Trả lịch đã cập nhật
else Hủy lịch
  Actor -> Form : 8. Nhập lý do hủy
  Form -> Controller : 9. POST /lichphongvan/:ma/huy
  activate Controller
  Controller -> LichPhongVan : 10. Cập nhật trạng thái da_huy
  Controller -> ThongBao : 11. Báo nhà tuyển dụng
  Controller --> Form : 12. Trả lịch đã cập nhật
end

Form --> UI : 13. Cập nhật trạng thái lịch
UI --> Actor : 14. Hiển thị kết quả thao tác
deactivate Controller
deactivate Form
deactivate UI
@enduml
