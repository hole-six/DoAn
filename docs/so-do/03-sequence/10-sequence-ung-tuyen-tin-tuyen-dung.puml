@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam titleFontSize 18
skinparam shadowing false
skinparam linetype ortho
skinparam sequenceMessageAlign center
skinparam ParticipantPadding 24
skinparam BoxPadding 8
skinparam sequence {
  ArrowColor #222222
  LifeLineBorderColor #666666
  LifeLineBackgroundColor #F7F7F7
  ParticipantBorderColor #222222
  ParticipantBackgroundColor White
  ActorBorderColor #222222
  ActorBackgroundColor White
  BoxBorderColor #888888
}
title sd Ứng tuyển tin tuyển dụng

actor "Actor: Ứng viên" as Actor
boundary "UI: chi-tiet-viec-lam" as UI
boundary "UI: form-ung-tuyen" as Form
control "Controller: HoSoUngTuyenController" as Controller
entity "Entity: HoSoUngTuyen" as MainEntity
entity "Entity: TinTuyenDung" as E1
entity "Entity: HoSoNangLuc" as E2
entity "Entity: ThongBao" as E3

Actor -> UI : 1. Nhấn Ứng tuyển ngay
activate UI
UI -> Form : 2. Hiển thị form-ung-tuyen
activate Form
Actor -> Form : 3. Chọn CV và nhập thư ứng tuyển
Form -> Controller : 4. ungTuyen(request)
activate Controller
Controller -> MainEntity : 5. Kiểm tra tin đang mở, CV và hồ sơ ứng viên
activate MainEntity
MainEntity --> Controller : 6. return kết quả kiểm tra
deactivate MainEntity

alt [Dữ liệu hợp lệ]
  Controller -> MainEntity : 7. Tạo hồ sơ ứng tuyển
  activate MainEntity
  MainEntity --> Controller : 8. return dữ liệu đã cập nhật
  deactivate MainEntity
  Controller -> E1 : 9. Gửi thông báo cho nhà tuyển dụng
  Controller --> Form : 10. Thông báo ứng tuyển thành công
  Form --> UI : 11. Cập nhật giao diện
  UI --> Actor : 12. Hiển thị kết quả thành công
else [Dữ liệu không hợp lệ]
  Controller --> Form : 10. Thông báo đã ứng tuyển hoặc thiếu CV
  Form --> UI : 11. Hiển thị lỗi tại màn hình
  UI --> Actor : 12. Yêu cầu kiểm tra lại thông tin
end
deactivate Controller
deactivate Form
deactivate UI
@enduml
