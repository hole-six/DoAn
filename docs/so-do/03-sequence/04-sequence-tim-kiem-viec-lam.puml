@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam titleFontSize 18
skinparam shadowing false
skinparam linetype ortho
skinparam sequenceMessageAlign center
skinparam sequence {
  ArrowColor #222222
  LifeLineBorderColor #666666
  LifeLineBackgroundColor #F7F7F7
  ParticipantBorderColor #222222
  ParticipantBackgroundColor White
  ActorBorderColor #222222
  ActorBackgroundColor White
  BoxBorderColor #888888
  GroupBorderColor #222222
  GroupHeaderFontColor #222222
}
title Sơ đồ Tìm kiếm việc làm

actor "Actor: Khách vãng lai / Ứng viên" as Actor
boundary "UI: viec-lam" as UI
boundary "UI: bo-loc-viec-lam" as Form
control "Controller: TinTuyenDungController" as Controller
entity "Entity: TinTuyenDung" as MainEntity
entity "Entity: DanhMucKyNang" as E1
entity "Entity: TinTuyenDungKyNang" as TinTuyenDungKyNang
entity "Entity: NhaTuyenDung" as E2

Actor -> UI : 1. Truy cập trang việc làm
activate UI
UI -> Form : 2. Hiển thị bo-loc-viec-lam
activate Form
Actor -> Form : 3. Nhập từ khóa và chọn bộ lọc
Form -> Controller : 4. timKiemTinTuyenDung(filter)
activate Controller
Controller -> MainEntity : 5. Chuẩn hóa từ khóa, kỹ năng, địa điểm
activate MainEntity
MainEntity --> Controller : 6. return kết quả kiểm tra
deactivate MainEntity

alt Dữ liệu hợp lệ
  Controller -> MainEntity : 7. Tìm tin đang mở phù hợp
  activate MainEntity
  MainEntity --> Controller : 8. return dữ liệu đã cập nhật
  deactivate MainEntity
  Controller -> E1 : 9. Lấy kỹ năng và công ty liên quan
  Controller --> Form : 10. Trả danh sách việc làm
  Form --> UI : 11. Cập nhật giao diện
  UI --> Actor : 12. Hiển thị kết quả thành công
else Dữ liệu không hợp lệ
  Controller --> Form : 10. Thông báo không tìm thấy dữ liệu phù hợp
  Form --> UI : 11. Hiển thị lỗi tại màn hình
  UI --> Actor : 12. Yêu cầu kiểm tra lại thông tin
end
Controller -> TinTuyenDungKyNang : Lấy liên kết kỹ năng của tin phù hợp
deactivate Controller
deactivate Form
deactivate UI
@enduml
