@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam titleFontSize 18
skinparam shadowing false
skinparam linetype ortho
skinparam sequenceMessageAlign center
skinparam ParticipantPadding 24
skinparam BoxPadding 8
skinparam sequence {
  ArrowColor #222222
  LifeLineBorderColor #666666
  LifeLineBackgroundColor #F7F7F7
  ParticipantBorderColor #222222
  ParticipantBackgroundColor White
  ActorBorderColor #222222
  ActorBackgroundColor White
  BoxBorderColor #888888
}
title sd Cập nhật thông tin tài khoản

actor "Actor: Ứng viên / Nhà tuyển dụng / Quản trị viên" as Actor
boundary "UI: cai-dat-tai-khoan" as UI
boundary "UI: form-cap-nhat-tai-khoan" as Form
control "Controller: NguoiDungController" as Controller
entity "Entity: TaiKhoan" as MainEntity
entity "Entity: ThongBao" as E1

Actor -> UI : 1. Mở trang cài đặt tài khoản
activate UI
UI -> Form : 2. Hiển thị form-cap-nhat-tai-khoan
activate Form
Actor -> Form : 3. Chỉnh sửa họ tên, số điện thoại, mật khẩu
Form -> Controller : 4. capNhatTaiKhoan(request)
activate Controller
Controller -> MainEntity : 5. Kiểm tra quyền sở hữu và dữ liệu nhập
activate MainEntity
MainEntity --> Controller : 6. return kết quả kiểm tra
deactivate MainEntity

alt [Dữ liệu hợp lệ]
  Controller -> MainEntity : 7. Cập nhật thông tin tài khoản
  activate MainEntity
  MainEntity --> Controller : 8. return dữ liệu đã cập nhật
  deactivate MainEntity
  Controller -> E1 : 9. Ghi nhận thông báo bảo mật nếu cần
  Controller --> Form : 10. Thông báo cập nhật thành công
  Form --> UI : 11. Cập nhật giao diện
  UI --> Actor : 12. Hiển thị kết quả thành công
else [Dữ liệu không hợp lệ]
  Controller --> Form : 10. Thông báo dữ liệu không hợp lệ
  Form --> UI : 11. Hiển thị lỗi tại màn hình
  UI --> Actor : 12. Yêu cầu kiểm tra lại thông tin
end
deactivate Controller
deactivate Form
deactivate UI
@enduml
