@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam titleFontSize 18
skinparam shadowing false
skinparam linetype ortho
skinparam sequenceMessageAlign center
skinparam sequence {
  ArrowColor #222222
  LifeLineBorderColor #666666
  LifeLineBackgroundColor #F7F7F7
  ParticipantBorderColor #222222
  ParticipantBackgroundColor White
  ActorBorderColor #222222
  ActorBackgroundColor White
  BoxBorderColor #888888
  GroupBorderColor #222222
  GroupHeaderFontColor #222222
}
title Sơ đồ Mời ứng viên phỏng vấn

actor "Actor: Nhà tuyển dụng" as Actor
boundary "UI: pipeline-ung-vien" as UI
boundary "UI: form-moi-phong-van (ScheduleModal)" as Form
control "Controller: HoSoUngTuyenController" as Controller
entity "Entity: HoSoUngTuyen" as HoSoUngTuyen
entity "Entity: TinTuyenDung" as TinTuyenDung
entity "Entity: UngVien" as UngVien
entity "Entity: LichPhongVan" as LichPhongVan
entity "Entity: LichSuHoSoUngTuyen" as LichSuHoSoUngTuyen
entity "Entity: ThongBao" as ThongBao

Actor -> UI : 1. Chọn hồ sơ trong pipeline, nhấn "Mời phỏng vấn"
activate UI
UI -> Form : 2. Mở ScheduleModal
activate Form
Actor -> Form : 3. Nhập thời gian, hình thức, địa chỉ/link họp, ghi chú
Form -> Controller : 4. POST /hosoungtuyen/:ma/moi-phong-van moiPhongVan(request)
activate Controller
Controller -> HoSoUngTuyen : 5. Lấy hồ sơ ứng tuyển
HoSoUngTuyen --> Controller : 6. Trả hồ sơ
Controller -> TinTuyenDung : 7. Kiểm tra hồ sơ thuộc công ty (qua tin)
Controller -> LichPhongVan : 8. Kiểm tra hồ sơ đã có lịch phỏng vấn chưa

alt Hợp lệ (trạng thái da_xem/dang_xet_duyet, chưa có lịch, thời gian hợp lệ)
  Controller -> LichPhongVan : 9. Tạo lịch (da_len_lich, ketQua cho_ket_qua)
  LichPhongVan --> Controller : 10. Trả lịch đã tạo
  Controller -> HoSoUngTuyen : 11. Cập nhật trạng thái hồ sơ thành moi_phong_van
  Controller -> LichSuHoSoUngTuyen : 12. Ghi lịch sử trạng thái "moi_phong_van"
  Controller -> UngVien : 13. Lấy người dùng ứng viên để gửi thông báo
  Controller -> ThongBao : 14. thongBaoMoiPhongVan cho ứng viên
  Controller --> Form : 15. Trả lịch phỏng vấn mới
  Form --> UI : 16. Cập nhật pipeline
  UI --> Actor : 17. Hiển thị gửi lời mời thành công
else Không hợp lệ (sai trạng thái, đã có lịch, thời gian không hợp lệ)
  Controller --> Form : 15. Trả lỗi nghiệp vụ
  Form --> UI : 16. Hiển thị lỗi tại màn hình
  UI --> Actor : 17. Yêu cầu kiểm tra lại dữ liệu lịch
end
deactivate Controller
deactivate Form
deactivate UI
@enduml
