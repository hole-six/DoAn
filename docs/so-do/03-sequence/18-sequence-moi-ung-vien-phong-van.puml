@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam titleFontSize 18
skinparam shadowing false
skinparam linetype ortho
skinparam sequenceMessageAlign center
skinparam sequence {
  ArrowColor #222222
  LifeLineBorderColor #666666
  LifeLineBackgroundColor #F7F7F7
  ParticipantBorderColor #222222
  ParticipantBackgroundColor White
  ActorBorderColor #222222
  ActorBackgroundColor White
  BoxBorderColor #888888
  GroupBorderColor #222222
  GroupHeaderFontColor #222222
}
title Sơ đồ Mời ứng viên phỏng vấn

actor "Actor: Nhà tuyển dụng" as Actor
boundary "UI: pipeline-ung-vien" as UI
boundary "UI: form-moi-phong-van" as Form
control "Controller: HoSoUngTuyenController" as Controller
entity "Entity: HoSoUngTuyen" as HoSoUngTuyen
entity "Entity: LichPhongVan" as LichPhongVan
entity "Entity: LichSuHoSoUngTuyen" as LichSuHoSoUngTuyen
entity "Entity: NhaTuyenDung" as NhaTuyenDung
entity "Entity: TinTuyenDung" as TinTuyenDung
entity "Entity: ThongBao" as ThongBao

Actor -> UI : 1. Chọn hồ sơ trong pipeline
activate UI
UI -> Form : 2. Mở form mời phỏng vấn
activate Form
Actor -> Form : 3. Nhập thời gian bắt đầu, kết thúc, hình thức, địa điểm hoặc link
Form -> Controller : 4. POST /hosoungtuyen/:ma/moi-phong-van
activate Controller
Controller -> HoSoUngTuyen : 5. Lấy hồ sơ ứng tuyển
HoSoUngTuyen --> Controller : 6. Trả hồ sơ
Controller -> NhaTuyenDung : 7. Kiểm tra hồ sơ thuộc công ty hiện tại
Controller -> TinTuyenDung : 8. Kiểm tra tin tuyển dụng liên quan

alt Hợp lệ
  Controller -> LichPhongVan : 9. Tạo lịch phỏng vấn
  LichPhongVan --> Controller : 10. Trả lịch mới
  Controller -> HoSoUngTuyen : 11. Cập nhật trạng thái moi_phong_van
  HoSoUngTuyen --> Controller : 12. Trả hồ sơ đã cập nhật
  Controller -> LichSuHoSoUngTuyen : 13. Ghi lịch sử hồ sơ ứng tuyển với trạng thái "moi_phong_van"
  Controller -> ThongBao : 14. Báo ứng viên có lịch phỏng vấn
  Controller --> Form : 15. Trả lịch phỏng vấn
  Form --> UI : 16. Cập nhật pipeline và lịch
  UI --> Actor : 17. Hiển thị mời phỏng vấn thành công
else Không hợp lệ
  Controller --> Form : 14. Trả lỗi quyền, hồ sơ hoặc thời gian
  Form --> UI : 15. Hiển thị lỗi
  UI --> Actor : 16. Yêu cầu sửa thông tin
end

deactivate Controller
deactivate Form
deactivate UI
@enduml
