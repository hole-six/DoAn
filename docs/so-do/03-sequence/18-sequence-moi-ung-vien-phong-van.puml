@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam titleFontSize 18
skinparam shadowing false
skinparam linetype ortho
skinparam sequenceMessageAlign center
skinparam ParticipantPadding 24
skinparam BoxPadding 8
skinparam sequence {
  ArrowColor #222222
  LifeLineBorderColor #666666
  LifeLineBackgroundColor #F7F7F7
  ParticipantBorderColor #222222
  ParticipantBackgroundColor White
  ActorBorderColor #222222
  ActorBackgroundColor White
  BoxBorderColor #888888
}
title sd Mời ứng viên phỏng vấn

actor "Actor: Nhà tuyển dụng" as Actor
boundary "UI: pipeline-ung-vien" as UI
boundary "UI: form-moi-phong-van" as Form
control "Controller: LichPhongVanController" as Controller
entity "Entity: LichPhongVan" as MainEntity
entity "Entity: HoSoUngTuyen" as E1
entity "Entity: ThongBao" as E2

Actor -> UI : 1. Chọn hồ sơ để mời phỏng vấn
activate UI
UI -> Form : 2. Hiển thị form-moi-phong-van
activate Form
Actor -> Form : 3. Chọn thời gian, hình thức, địa điểm hoặc link online
Form -> Controller : 4. taoLichPhongVan(request)
activate Controller
Controller -> MainEntity : 5. Kiểm tra hồ sơ đủ điều kiện và thời gian hợp lệ
activate MainEntity
MainEntity --> Controller : 6. return kết quả kiểm tra
deactivate MainEntity

alt [Dữ liệu hợp lệ]
  Controller -> MainEntity : 7. Tạo lịch phỏng vấn
  activate MainEntity
  MainEntity --> Controller : 8. return dữ liệu đã cập nhật
  deactivate MainEntity
  Controller -> E1 : 9. Cập nhật hồ sơ sang mời phỏng vấn và báo ứng viên
  Controller --> Form : 10. Thông báo đã gửi lời mời phỏng vấn
  Form --> UI : 11. Cập nhật giao diện
  UI --> Actor : 12. Hiển thị kết quả thành công
else [Dữ liệu không hợp lệ]
  Controller --> Form : 10. Thông báo thời gian hoặc hình thức không hợp lệ
  Form --> UI : 11. Hiển thị lỗi tại màn hình
  UI --> Actor : 12. Yêu cầu kiểm tra lại thông tin
end
deactivate Controller
deactivate Form
deactivate UI
@enduml
