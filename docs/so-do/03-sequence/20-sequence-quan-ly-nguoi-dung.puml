@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam titleFontSize 18
skinparam shadowing false
skinparam linetype ortho
skinparam sequenceMessageAlign center
skinparam ParticipantPadding 24
skinparam BoxPadding 8
skinparam sequence {
  ArrowColor #222222
  LifeLineBorderColor #666666
  LifeLineBackgroundColor #F7F7F7
  ParticipantBorderColor #222222
  ParticipantBackgroundColor White
  ActorBorderColor #222222
  ActorBackgroundColor White
  BoxBorderColor #888888
}
title sd Quản lý người dùng

actor "Actor: Quản trị viên" as Actor
boundary "UI: quan-tri-nguoi-dung" as UI
boundary "UI: form-tai-khoan" as Form
control "Controller: NguoiDungController" as Controller
entity "Entity: TaiKhoan" as MainEntity
entity "Entity: UngVien" as E1
entity "Entity: NhaTuyenDung" as E2
entity "Entity: ThongBao" as E3

Actor -> UI : 1. Mở trang quản lý người dùng
activate UI
UI -> Form : 2. Hiển thị form-tai-khoan
activate Form
Actor -> Form : 3. Tìm kiếm, thêm, sửa, khóa hoặc xóa tài khoản
Form -> Controller : 4. quanLyTaiKhoan(request)
activate Controller
Controller -> MainEntity : 5. Kiểm tra quyền quản trị và ràng buộc tài khoản
activate MainEntity
MainEntity --> Controller : 6. return kết quả kiểm tra
deactivate MainEntity

alt [Dữ liệu hợp lệ]
  Controller -> MainEntity : 7. Cập nhật tài khoản
  activate MainEntity
  MainEntity --> Controller : 8. return dữ liệu đã cập nhật
  deactivate MainEntity
  Controller -> E1 : 9. Đồng bộ hồ sơ ứng viên hoặc công ty liên quan
  Controller --> Form : 10. Trả danh sách tài khoản mới
  Form --> UI : 11. Cập nhật giao diện
  UI --> Actor : 12. Hiển thị kết quả thành công
else [Dữ liệu không hợp lệ]
  Controller --> Form : 10. Thông báo thao tác tài khoản không hợp lệ
  Form --> UI : 11. Hiển thị lỗi tại màn hình
  UI --> Actor : 12. Yêu cầu kiểm tra lại thông tin
end
deactivate Controller
deactivate Form
deactivate UI
@enduml
