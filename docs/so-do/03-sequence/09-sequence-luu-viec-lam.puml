@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam titleFontSize 18
skinparam shadowing false
skinparam linetype ortho
skinparam sequenceMessageAlign center
skinparam sequence {
  ArrowColor #222222
  LifeLineBorderColor #666666
  LifeLineBackgroundColor #F7F7F7
  ParticipantBorderColor #222222
  ParticipantBackgroundColor White
  ActorBorderColor #222222
  ActorBackgroundColor White
  BoxBorderColor #888888
  GroupBorderColor #222222
  GroupHeaderFontColor #222222
}
title Sơ đồ Lưu việc làm

actor "Actor: Ứng viên" as Actor
boundary "UI: chi-tiet-viec-lam" as UI
boundary "UI: nut-luu-viec-lam" as Form
control "Controller: ViecLamDaLuuController" as Controller
entity "Entity: ViecLamDaLuu" as MainEntity
entity "Entity: TinTuyenDung" as E1
entity "Entity: UngVien" as E2

Actor -> UI : 1. Mở chi tiết việc làm
activate UI
UI -> Form : 2. Hiển thị nut-luu-viec-lam
activate Form
Actor -> Form : 3. Nhấn nút Lưu hoặc Bỏ lưu
Form -> Controller : 4. toggleLuuViecLam(maTin)
activate Controller
Controller -> MainEntity : 5. Kiểm tra vai trò ứng viên và tin đang tồn tại
activate MainEntity
MainEntity --> Controller : 6. return kết quả kiểm tra
deactivate MainEntity

alt Dữ liệu hợp lệ
  Controller -> MainEntity : 7. Tạo hoặc xóa bản ghi việc làm đã lưu
  activate MainEntity
  MainEntity --> Controller : 8. return dữ liệu đã cập nhật
  deactivate MainEntity
  Controller -> E1 : 9. Lấy lại trạng thái lưu hiện tại
  Controller --> Form : 10. Thông báo trạng thái lưu mới
  Form --> UI : 11. Cập nhật giao diện
  UI --> Actor : 12. Hiển thị kết quả thành công
else Dữ liệu không hợp lệ
  Controller --> Form : 10. Yêu cầu đăng nhập bằng tài khoản ứng viên
  Form --> UI : 11. Hiển thị lỗi tại màn hình
  UI --> Actor : 12. Yêu cầu kiểm tra lại thông tin
end
deactivate Controller
deactivate Form
deactivate UI
@enduml
