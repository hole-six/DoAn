@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam titleFontSize 18
skinparam shadowing false
skinparam linetype ortho
skinparam sequenceMessageAlign center
skinparam sequence {
  ArrowColor #222222
  LifeLineBorderColor #666666
  LifeLineBackgroundColor #F7F7F7
  ParticipantBorderColor #222222
  ParticipantBackgroundColor White
  ActorBorderColor #222222
  ActorBackgroundColor White
  BoxBorderColor #888888
  GroupBorderColor #222222
  GroupHeaderFontColor #222222
}
title Sơ đồ Lưu việc làm

actor "Actor: Ứng viên" as Actor
boundary "UI: chi-tiet-viec-lam" as UI
boundary "UI: nut-luu-viec-lam" as Form
control "Controller: ViecLamDaLuuController" as Controller
entity "Entity: ViecLamDaLuu" as MainEntity
entity "Entity: TinTuyenDung" as TinTuyenDung
entity "Entity: NguoiDung" as NguoiDung

Actor -> UI : 1. Mở chi tiết việc làm
activate UI
UI -> Form : 2. Hiển thị nut-luu-viec-lam
activate Form
Actor -> Form : 3. Nhấn nút Lưu hoặc Bỏ lưu
Form -> Controller : 4. POST|DELETE /viec-lam-da-luu/:maTinTuyenDung\n(yeuCauDangNhap + vai trò ung_vien)
activate Controller
Controller -> NguoiDung : 5. Lấy maNguoiDung từ phiên đăng nhập
activate NguoiDung
NguoiDung --> Controller : 6. return maNguoiDung
deactivate NguoiDung

alt Thao tác Lưu (POST)
  Controller -> TinTuyenDung : 7. Kiểm tra tin tuyển dụng tồn tại theo mã
  activate TinTuyenDung
  TinTuyenDung --> Controller : 8. return tin (hoặc 404 JOB_NOT_FOUND)
  deactivate TinTuyenDung
  Controller -> MainEntity : 9. upsert ViecLamDaLuu theo (maNguoiDung, maTinTuyenDung)
  Controller --> Form : 10. Trả "Đã lưu việc làm" kèm bản ghi
  Form --> UI : 11. Cập nhật nút thành Đã lưu
  UI --> Actor : 12. Hiển thị đã lưu việc làm
else Thao tác Bỏ lưu (DELETE)
  Controller -> MainEntity : 9. Xóa ViecLamDaLuu theo (maNguoiDung, maTinTuyenDung)
  Controller --> Form : 10. Trả "Đã bỏ lưu việc làm"
  Form --> UI : 11. Cập nhật nút thành Chưa lưu
  UI --> Actor : 12. Hiển thị đã bỏ lưu việc làm
end
deactivate Controller
deactivate Form
deactivate UI
@enduml
