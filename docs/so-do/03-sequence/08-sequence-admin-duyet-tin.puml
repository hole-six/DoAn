@startuml
skinparam shadowing false
title Sequence - Quản trị viên duyệt tin tuyển dụng

actor "Quản trị viên" as Admin
boundary "DashboardQuảnTrị" as UI
control "AdminTinController" as Controller
entity "TinTuyểnDụng" as Job
entity "ThôngBáo" as Notify
database "MongoDB" as DB

Admin -> UI : Chọn tin chờ duyệt
UI -> Controller : PATCH /api/admin/tintuyendung/{id}/duyet
Controller -> Job : cập nhật trạng thái
Job -> DB : update
alt Duyệt
  Controller -> Notify : thông báo tin đã duyệt cho NTD
else Từ chối
  Controller -> Notify : thông báo lý do từ chối cho NTD
end
Notify -> DB : insert
Controller --> UI : kết quả
UI --> Admin : cập nhật danh sách
@enduml

