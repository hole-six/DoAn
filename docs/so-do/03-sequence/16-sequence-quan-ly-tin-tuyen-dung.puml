@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam titleFontSize 18
skinparam shadowing false
skinparam linetype ortho
skinparam sequenceMessageAlign center
skinparam sequence {
  ArrowColor #222222
  LifeLineBorderColor #666666
  LifeLineBackgroundColor #F7F7F7
  ParticipantBorderColor #222222
  ParticipantBackgroundColor White
  ActorBorderColor #222222
  ActorBackgroundColor White
  BoxBorderColor #888888
  GroupBorderColor #222222
  GroupHeaderFontColor #222222
}
title Sơ đồ Quản lý tin tuyển dụng

actor "Actor: Nhà tuyển dụng" as Actor
boundary "UI: quan-ly-tin" as UI
boundary "UI: form-sua-tin" as Form
control "Controller: TinTuyenDungController" as Controller
entity "Entity: TinTuyenDung" as MainEntity
entity "Entity: TinTuyenDungKyNang" as TinTuyenDungKyNang

Actor -> UI : 1. Mở trang quản lý tin
activate UI
UI -> Form : 2. Hiển thị form-sua-tin
activate Form
Actor -> Form : 3. Tìm kiếm, sửa, tạm đóng, mở lại hoặc xóa tin

alt Sửa nội dung tin
  Form -> Controller : 4. PATCH /tintuyendung/:ma capNhat(request)
  activate Controller
  Controller -> MainEntity : 5. Kiểm tra tin thuộc công ty và trạng thái cho phép sửa
  activate MainEntity
  MainEntity --> Controller : 6. return kết quả kiểm tra
  deactivate MainEntity
  Controller -> MainEntity : 7. Cập nhật nội dung tin
  Controller -> TinTuyenDungKyNang : 8. deleteMany rồi createMany đồng bộ kỹ năng
  Controller --> Form : 9. Trả tin đã cập nhật
  deactivate Controller
else Tạm đóng / Mở lại
  Form -> Controller : 4. POST /tintuyendung/:ma/tam-dong | /:ma/mo-lai
  activate Controller
  Controller -> MainEntity : 5. Cập nhật trạng thái tam_dong hoặc dang_mo
  Controller --> Form : 6. Trả tin đã cập nhật
  deactivate Controller
else Xóa tin
  Form -> Controller : 4. DELETE /tintuyendung/:ma
  activate Controller
  Controller -> MainEntity : 5. Xóa tin tuyển dụng
  Controller --> Form : 6. Trả kết quả xóa
  deactivate Controller
end

Form --> UI : 10. Cập nhật danh sách tin
UI --> Actor : 11. Hiển thị kết quả thao tác
deactivate Form
deactivate UI
@enduml
