@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam titleFontSize 18
skinparam shadowing false
skinparam linetype ortho
skinparam sequenceMessageAlign center
skinparam sequence {
  ArrowColor #222222
  LifeLineBorderColor #666666
  LifeLineBackgroundColor #F7F7F7
  ParticipantBorderColor #222222
  ParticipantBackgroundColor White
  ActorBorderColor #222222
  ActorBackgroundColor White
  BoxBorderColor #888888
  GroupBorderColor #222222
  GroupHeaderFontColor #222222
}
title Sơ đồ Quản lý tin tuyển dụng

actor "Actor: Nhà tuyển dụng" as Actor
boundary "UI: quan-ly-tin" as UI
boundary "UI: form-sua-tin" as Form
control "Controller: TinTuyenDungController" as Controller
entity "Entity: TinTuyenDung" as MainEntity
entity "Entity: NhaTuyenDung" as E1
entity "Entity: DanhMucKyNang" as E2

Actor -> UI : 1. Mở trang quản lý tin
activate UI
UI -> Form : 2. Hiển thị form-sua-tin
activate Form
Actor -> Form : 3. Tìm kiếm, sửa, đóng, mở hoặc xóa tin
Form -> Controller : 4. capNhatTinTuyenDung(request)
activate Controller
Controller -> MainEntity : 5. Kiểm tra tin thuộc công ty và trạng thái cho phép
activate MainEntity
MainEntity --> Controller : 6. return kết quả kiểm tra
deactivate MainEntity

alt Dữ liệu hợp lệ
  Controller -> MainEntity : 7. Cập nhật trạng thái hoặc nội dung tin
  activate MainEntity
  MainEntity --> Controller : 8. return dữ liệu đã cập nhật
  deactivate MainEntity
  Controller -> E1 : 9. Cập nhật kỹ năng liên quan nếu có
  Controller --> Form : 10. Trả danh sách tin mới
  Form --> UI : 11. Cập nhật giao diện
  UI --> Actor : 12. Hiển thị kết quả thành công
else Dữ liệu không hợp lệ
  Controller --> Form : 10. Thông báo không có quyền hoặc trạng thái không hợp lệ
  Form --> UI : 11. Hiển thị lỗi tại màn hình
  UI --> Actor : 12. Yêu cầu kiểm tra lại thông tin
end
deactivate Controller
deactivate Form
deactivate UI
@enduml
