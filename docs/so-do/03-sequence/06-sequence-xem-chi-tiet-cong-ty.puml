@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam titleFontSize 18
skinparam shadowing false
skinparam linetype ortho
skinparam sequenceMessageAlign center
skinparam sequence {
  ArrowColor #222222
  LifeLineBorderColor #666666
  LifeLineBackgroundColor #F7F7F7
  ParticipantBorderColor #222222
  ParticipantBackgroundColor White
  ActorBorderColor #222222
  ActorBackgroundColor White
  BoxBorderColor #888888
  GroupBorderColor #222222
  GroupHeaderFontColor #222222
}
title Sơ đồ Xem công ty

actor "Actor: Khách vãng lai / Ứng viên" as Actor
boundary "UI: chi-tiet-cong-ty" as UI
boundary "UI: khung-thong-tin-cong-ty" as Form
control "Controller: NhaTuyenDungController" as Controller
control "Controller: TinTuyenDungController" as TinController
control "Controller: DanhGiaCongTyController" as DanhGiaController
entity "Entity: NhaTuyenDung" as MainEntity
entity "Entity: NguoiDung" as NguoiDung
entity "Entity: TinTuyenDung" as TinTuyenDung
entity "Entity: DanhGiaCongTy" as DanhGiaCongTy

Actor -> UI : 1. Mở trang chi tiết công ty
activate UI
UI -> Form : 2. Hiển thị khung-thong-tin-cong-ty
activate Form
Actor -> Form : 3. Xem hồ sơ, tin đang mở và đánh giá

Form -> Controller : 4. GET /nhatuyendung/:ma (public)
activate Controller
Controller -> MainEntity : 5. Tìm công ty theo mã
activate MainEntity
MainEntity --> Controller : 6. return công ty (hoặc rỗng)
deactivate MainEntity

alt Công ty tồn tại
  Controller -> NguoiDung : 7. Gắn thông tin người dùng cho công ty (ganNguoiDungChoCongTy)
  Controller --> Form : 8. Trả hồ sơ công ty
  deactivate Controller

  Form -> TinController : 9. GET /tintuyendung
  activate TinController
  TinController -> TinTuyenDung : 10. Lấy danh sách tin tuyển dụng
  TinController --> Form : 11. Trả tin; client lọc theo công ty và trạng thái dang_mo
  deactivate TinController

  Form -> DanhGiaController : 12. GET /danhgiacongty
  activate DanhGiaController
  DanhGiaController -> DanhGiaCongTy : 13. Lấy danh sách đánh giá
  DanhGiaController --> Form : 14. Trả đánh giá; client lọc theo công ty và daDuyet
  deactivate DanhGiaController

  Form --> UI : 15. Cập nhật giao diện
  UI --> Actor : 16. Hiển thị chi tiết công ty, tin đang mở và điểm đánh giá
else Không tìm thấy (404)
  Controller --> Form : 8. Trả lỗi 404 không tìm thấy công ty
  deactivate Controller
  Form --> UI : 15. Hiển thị thông báo không tìm thấy công ty
  UI --> Actor : 16. Báo công ty không tồn tại
end
deactivate Form
deactivate UI
@enduml
