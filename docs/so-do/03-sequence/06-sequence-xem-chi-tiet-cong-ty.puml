@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam titleFontSize 18
skinparam shadowing false
skinparam linetype ortho
skinparam sequenceMessageAlign center
skinparam ParticipantPadding 24
skinparam BoxPadding 8
skinparam sequence {
  ArrowColor #222222
  LifeLineBorderColor #666666
  LifeLineBackgroundColor #F7F7F7
  ParticipantBorderColor #222222
  ParticipantBackgroundColor White
  ActorBorderColor #222222
  ActorBackgroundColor White
  BoxBorderColor #888888
}
title sd Xem chi tiết công ty

actor "Actor: Khách vãng lai / Ứng viên" as Actor
boundary "UI: chi-tiet-cong-ty" as UI
boundary "UI: khung-thong-tin-cong-ty" as Form
control "Controller: NhaTuyenDungController" as Controller
entity "Entity: NhaTuyenDung" as MainEntity
entity "Entity: TinTuyenDung" as E1
entity "Entity: ReviewCongTy" as E2

Actor -> UI : 1. Mở trang chi tiết công ty
activate UI
UI -> Form : 2. Hiển thị khung-thong-tin-cong-ty
activate Form
Actor -> Form : 3. Xem hồ sơ, đánh giá và tin đang mở
Form -> Controller : 4. layChiTietCongTy(maCongTy)
activate Controller
Controller -> MainEntity : 5. Kiểm tra công ty đã được duyệt
activate MainEntity
MainEntity --> Controller : 6. return kết quả kiểm tra
deactivate MainEntity

alt [Dữ liệu hợp lệ]
  Controller -> MainEntity : 7. Lấy hồ sơ công ty
  activate MainEntity
  MainEntity --> Controller : 8. return dữ liệu đã cập nhật
  deactivate MainEntity
  Controller -> E1 : 9. Lấy tin tuyển dụng và đánh giá liên quan
  Controller --> Form : 10. Hiển thị chi tiết công ty
  Form --> UI : 11. Cập nhật giao diện
  UI --> Actor : 12. Hiển thị kết quả thành công
else [Dữ liệu không hợp lệ]
  Controller --> Form : 10. Thông báo công ty không tồn tại hoặc chưa được duyệt
  Form --> UI : 11. Hiển thị lỗi tại màn hình
  UI --> Actor : 12. Yêu cầu kiểm tra lại thông tin
end
deactivate Controller
deactivate Form
deactivate UI
@enduml
