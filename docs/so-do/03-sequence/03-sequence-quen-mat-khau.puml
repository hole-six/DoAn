@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam titleFontSize 18
skinparam shadowing false
skinparam linetype ortho
skinparam sequenceMessageAlign center
skinparam ParticipantPadding 24
skinparam BoxPadding 8
skinparam sequence {
  ArrowColor #222222
  LifeLineBorderColor #666666
  LifeLineBackgroundColor #F7F7F7
  ParticipantBorderColor #222222
  ParticipantBackgroundColor White
  ActorBorderColor #222222
  ActorBackgroundColor White
  BoxBorderColor #888888
}
title sd Quên mật khẩu

actor "Actor: Khách vãng lai" as Actor
boundary "UI: quen-mat-khau" as UI
boundary "UI: form-quen-mat-khau" as Form
control "Controller: XacThucController" as Controller
entity "Entity: TaiKhoan" as MainEntity
entity "Entity: EmailDatLaiMatKhau" as E1

Actor -> UI : 1. Truy cập chức năng quên mật khẩu
activate UI
UI -> Form : 2. Hiển thị form-quen-mat-khau
activate Form
Actor -> Form : 3. Nhập email cần đặt lại mật khẩu
Form -> Controller : 4. yeuCauDatLaiMatKhau(email)
activate Controller
Controller -> MainEntity : 5. Kiểm tra tài khoản theo email
activate MainEntity
MainEntity --> Controller : 6. return kết quả kiểm tra
deactivate MainEntity

alt [Dữ liệu hợp lệ]
  Controller -> MainEntity : 7. Tạo mã đặt lại mật khẩu
  activate MainEntity
  MainEntity --> Controller : 8. return dữ liệu đã cập nhật
  deactivate MainEntity
  Controller -> E1 : 9. Gửi email chứa liên kết đặt lại
  Controller --> Form : 10. Thông báo đã gửi email hướng dẫn
  Form --> UI : 11. Cập nhật giao diện
  UI --> Actor : 12. Hiển thị kết quả thành công
else [Dữ liệu không hợp lệ]
  Controller --> Form : 10. Thông báo email không tồn tại hoặc không hợp lệ
  Form --> UI : 11. Hiển thị lỗi tại màn hình
  UI --> Actor : 12. Yêu cầu kiểm tra lại thông tin
end
deactivate Controller
deactivate Form
deactivate UI
@enduml
