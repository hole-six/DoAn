@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam titleFontSize 18
skinparam shadowing false
skinparam linetype ortho
skinparam sequenceMessageAlign center
skinparam sequence {
  ArrowColor #222222
  LifeLineBorderColor #666666
  LifeLineBackgroundColor #F7F7F7
  ParticipantBorderColor #222222
  ParticipantBackgroundColor White
  ActorBorderColor #222222
  ActorBackgroundColor White
  BoxBorderColor #888888
  GroupBorderColor #222222
  GroupHeaderFontColor #222222
}
title Sơ đồ Xem thống kê hệ thống

actor "Actor: Quản trị viên" as Actor
boundary "UI: quan-tri-dashboard" as UI
control "Controller: CanhBaoQuanTriController" as AlertController
entity "Entity: NguoiDung" as NguoiDung
entity "Entity: TinTuyenDung" as TinTuyenDung
entity "Entity: NhaTuyenDung" as NhaTuyenDung
entity "Entity: HoSoUngTuyen" as HoSoUngTuyen

Actor -> UI : 1. Mở dashboard quản trị
activate UI

UI -> NguoiDung : 2. GET /nguoidung
NguoiDung --> UI : 3. Trả danh sách người dùng
UI -> TinTuyenDung : 4. GET /tintuyendung
TinTuyenDung --> UI : 5. Trả danh sách tin tuyển dụng
UI -> NhaTuyenDung : 6. GET /nhatuyendung
NhaTuyenDung --> UI : 7. Trả danh sách công ty
UI -> HoSoUngTuyen : 8. GET /hosoungtuyen
HoSoUngTuyen --> UI : 9. Trả danh sách hồ sơ ứng tuyển

UI -> AlertController : 10. GET /canhbaoquantri
activate AlertController
AlertController -> TinTuyenDung : 11. Đếm tin chờ duyệt, quá hạn, sắp hết hạn
AlertController -> NhaTuyenDung : 12. Đếm công ty chờ duyệt, quá hạn
AlertController -> HoSoUngTuyen : 13. Đếm hồ sơ ứng tuyển mới trong 24 giờ
AlertController -> NguoiDung : 14. Đếm tài khoản bị khóa
AlertController --> UI : 15. Trả cảnh báo và thống kê vận hành
deactivate AlertController

alt Tải dữ liệu thành công
  UI -> UI : 16. Tổng hợp KPI và lọc tin chờ duyệt (client)
  UI --> Actor : 17. Hiển thị dashboard quản trị
else Tải dữ liệu thất bại
  UI --> Actor : 17. Hiển thị lỗi và cho phép thử lại
end
deactivate UI
@enduml
