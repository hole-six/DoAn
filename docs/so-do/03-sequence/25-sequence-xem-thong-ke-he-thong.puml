@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam titleFontSize 18
skinparam shadowing false
skinparam linetype ortho
skinparam sequenceMessageAlign center
skinparam ParticipantPadding 24
skinparam BoxPadding 8
skinparam sequence {
  ArrowColor #222222
  LifeLineBorderColor #666666
  LifeLineBackgroundColor #F7F7F7
  ParticipantBorderColor #222222
  ParticipantBackgroundColor White
  ActorBorderColor #222222
  ActorBackgroundColor White
  BoxBorderColor #888888
}
title sd Xem thống kê hệ thống

actor "Actor: Quản trị viên" as Actor
boundary "UI: quan-tri-dashboard" as UI
boundary "UI: bo-loc-thong-ke" as Form
control "Controller: ThongKeController" as Controller
entity "Entity: ThongKeHeThong" as MainEntity
entity "Entity: TaiKhoan" as E1
entity "Entity: TinTuyenDung" as E2
entity "Entity: HoSoUngTuyen" as E3
entity "Entity: NhaTuyenDung" as E4

Actor -> UI : 1. Mở dashboard quản trị
activate UI
UI -> Form : 2. Hiển thị bo-loc-thong-ke
activate Form
Actor -> Form : 3. Chọn khoảng thời gian hoặc loại thống kê
Form -> Controller : 4. layThongKeHeThong(filter)
activate Controller
Controller -> MainEntity : 5. Kiểm tra quyền quản trị và tham số thống kê
activate MainEntity
MainEntity --> Controller : 6. return kết quả kiểm tra
deactivate MainEntity

alt [Dữ liệu hợp lệ]
  Controller -> MainEntity : 7. Tổng hợp số liệu hệ thống
  activate MainEntity
  MainEntity --> Controller : 8. return dữ liệu đã cập nhật
  deactivate MainEntity
  Controller -> E1 : 9. Đếm người dùng, công ty, tin và hồ sơ ứng tuyển
  Controller --> Form : 10. Hiển thị biểu đồ và chỉ số thống kê
  Form --> UI : 11. Cập nhật giao diện
  UI --> Actor : 12. Hiển thị kết quả thành công
else [Dữ liệu không hợp lệ]
  Controller --> Form : 10. Thông báo không tải được dữ liệu thống kê
  Form --> UI : 11. Hiển thị lỗi tại màn hình
  UI --> Actor : 12. Yêu cầu kiểm tra lại thông tin
end
deactivate Controller
deactivate Form
deactivate UI
@enduml
