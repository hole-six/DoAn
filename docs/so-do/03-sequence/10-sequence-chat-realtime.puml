@startuml
skinparam shadowing false
title Sequence - Chat realtime Socket.IO

actor "Người gửi" as Sender
actor "Người nhận" as Receiver
boundary "Chat UI" as UI
control "ChatController" as Controller
control "Socket.IO" as Socket
entity "CuộcTròChuyện" as Conversation
entity "TinNhắn" as Message
database "MongoDB" as DB

Sender -> UI : Nhập tin nhắn
UI -> Controller : POST /api/tinnhan
Controller -> Conversation : kiểm tra/tạo cuộc trò chuyện
Conversation -> DB : findOrCreate
Controller -> Message : lưu tin nhắn
Message -> DB : insert
Controller -> Socket : emit message:new
Socket -> Receiver : realtime event
Controller --> UI : tin nhắn đã lưu
UI --> Sender : cập nhật hội thoại
@enduml

