@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam titleFontSize 18
skinparam shadowing false
skinparam linetype ortho
skinparam sequenceMessageAlign center
skinparam sequence {
  ArrowColor #222222
  LifeLineBorderColor #666666
  LifeLineBackgroundColor #F7F7F7
  ParticipantBorderColor #222222
  ParticipantBackgroundColor White
  ActorBorderColor #222222
  ActorBackgroundColor White
  BoxBorderColor #888888
  GroupBorderColor #222222
  GroupHeaderFontColor #222222
}
title Sơ đồ Quản lý danh mục kỹ năng

actor "Actor: Quản trị viên" as Actor
boundary "UI: quan-tri-ky-nang" as UI
boundary "UI: form-ky-nang" as Form
control "Controller: DanhMucKyNangController" as Controller
entity "Entity: DanhMucKyNang" as MainEntity

Actor -> UI : 1. Mở trang danh mục kỹ năng
activate UI
UI -> Form : 2. Hiển thị form-ky-nang
activate Form
Actor -> Form : 3. Thêm, sửa hoặc xóa kỹ năng
Form -> Controller : 4. GET/POST/PATCH/DELETE /danhmuckynang
activate Controller
Controller -> Controller : 5. Kiểm tra zod tenKyNang, loaiKyNang

alt Dữ liệu hợp lệ
  Controller -> MainEntity : 6. Tạo, cập nhật hoặc xóa kỹ năng (CRUD thuần)
  activate MainEntity
  MainEntity --> Controller : 7. return dữ liệu đã xử lý
  deactivate MainEntity
  Controller --> Form : 8. Trả danh mục kỹ năng mới
  Form --> UI : 9. Cập nhật giao diện
  UI --> Actor : 10. Hiển thị kết quả thành công
else Dữ liệu không hợp lệ
  Controller --> Form : 8. Thông báo dữ liệu kỹ năng không hợp lệ
  Form --> UI : 9. Hiển thị lỗi tại màn hình
  UI --> Actor : 10. Yêu cầu kiểm tra lại thông tin
end
deactivate Controller
deactivate Form
deactivate UI
@enduml
