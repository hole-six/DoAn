@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam titleFontSize 18
skinparam shadowing false
skinparam linetype ortho
skinparam sequenceMessageAlign center
skinparam sequence {
  ArrowColor #222222
  LifeLineBorderColor #666666
  LifeLineBackgroundColor #F7F7F7
  ParticipantBorderColor #222222
  ParticipantBackgroundColor White
  ActorBorderColor #222222
  ActorBackgroundColor White
  BoxBorderColor #888888
  GroupBorderColor #222222
  GroupHeaderFontColor #222222
}
title Sơ đồ Xem tin tuyển dụng

actor "Actor: Khách vãng lai / Ứng viên" as Actor
boundary "UI: chi-tiet-viec-lam" as UI
boundary "UI: khung-thao-tac-viec-lam" as Form
control "Controller: TinTuyenDungController" as Controller
entity "Entity: TinTuyenDung" as MainEntity
entity "Entity: NhaTuyenDung" as NhaTuyenDung
entity "Entity: TinTuyenDungKyNang" as TinTuyenDungKyNang
entity "Entity: DanhMucKyNang" as DanhMucKyNang

Actor -> UI : 1. Mở một tin tuyển dụng
activate UI
UI -> Form : 2. Hiển thị khung-thao-tac-viec-lam
activate Form
Actor -> Form : 3. Xem mô tả, yêu cầu và quyền lợi
Form -> Controller : 4. GET /tintuyendung/:ma (public)
activate Controller
Controller -> MainEntity : 5. Tìm tin tuyển dụng theo mã
activate MainEntity
MainEntity --> Controller : 6. return tin (hoặc rỗng)
deactivate MainEntity

alt Tin tồn tại
  Controller -> NhaTuyenDung : 7. Gắn thông tin nhà tuyển dụng cho tin
  Controller -> TinTuyenDungKyNang : 8. Lấy liên kết kỹ năng của tin
  TinTuyenDungKyNang -> DanhMucKyNang : 9. Lấy tên và loại kỹ năng
  Controller --> Form : 10. Trả chi tiết tin kèm công ty và kỹ năng
  Form --> UI : 11. Cập nhật giao diện
  UI --> Actor : 12. Hiển thị chi tiết tin tuyển dụng
else Không tìm thấy (404)
  Controller --> Form : 10. Trả lỗi 404 Không tìm thấy tin tuyển dụng
  Form --> UI : 11. Hiển thị thông báo không tìm thấy tin
  UI --> Actor : 12. Báo tin không tồn tại
end
deactivate Controller
deactivate Form
deactivate UI
@enduml
