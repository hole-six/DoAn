@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam titleFontSize 18
skinparam shadowing false
skinparam linetype ortho
skinparam sequenceMessageAlign center
skinparam ParticipantPadding 24
skinparam BoxPadding 8
skinparam sequence {
  ArrowColor #222222
  LifeLineBorderColor #666666
  LifeLineBackgroundColor #F7F7F7
  ParticipantBorderColor #222222
  ParticipantBackgroundColor White
  ActorBorderColor #222222
  ActorBackgroundColor White
  BoxBorderColor #888888
}
title sd Đăng ký tài khoản

actor "Actor: Khách vãng lai" as Actor
boundary "UI: dang-ky" as UI
boundary "UI: form-dang-ky" as Form
control "Controller: XacThucController" as Controller
entity "Entity: TaiKhoan" as MainEntity
entity "Entity: UngVien" as E1
entity "Entity: NhaTuyenDung" as E2
entity "Entity: ThongBao" as E3

Actor -> UI : 1. Truy cập trang đăng ký
activate UI
UI -> Form : 2. Hiển thị form-dang-ky
activate Form
Actor -> Form : 3. Nhập thông tin đăng ký và chọn vai trò
Form -> Controller : 4. dangKy(request)
activate Controller
Controller -> MainEntity : 5. Kiểm tra email, mật khẩu và vai trò
activate MainEntity
MainEntity --> Controller : 6. return kết quả kiểm tra
deactivate MainEntity

alt [Dữ liệu hợp lệ]
  Controller -> MainEntity : 7. Tạo tài khoản mới
  activate MainEntity
  MainEntity --> Controller : 8. return dữ liệu đã cập nhật
  deactivate MainEntity
  Controller -> E1 : 9. Tạo hồ sơ ứng viên hoặc hồ sơ công ty
  Controller -> E2 : 10. Gửi thông báo duyệt công ty nếu là nhà tuyển dụng
  Controller --> Form : 11. Thông báo đăng ký thành công
  Form --> UI : 12. Cập nhật giao diện
  UI --> Actor : 13. Hiển thị kết quả thành công
else [Dữ liệu không hợp lệ]
  Controller --> Form : 11. Thông báo dữ liệu không hợp lệ
  Form --> UI : 12. Hiển thị lỗi tại màn hình
  UI --> Actor : 13. Yêu cầu kiểm tra lại thông tin
end
deactivate Controller
deactivate Form
deactivate UI
@enduml
