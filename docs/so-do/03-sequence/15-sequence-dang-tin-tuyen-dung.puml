@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam titleFontSize 18
skinparam shadowing false
skinparam linetype ortho
skinparam sequenceMessageAlign center
skinparam sequence {
  ArrowColor #222222
  LifeLineBorderColor #666666
  LifeLineBackgroundColor #F7F7F7
  ParticipantBorderColor #222222
  ParticipantBackgroundColor White
  ActorBorderColor #222222
  ActorBackgroundColor White
  BoxBorderColor #888888
  GroupBorderColor #222222
  GroupHeaderFontColor #222222
}
title Sơ đồ Đăng tin tuyển dụng

actor "Actor: Nhà tuyển dụng" as Actor
boundary "UI: quan-ly-tin" as UI
boundary "UI: form-dang-tin" as Form
control "Controller: TinTuyenDungController" as Controller
entity "Entity: NhaTuyenDung" as NhaTuyenDung
entity "Entity: TinTuyenDung" as MainEntity
entity "Entity: TinTuyenDungKyNang" as TinTuyenDungKyNang
entity "Entity: DanhMucKyNang" as DanhMucKyNang
entity "Entity: ThongBao" as ThongBao

Actor -> UI : 1. Nhấn Đăng tin tuyển dụng
activate UI
UI -> Form : 2. Hiển thị form-dang-tin
activate Form
Form -> DanhMucKyNang : 3. Tải danh mục kỹ năng để chọn
Actor -> Form : 4. Nhập tiêu đề, mô tả, kỹ năng, lương và hạn nộp
Form -> Controller : 5. POST /tintuyendung taoMoi(request)
activate Controller
Controller -> NhaTuyenDung : 6. Lấy công ty theo người dùng, kiểm tra trạng thái duyệt
activate NhaTuyenDung
NhaTuyenDung --> Controller : 7. return công ty và trangThaiDuyet
deactivate NhaTuyenDung

alt Công ty đã duyệt và dữ liệu hợp lệ
  Controller -> MainEntity : 8. Tạo tin tuyển dụng trạng thái cho_duyet
  activate MainEntity
  MainEntity --> Controller : 9. return tin đã tạo
  deactivate MainEntity
  Controller -> TinTuyenDungKyNang : 10. createMany kỹ năng bắt buộc/trọng số (liên kết DanhMucKyNang)
  Controller -> ThongBao : 11. Gửi thông báo cho admin duyệt tin
  Controller --> Form : 12. Thông báo tin đã gửi duyệt
  Form --> UI : 13. Cập nhật giao diện
  UI --> Actor : 14. Hiển thị kết quả thành công
else Công ty chưa duyệt hoặc dữ liệu không hợp lệ
  Controller --> Form : 8. Thông báo công ty chưa được duyệt hoặc dữ liệu lỗi
  Form --> UI : 9. Hiển thị lỗi tại màn hình
  UI --> Actor : 10. Yêu cầu kiểm tra lại thông tin
end
deactivate Controller
deactivate Form
deactivate UI
@enduml
