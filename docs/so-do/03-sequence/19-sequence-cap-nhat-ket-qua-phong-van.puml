@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam titleFontSize 18
skinparam shadowing false
skinparam linetype ortho
skinparam sequenceMessageAlign center
skinparam ParticipantPadding 24
skinparam BoxPadding 8
skinparam sequence {
  ArrowColor #222222
  LifeLineBorderColor #666666
  LifeLineBackgroundColor #F7F7F7
  ParticipantBorderColor #222222
  ParticipantBackgroundColor White
  ActorBorderColor #222222
  ActorBackgroundColor White
  BoxBorderColor #888888
}
title sd Cập nhật kết quả phỏng vấn

actor "Actor: Nhà tuyển dụng" as Actor
boundary "UI: lich-phong-van-ntd" as UI
boundary "UI: form-ket-qua-phong-van" as Form
control "Controller: LichPhongVanController" as Controller
entity "Entity: LichPhongVan" as MainEntity
entity "Entity: HoSoUngTuyen" as E1
entity "Entity: ThongBao" as E2

Actor -> UI : 1. Mở lịch phỏng vấn cần cập nhật
activate UI
UI -> Form : 2. Hiển thị form-ket-qua-phong-van
activate Form
Actor -> Form : 3. Nhập kết quả đạt hoặc không đạt
Form -> Controller : 4. capNhatKetQuaPhongVan(request)
activate Controller
Controller -> MainEntity : 5. Kiểm tra lịch thuộc công ty và đã đến bước đánh giá
activate MainEntity
MainEntity --> Controller : 6. return kết quả kiểm tra
deactivate MainEntity

alt [Dữ liệu hợp lệ]
  Controller -> MainEntity : 7. Cập nhật kết quả phỏng vấn
  activate MainEntity
  MainEntity --> Controller : 8. return dữ liệu đã cập nhật
  deactivate MainEntity
  Controller -> E1 : 9. Cập nhật trạng thái hồ sơ và báo ứng viên
  Controller --> Form : 10. Thông báo cập nhật kết quả thành công
  Form --> UI : 11. Cập nhật giao diện
  UI --> Actor : 12. Hiển thị kết quả thành công
else [Dữ liệu không hợp lệ]
  Controller --> Form : 10. Thông báo lịch chưa thể cập nhật kết quả
  Form --> UI : 11. Hiển thị lỗi tại màn hình
  UI --> Actor : 12. Yêu cầu kiểm tra lại thông tin
end
deactivate Controller
deactivate Form
deactivate UI
@enduml
