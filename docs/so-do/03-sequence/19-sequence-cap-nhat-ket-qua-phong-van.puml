@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam titleFontSize 18
skinparam shadowing false
skinparam linetype ortho
skinparam sequenceMessageAlign center
skinparam sequence {
  ArrowColor #222222
  LifeLineBorderColor #666666
  LifeLineBackgroundColor #F7F7F7
  ParticipantBorderColor #222222
  ParticipantBackgroundColor White
  ActorBorderColor #222222
  ActorBackgroundColor White
  BoxBorderColor #888888
  GroupBorderColor #222222
  GroupHeaderFontColor #222222
}
title Sơ đồ Cập nhật kết quả phỏng vấn

actor "Actor: Nhà tuyển dụng" as Actor
boundary "UI: lich-phong-van-ntd" as UI
boundary "UI: form-ket-qua-phong-van" as Form
control "Controller: LichPhongVanController" as Controller
entity "Entity: LichPhongVan" as LichPhongVan
entity "Entity: HoSoUngTuyen" as HoSoUngTuyen
entity "Entity: LichSuHoSoUngTuyen" as LichSuHoSoUngTuyen
entity "Entity: DanhGiaPhongVan" as DanhGiaPhongVan
entity "Entity: NhaTuyenDung" as NhaTuyenDung
entity "Entity: TinTuyenDung" as TinTuyenDung
entity "Entity: ThongBao" as ThongBao

Actor -> UI : 1. Mở lịch phỏng vấn nhà tuyển dụng
activate UI
UI -> Form : 2. Chọn lịch cần cập nhật kết quả
activate Form
Actor -> Form : 3. Chọn kết quả đạt hoặc không đạt và ghi chú
Form -> Controller : 4. POST /lichphongvan/:ma/hoan-thanh
activate Controller
Controller -> LichPhongVan : 5. Lấy lịch phỏng vấn
LichPhongVan --> Controller : 6. Trả lịch
Controller -> HoSoUngTuyen : 7. Lấy hồ sơ ứng tuyển của lịch
HoSoUngTuyen --> Controller : 8. Trả hồ sơ
Controller -> NhaTuyenDung : 9. Kiểm tra quyền công ty
Controller -> TinTuyenDung : 10. Kiểm tra tin thuộc công ty

alt Hợp lệ
  Controller -> LichPhongVan : 11. Cập nhật trạng thái hoan_thanh và kết quả
  LichPhongVan --> Controller : 12. Trả lịch đã cập nhật
  Controller -> HoSoUngTuyen : 13. Cập nhật trạng thái dat hoặc khong_dat
  HoSoUngTuyen --> Controller : 14. Trả hồ sơ đã cập nhật
  Controller -> LichSuHoSoUngTuyen : 15. Ghi lịch sử kết quả hồ sơ
  Controller -> DanhGiaPhongVan : 16. Lưu điểm, nhận xét và kết quả đề xuất nếu có
  Controller -> ThongBao : 17. Báo kết quả phỏng vấn cho ứng viên
  Controller --> Form : 18. Trả kết quả cập nhật
  Form --> UI : 19. Cập nhật danh sách lịch
  UI --> Actor : 20. Hiển thị cập nhật thành công
else Không hợp lệ
  Controller --> Form : 16. Trả lỗi quyền, trạng thái hoặc kết quả
  Form --> UI : 17. Hiển thị lỗi
  UI --> Actor : 18. Yêu cầu kiểm tra lại
end

deactivate Controller
deactivate Form
deactivate UI
@enduml
