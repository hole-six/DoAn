@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam titleFontSize 18
skinparam shadowing false
skinparam linetype ortho
skinparam sequenceMessageAlign center
skinparam ParticipantPadding 24
skinparam BoxPadding 8
skinparam sequence {
  ArrowColor #222222
  LifeLineBorderColor #666666
  LifeLineBackgroundColor #F7F7F7
  ParticipantBorderColor #222222
  ParticipantBackgroundColor White
  ActorBorderColor #222222
  ActorBackgroundColor White
  BoxBorderColor #888888
}
title sd Quản lý hồ sơ ứng viên

actor "Actor: Nhà tuyển dụng" as Actor
boundary "UI: pipeline-ung-vien" as UI
boundary "UI: drawer-ho-so-ung-vien" as Form
control "Controller: HoSoUngTuyenController" as Controller
entity "Entity: HoSoUngTuyen" as MainEntity
entity "Entity: UngVien" as E1
entity "Entity: TinTuyenDung" as E2
entity "Entity: ThongBao" as E3

Actor -> UI : 1. Mở pipeline ứng viên
activate UI
UI -> Form : 2. Hiển thị drawer-ho-so-ung-vien
activate Form
Actor -> Form : 3. Xem hồ sơ, chuyển trạng thái, từ chối hoặc chọn phỏng vấn
Form -> Controller : 4. capNhatTrangThaiHoSo(request)
activate Controller
Controller -> MainEntity : 5. Kiểm tra hồ sơ thuộc tin của công ty
activate MainEntity
MainEntity --> Controller : 6. return kết quả kiểm tra
deactivate MainEntity

alt [Dữ liệu hợp lệ]
  Controller -> MainEntity : 7. Cập nhật trạng thái hồ sơ ứng tuyển
  activate MainEntity
  MainEntity --> Controller : 8. return dữ liệu đã cập nhật
  deactivate MainEntity
  Controller -> E1 : 9. Gửi thông báo cho ứng viên
  Controller --> Form : 10. Hiển thị pipeline đã cập nhật
  Form --> UI : 11. Cập nhật giao diện
  UI --> Actor : 12. Hiển thị kết quả thành công
else [Dữ liệu không hợp lệ]
  Controller --> Form : 10. Thông báo thao tác không hợp lệ
  Form --> UI : 11. Hiển thị lỗi tại màn hình
  UI --> Actor : 12. Yêu cầu kiểm tra lại thông tin
end
deactivate Controller
deactivate Form
deactivate UI
@enduml
