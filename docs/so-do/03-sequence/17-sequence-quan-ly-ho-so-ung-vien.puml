@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam titleFontSize 18
skinparam shadowing false
skinparam linetype ortho
skinparam sequenceMessageAlign center
skinparam sequence {
  ArrowColor #222222
  LifeLineBorderColor #666666
  LifeLineBackgroundColor #F7F7F7
  ParticipantBorderColor #222222
  ParticipantBackgroundColor White
  ActorBorderColor #222222
  ActorBackgroundColor White
  BoxBorderColor #888888
  GroupBorderColor #222222
  GroupHeaderFontColor #222222
}
title Sơ đồ Quản lý hồ sơ ứng viên

actor "Actor: Nhà tuyển dụng" as Actor
boundary "UI: pipeline-ung-vien" as UI
boundary "UI: drawer-ho-so-ung-vien" as Form
control "Controller: HoSoUngTuyenController" as Controller
entity "Entity: HoSoUngTuyen" as HoSoUngTuyen
entity "Entity: UngVien" as UngVien
entity "Entity: TinTuyenDung" as TinTuyenDung
entity "Entity: HoSoNangLuc" as HoSoNangLuc
entity "Entity: LichSuHoSoUngTuyen" as LichSuHoSoUngTuyen
entity "Entity: ThongBao" as ThongBao

Actor -> UI : 1. Mở pipeline ứng viên
activate UI
UI -> Controller : 2. GET /hosoungtuyen
activate Controller
Controller -> HoSoUngTuyen : 3. Lấy hồ sơ thuộc tin của công ty
HoSoUngTuyen --> Controller : 4. Trả danh sách hồ sơ
Controller -> UngVien : 5. Populate thông tin ứng viên
Controller -> TinTuyenDung : 6. Populate tin tuyển dụng
Controller -> HoSoNangLuc : 7. Populate hồ sơ năng lực / CV
Controller --> UI : 8. Trả dữ liệu pipeline
deactivate Controller
UI -> Form : 9. Mở khung chi tiết ứng viên

alt Đánh dấu đã xem
  Actor -> Form : 10. Chọn xem hồ sơ
  Form -> Controller : 11. POST /hosoungtuyen/:ma/xem
  activate Controller
  Controller -> HoSoUngTuyen : 12. Cập nhật trạng thái da_nop -> da_xem
  Controller -> LichSuHoSoUngTuyen : 13. Ghi lịch sử trạng thái hồ sơ
  Controller -> ThongBao : 14. Báo ứng viên hồ sơ đã được xem
  Controller --> Form : 15. Trả hồ sơ đã cập nhật
  deactivate Controller
else Đánh giá hồ sơ (xét duyệt / từ chối)
  Actor -> Form : 10. Đưa vào xét duyệt hoặc từ chối sàng lọc
  Form -> Controller : 11. POST /hosoungtuyen/:ma/danh-gia
  activate Controller
  Controller -> HoSoUngTuyen : 12. Cập nhật trạng thái dang_xet_duyet / tu_choi
  Controller -> LichSuHoSoUngTuyen : 13. Ghi lịch sử trạng thái hồ sơ
  Controller -> ThongBao : 14. Báo ứng viên kết quả sàng lọc
  Controller --> Form : 15. Trả hồ sơ đã cập nhật
  deactivate Controller
else Mời phỏng vấn
  Actor -> Form : 10. Chọn lên lịch phỏng vấn
  Form -> Controller : 11. POST /hosoungtuyen/:ma/moi-phong-van
  activate Controller
  Controller -> HoSoUngTuyen : 12. Cập nhật trạng thái moi_phong_van
  Controller -> LichSuHoSoUngTuyen : 13. Ghi lịch sử "moi_phong_van"
  Controller -> ThongBao : 14. Báo ứng viên lời mời phỏng vấn
  Controller --> Form : 15. Trả kết quả mời phỏng vấn
  deactivate Controller
end

Form --> UI : 16. Tải lại pipeline
UI --> Actor : 17. Hiển thị kết quả thao tác
deactivate Form
deactivate UI
@enduml
