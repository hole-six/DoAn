@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam titleFontSize 18
skinparam shadowing false
skinparam linetype ortho
skinparam sequenceMessageAlign center
skinparam sequence {
  ArrowColor #222222
  LifeLineBorderColor #666666
  LifeLineBackgroundColor #F7F7F7
  ParticipantBorderColor #222222
  ParticipantBackgroundColor White
  ActorBorderColor #222222
  ActorBackgroundColor White
  BoxBorderColor #888888
  GroupBorderColor #222222
  GroupHeaderFontColor #222222
}
title Sơ đồ Quản lý hồ sơ ứng viên

actor "Actor: Nhà tuyển dụng" as Actor
boundary "UI: pipeline-ung-vien" as UI
boundary "UI: drawer-ho-so-ung-vien" as Form
control "Controller: HoSoUngTuyenController" as Controller
entity "Entity: HoSoUngTuyen" as HoSoUngTuyen
entity "Entity: UngVien" as UngVien
entity "Entity: TinTuyenDung" as TinTuyenDung
entity "Entity: NhaTuyenDung" as NhaTuyenDung
entity "Entity: LichPhongVan" as LichPhongVan
entity "Entity: LichSuHoSoUngTuyen" as LichSuHoSoUngTuyen
entity "Entity: ThongBao" as ThongBao

Actor -> UI : 1. Mở pipeline ứng viên
activate UI
UI -> Form : 2. Hiển thị hồ sơ ứng tuyển
activate Form
Form -> Controller : 3. GET /hosoungtuyen
activate Controller
Controller -> HoSoUngTuyen : 4. Lấy hồ sơ thuộc tin của công ty
HoSoUngTuyen --> Controller : 5. Trả danh sách hồ sơ
Controller -> UngVien : 6. Populate thông tin ứng viên
Controller -> TinTuyenDung : 7. Populate tin tuyển dụng
Controller --> Form : 8. Trả dữ liệu pipeline
deactivate Controller

alt Đánh dấu đã xem hoặc đánh giá
  Actor -> Form : 9. Chọn xem, đưa vào xét duyệt hoặc từ chối
  Form -> Controller : 10. POST /hosoungtuyen/:ma/xem hoặc /:ma/danh-gia
  activate Controller
  Controller -> HoSoUngTuyen : 11. Kiểm tra hồ sơ thuộc công ty
  Controller -> NhaTuyenDung : 12. Kiểm tra nhà tuyển dụng hiện tại
  Controller -> HoSoUngTuyen : 13. Cập nhật trạng thái nghiệp vụ
  Controller -> LichSuHoSoUngTuyen : 14. Ghi lịch sử trạng thái hồ sơ
  Controller -> ThongBao : 15. Báo ứng viên khi cần
  Controller --> Form : 16. Trả hồ sơ đã cập nhật
else Mời phỏng vấn
  Actor -> Form : 9. Chọn lên lịch phỏng vấn
  Form -> Controller : 10. POST /hosoungtuyen/:ma/moi-phong-van
  activate Controller
  Controller -> HoSoUngTuyen : 11. Kiểm tra hồ sơ thuộc công ty
  Controller -> LichPhongVan : 12. Tạo lịch phỏng vấn
  Controller -> LichSuHoSoUngTuyen : 13. Ghi lịch sử trạng thái "moi_phong_van"
  Controller -> ThongBao : 14. Báo ứng viên
  Controller --> Form : 15. Trả lịch mới
end

Form --> UI : 17. Cập nhật pipeline
UI --> Actor : 18. Hiển thị kết quả thao tác
deactivate Controller
deactivate Form
deactivate UI
@enduml
