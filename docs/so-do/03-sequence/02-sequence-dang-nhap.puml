@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam titleFontSize 18
skinparam shadowing false
skinparam linetype ortho
skinparam sequenceMessageAlign center
skinparam ParticipantPadding 24
skinparam BoxPadding 8
skinparam sequence {
  ArrowColor #222222
  LifeLineBorderColor #666666
  LifeLineBackgroundColor #F7F7F7
  ParticipantBorderColor #222222
  ParticipantBackgroundColor White
  ActorBorderColor #222222
  ActorBackgroundColor White
  BoxBorderColor #888888
}
title sd Đăng nhập

actor "Actor: Khách vãng lai" as Actor
boundary "UI: dang-nhap" as UI
boundary "UI: form-dang-nhap" as Form
control "Controller: XacThucController" as Controller
entity "Entity: TaiKhoan" as MainEntity
entity "Entity: PhienDangNhap" as E1

Actor -> UI : 1. Truy cập trang đăng nhập
activate UI
UI -> Form : 2. Hiển thị form-dang-nhap
activate Form
Actor -> Form : 3. Nhập email, mật khẩu hoặc chọn Google
Form -> Controller : 4. dangNhap(request)
activate Controller
Controller -> MainEntity : 5. Kiểm tra thông tin xác thực
activate MainEntity
MainEntity --> Controller : 6. return kết quả kiểm tra
deactivate MainEntity

alt [Dữ liệu hợp lệ]
  Controller -> MainEntity : 7. Tạo phiên đăng nhập và token
  activate MainEntity
  MainEntity --> Controller : 8. return dữ liệu đã cập nhật
  deactivate MainEntity
  Controller -> E1 : 9. Xác định vai trò để chuyển đúng dashboard
  Controller --> Form : 10. Đăng nhập thành công
  Form --> UI : 11. Cập nhật giao diện
  UI --> Actor : 12. Hiển thị kết quả thành công
else [Dữ liệu không hợp lệ]
  Controller --> Form : 10. Thông báo sai email hoặc mật khẩu
  Form --> UI : 11. Hiển thị lỗi tại màn hình
  UI --> Actor : 12. Yêu cầu kiểm tra lại thông tin
end
deactivate Controller
deactivate Form
deactivate UI
@enduml
