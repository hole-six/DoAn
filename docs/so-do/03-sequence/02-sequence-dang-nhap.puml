@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam titleFontSize 18
skinparam shadowing false
skinparam linetype ortho
skinparam sequenceMessageAlign center
skinparam sequence {
  ArrowColor #222222
  LifeLineBorderColor #666666
  LifeLineBackgroundColor #F7F7F7
  ParticipantBorderColor #222222
  ParticipantBackgroundColor White
  ActorBorderColor #222222
  ActorBackgroundColor White
  BoxBorderColor #888888
  GroupBorderColor #222222
  GroupHeaderFontColor #222222
}
title Sơ đồ Đăng nhập

actor "Actor: Khách vãng lai" as Actor
boundary "UI: dang-nhap" as UI
boundary "UI: form-dang-nhap" as Form
control "Controller: XacThucController" as Controller
entity "Entity: NguoiDung" as NguoiDung
entity "Entity: UngVien" as UngVien

Actor -> UI : 1. Mở trang đăng nhập
activate UI
UI -> Form : 2. Hiển thị form email/mật khẩu và Google
activate Form

alt Đăng nhập email/mật khẩu
  Actor -> Form : 3. Nhập email và mật khẩu
  Form -> Controller : 4. POST /xacthuc/dang-nhap
  activate Controller
  Controller -> NguoiDung : 5. Tìm email, kiểm tra trạng thái và mật khẩu
  activate NguoiDung
  NguoiDung --> Controller : 6. Trả NguoiDung hợp lệ
  deactivate NguoiDung
else Đăng nhập Google
  Actor -> Form : 3. Chọn Google
  Form -> Controller : 4. POST /xacthuc/dang-nhap-google
  activate Controller
  Controller -> NguoiDung : 5. Tạo hoặc lấy NguoiDung theo email Google
  activate NguoiDung
  NguoiDung --> Controller : 6. Trả NguoiDung hợp lệ
  deactivate NguoiDung
  opt Vai trò ứng viên
    Controller -> UngVien : 7. Đảm bảo hồ sơ ứng viên tồn tại
    UngVien --> Controller : 8. Trả hồ sơ ứng viên
  end
end

alt Hợp lệ
  Controller --> Form : 9. Trả accessToken, refreshToken, NguoiDung
  Form --> UI : 10. Lưu phiên đăng nhập ở trình duyệt
  UI --> Actor : 11. Điều hướng theo vai trò
else Không hợp lệ
  Controller --> Form : 9. Trả lỗi xác thực hoặc tài khoản bị khóa
  Form --> UI : 10. Hiển thị thông báo lỗi
  UI --> Actor : 11. Yêu cầu kiểm tra lại thông tin
end

deactivate Controller
deactivate Form
deactivate UI
@enduml
