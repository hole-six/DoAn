@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam titleFontSize 18
skinparam shadowing false
skinparam linetype ortho
skinparam sequenceMessageAlign center
skinparam sequence {
  ArrowColor #222222
  LifeLineBorderColor #666666
  LifeLineBackgroundColor #F7F7F7
  ParticipantBorderColor #222222
  ParticipantBackgroundColor White
  ActorBorderColor #222222
  ActorBackgroundColor White
  BoxBorderColor #888888
  GroupBorderColor #222222
  GroupHeaderFontColor #222222
}
title Sơ đồ Duyệt tin tuyển dụng

actor "Actor: Quản trị viên" as Actor
boundary "UI: quan-tri-tin-tuyen-dung" as UI
boundary "UI: form-duyet-tin" as Form
control "Controller: TinTuyenDungController" as Controller
entity "Entity: TinTuyenDung" as MainEntity
entity "Entity: TinTuyenDungKyNang" as TinTuyenDungKyNang
entity "Entity: NhaTuyenDung" as E1
entity "Entity: ThongBao" as E2

Actor -> UI : 1. Mở danh sách tin chờ duyệt
activate UI
UI -> Form : 2. Hiển thị form-duyet-tin
activate Form
Actor -> Form : 3. Xem nội dung và chọn duyệt hoặc từ chối
Form -> Controller : 4. POST /tintuyendung/:ma/duyet | /tu-choi
activate Controller
Controller -> MainEntity : 5. Kiểm tra tin và công ty liên quan
activate MainEntity
MainEntity --> Controller : 6. return kết quả kiểm tra
deactivate MainEntity

alt Dữ liệu hợp lệ
  Controller -> MainEntity : 7. Cập nhật trạng thái tin (dang_mo hoặc tu_choi)
  activate MainEntity
  MainEntity --> Controller : 8. return dữ liệu đã cập nhật
  deactivate MainEntity
  Controller -> E2 : 9. Tạo ThôngBáo kết quả duyệt tin cho nhà tuyển dụng
  Controller --> Form : 10. Thông báo xử lý tin thành công
  Form --> UI : 11. Cập nhật giao diện
  UI --> Actor : 12. Hiển thị kết quả thành công
else Dữ liệu không hợp lệ
  Controller --> Form : 10. Thông báo tin không hợp lệ
  Form --> UI : 11. Hiển thị lỗi tại màn hình
  UI --> Actor : 12. Yêu cầu kiểm tra lại thông tin
end
Controller -> TinTuyenDungKyNang : Đọc kèm kỹ năng của tin khi xem/duyệt (include)
Controller -> E1 : Đọc công ty liên quan để lấy người nhận thông báo
@enduml
