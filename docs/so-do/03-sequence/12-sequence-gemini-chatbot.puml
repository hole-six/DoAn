@startuml
skinparam shadowing false
title Sequence - Gemini chatbot và fallback database

actor "Người dùng" as User
boundary "AI Widget" as UI
control "AiController" as Controller
control "AiService" as Service
entity "TinTuyểnDụng" as Job
control "Gemini API" as Gemini
database "MongoDB" as DB

User -> UI : Nhập câu hỏi
UI -> UI : chặn gửi trùng nếu đang chờ
UI -> Controller : POST /api/ai/chatbot
Controller -> Service : chatbot(cauHoi)
Service -> Job : tìm job phù hợp database
Job -> DB : find active jobs
DB --> Job : jobs
Job --> Service : jobs
Service -> Gemini : generateContent(prompt)
alt Gemini trả lời
  Gemini --> Service : JSON/câu trả lời
  Service --> Controller : traLoi + goiY + nguon gemini
else Gemini lỗi/rate limit
  Service -> Service : fallback từ dữ liệu jobs
  Service --> Controller : traLoi + goiY + nguon database_fallback
end
Controller --> UI : duLieu
UI --> User : hiển thị trả lời
@enduml

