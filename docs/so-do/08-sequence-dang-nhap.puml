@startuml
skinparam shadowing false
title Sequence Diagram - Dang nhap JWT/Google

actor User
participant "DangNhapPage" as LoginPage
participant "XacthucController" as AuthController
participant "XacthucService" as AuthService
participant "NguoiDungModel" as UserModel
database "MongoDB" as DB

User -> LoginPage : nhap email/mat khau hoac Google credential
LoginPage -> AuthController : POST /api/xacthuc/dang-nhap
AuthController -> AuthService : xac thuc thong tin
AuthService -> UserModel : tim nguoi dung
UserModel -> DB : query by email
DB --> UserModel : user
UserModel --> AuthService : user + mat khau hash
alt thong tin hop le
  AuthService -> AuthService : tao accessToken + refreshToken
  AuthService --> AuthController : phien dang nhap
  AuthController --> LoginPage : token + nguoiDung
  LoginPage -> LoginPage : luu localStorage
  LoginPage --> User : dieu huong dashboard theo vai tro
else thong tin khong hop le
  AuthController --> LoginPage : loi 401/400
  LoginPage --> User : hien thi loi dang nhap
end
@enduml

