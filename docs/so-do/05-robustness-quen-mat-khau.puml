@startuml
left to right direction
skinparam shadowing false
title Robustness Diagram - Quen mat khau

actor "User" as User
boundary "ForgotPasswordPage" as ForgotPage
boundary "ResetPasswordPage" as ResetPage
control "XacthucController" as AuthController
control "XacthucService" as AuthService
entity "NguoiDungModel" as UserModel
control "EmailService" as EmailService
database "MongoDB" as DB

User --> ForgotPage : nhap email
ForgotPage --> AuthController : POST /quen-mat-khau
AuthController --> AuthService : yeu cau reset
AuthService --> UserModel : tim user theo email
UserModel --> DB : truy van nguoi dung
AuthService --> UserModel : luu resetTokenHash + expires
AuthService --> EmailService : gui link reset
EmailService --> User : email reset

User --> ResetPage : click link reset
ResetPage --> AuthController : GET/POST token
AuthController --> AuthService : xac minh token/cap nhat mat khau
AuthService --> UserModel : cap nhat mat khau, xoa token
UserModel --> DB : luu thay doi
ResetPage --> User : thong bao thanh cong
@enduml

