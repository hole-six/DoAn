@startuml
skinparam shadowing false
title Activity Diagram - Lich phong van va cap nhat ket qua

start
:Nha tuyen dung xem ho so ung vien;
if (Ho so du dieu kien phong van?) then (Co)
  :Chon "Moi phong van";
  :Nhap thoi gian, hinh thuc, dia chi/link hop;
  if (Thong tin lich hop le?) then (Co)
    :POST /api/hosoungtuyen/:id/moi-phong-van;
    :Tao lich phong van;
    :Cap nhat trang thai ho so moi_phong_van;
    :Gui thong bao cho ung vien;
    :Ung vien xem lich phong van;
    if (Ung vien dong y lich?) then (Co)
      :POST /api/lichphongvan/:id/xac-nhan;
      :Cap nhat trang thai da_xac_nhan;
    else (Khong)
      :Ung vien gui yeu cau doi lich;
      :Cap nhat trang thai yeu_cau_doi_lich;
      :Thong bao nha tuyen dung xu ly lai;
    endif

    :Den buoi phong van;
    :Nha tuyen dung mo form cap nhat ket qua;
    if (Ket qua dat?) then (Dat)
      :Cap nhat lich hoan_thanh;
      :Cap nhat ho so trang thai dat;
      :Thong bao ung vien dat phong van;
      stop
    else (Khong dat)
      :Cap nhat lich hoan_thanh;
      :Cap nhat ho so trang thai tu_choi/khong_dat;
      :Thong bao ung vien khong dat;
      stop
    endif
  else (Khong)
    :Hien thi loi du lieu lich;
    stop
  endif
else (Khong)
  :Tiep tuc sang loc ho so;
  stop
endif
@enduml

