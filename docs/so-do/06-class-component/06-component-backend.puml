@startuml
skinparam shadowing false
title Component Diagram - Backend API EffortIT

package "Node.js Express Backend" {
  component "Auth API" as Auth
  component "Recruitment API" as Recruitment
  component "Employer/Admin API" as Admin
  component "CV/Profile API" as CV
  component "Chat API" as Chat
  component "Notification API" as Notification
  component "AI API" as AI
  component "Upload Static Files" as Upload
}

database "MongoDB" as DB
cloud "Gemini API" as Gemini
cloud "SMTP Gmail" as SMTP
node "Socket.IO Server" as Socket

Auth --> DB
Recruitment --> DB
Admin --> DB
CV --> DB
Chat --> DB
Notification --> DB
AI --> DB
Upload --> DB
AI --> Gemini
Notification --> SMTP
Chat --> Socket
Notification --> Socket
@enduml

