@startuml
skinparam shadowing false
title Class Diagram - Chat và thông báo

class "TinNhắnController" as ChatController {
  +lấyCuộcTròChuyện()
  +gửiTinNhắn()
  +đánhDấuĐãĐọc()
}

class "TinNhắnService" as ChatService {
  +lấyHoặcTạoCuộcTròChuyện()
  +lưuTinNhắn()
  +phátRealtime()
}

class "ThôngBáoService" as NotifyService {
  +tạoThôngBáo()
  +đánhDấuĐãĐọc()
  +gửiRealtime()
}

class "CuộcTròChuyện" as Conversation
class "TinNhắn" as Message
class "ThôngBáo" as Notification
class "SocketServer" as Socket

ChatController --> ChatService
ChatService --> Conversation
ChatService --> Message
ChatService --> Socket
NotifyService --> Notification
NotifyService --> Socket
Conversation "1" o-- "*" Message
@enduml

