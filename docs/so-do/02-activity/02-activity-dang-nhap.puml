@startuml
scale 0.82
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam shadowing false
skinparam linetype ortho
skinparam nodesep 18
skinparam ranksep 18
skinparam Padding 2
skinparam activity {
  BackgroundColor White
  BorderColor #222222
  DiamondBackgroundColor White
  DiamondBorderColor #222222
  BarColor #111111
}
start
:Khách vãng lai mở trang đăng nhập;
if (Chọn phương thức?) then (Email/mật khẩu)
  fork
    :Nhập email;
  fork again
    :Nhập mật khẩu;
  end fork
  if (Muốn thoát?) then (Có)
    :Quay lại trang chủ;
  else (Không)
    :Nhấn nút "Đăng nhập";
    :Tìm NgườiDùng theo email;
    if (Tài khoản tồn tại và hoạt động?) then (Đúng)
      :Kiểm tra mật khẩu;
      if (Mật khẩu đúng?) then (Đúng)
        :Xác thực email/mật khẩu thành công;
      else (Sai)
        :Hiển thị sai email hoặc mật khẩu;
      endif
    else (Sai)
      :Hiển thị tài khoản không tồn tại hoặc bị khóa;
    endif
  endif
else (Google)
  :Nhấn nút đăng nhập Google;
  :Chọn tài khoản Google;
  :Xác thực thông tin đăng nhập Google;
  if (Thông tin Google hợp lệ?) then (Đúng)
    :Tìm NgườiDùng theo email Google;
    if (Chưa có tài khoản?) then (Có)
      :Tạo NgườiDùng vai trò ứng viên;
      :Tạo hồ sơ ỨngViên nếu cần;
    else (Không)
      :Dùng NgườiDùng hiện có;
    endif
    if (Tài khoản đang hoạt động?) then (Đúng)
      :Xác thực Google thành công;
    else (Sai)
      :Hiển thị tài khoản không hoạt động;
    endif
  else (Sai)
    :Hiển thị đăng nhập Google thất bại;
  endif
endif
if (Đăng nhập thành công?) then (Có)
  :Tạo mã truy cập và mã làm mới phiên;
  :Lưu phiên đăng nhập ở trình duyệt;
  :Xác định vai trò người dùng;
  if (Vai trò?) then (Ứng viên)
    :Đi tới bảng điều khiển ứng viên;
  elseif (Nhà tuyển dụng?) then (Nhà tuyển dụng)
    :Đi tới bảng điều khiển nhà tuyển dụng;
  else (Quản trị viên)
    :Đi tới bảng điều khiển quản trị;
  endif
else (Không)
endif
stop
@enduml
