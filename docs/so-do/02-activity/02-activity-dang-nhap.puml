@startuml
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam linetype ortho
skinparam activity {
  BackgroundColor White
  BorderColor #222222
  DiamondBackgroundColor White
  DiamondBorderColor #222222
  BarColor #111111
}
start
:Khách vãng lai mở trang đăng nhập;
if (Chọn phương thức?) then (Email/mật khẩu)
  fork
    :Nhập email;
  fork again
    :Nhập mật khẩu;
  end fork
  if (Muốn thoát?) then (Có)
    :Nhấn quay lại trang chủ;
    :Kết thúc nhánh;
  else (Không)
    :Nhấn nút "Đăng nhập";
  endif
  :Hệ thống tìm NguoiDung theo email;
  if (Tài khoản tồn tại và hoạt động?) then (Đúng)
    :Kiểm tra mật khẩu;
    if (Mật khẩu đúng?) then (Đúng)
      :Tạo accessToken và refreshToken;
    else (Sai)
      :Hiển thị sai email hoặc mật khẩu;
      :Kết thúc nhánh;
    endif
  else (Sai)
    :Hiển thị tài khoản không tồn tại hoặc bị khóa;
    :Kết thúc nhánh;
  endif
else (Google)
  :Nhấn nút đăng nhập Google;
  :Chọn tài khoản Google;
  :Hệ thống xác thực Google credential;
  if (Google credential hợp lệ?) then (Đúng)
    :Tìm NguoiDung theo email Google;
    if (Chưa có tài khoản?) then (Có)
      :Tạo NguoiDung vai trò ung_vien trạng thái hoạt động;
      :Tạo hoặc đảm bảo hồ sơ UngVien;
    else (Không)
      :Dùng NguoiDung hiện có;
    endif
    if (Tài khoản đang hoạt động?) then (Đúng)
      :Tạo accessToken và refreshToken;
    else (Sai)
      :Hiển thị tài khoản không ở trạng thái hoạt động;
      :Kết thúc nhánh;
    endif
  else (Sai)
    :Hiển thị đăng nhập Google thất bại;
    :Kết thúc nhánh;
  endif
endif
:Lưu phiên đăng nhập ở trình duyệt;
:Hệ thống tự nhận vai trò từ NguoiDung;
if (Vai trò?) then (Ứng viên)
  :Điều hướng tới dashboard ứng viên;
elseif (Vai trò nhà tuyển dụng?) then (Nhà tuyển dụng)
  :Điều hướng tới dashboard nhà tuyển dụng;
else (Quản trị viên)
  :Điều hướng tới dashboard quản trị;
endif
stop
@enduml
