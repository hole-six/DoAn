@startuml
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam linetype ortho
skinparam activity {
  BackgroundColor White
  BorderColor #222222
  DiamondBackgroundColor White
  DiamondBorderColor #222222
  BarColor #111111
}
start
:Ứng viên đăng nhập;
:Mở trang hồ sơ ứng tuyển hoặc chi tiết công ty;
:Hệ thống tải ỨngViên và HồSơỨngTuyển liên quan;
if (Ứng viên đủ điều kiện đánh giá?) then (Đã được mời phỏng vấn)
  :Nhấn nút "Đánh giá công ty";
  :Hệ thống tải NhàTuyểnDụng từ HồSơỨngTuyển;
  if (Đã từng đánh giá hồ sơ này?) then (Có)
    :Hiển thị thông báo đã đánh giá công ty;
  else (Chưa)
    fork
      :Chọn số sao từ 1 đến 5;
    fork again
      :Nhập nội dung đánh giá;
    fork again
      :Chọn ẩn danh nếu muốn;
    end fork
    if (Muốn thoát?) then (Có)
      :Nhấn nút "Đóng";
    else (Không)
      :Nhấn nút "Gửi đánh giá";
      :Hệ thống kiểm tra điểm và nội dung;
      if (Dữ liệu hợp lệ?) then (Đúng)
        :Tạo ĐánhGiáCôngTy trạng thái chưa duyệt;
        :Hiển thị thông báo gửi đánh giá thành công;
      else (Sai)
        :Hiển thị thông báo lỗi;
      endif
    endif
  endif
else (Chưa đủ điều kiện)
  :Hiển thị yêu cầu phải được mời phỏng vấn trước khi đánh giá;
endif
stop
@enduml
