@startuml
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam linetype ortho
skinparam activity {
  BackgroundColor White
  BorderColor #222222
  DiamondBackgroundColor White
  DiamondBorderColor #222222
  BarColor #111111
}
start
:Nhà tuyển dụng đăng nhập;
:Mở trang lịch phỏng vấn nhà tuyển dụng;
:Hệ thống tải LịchPhỏngVấn và HồSơỨngTuyển liên quan;
:Chọn lịch cần cập nhật kết quả;
if (Lịch thuộc công ty?) then (Đúng)
  if (Trạng thái có thể cập nhật kết quả?) then (Có)
    if (Chọn kết quả?) then (Đạt)
      :Nhấn nút "Đạt";
      :Nhập ghi chú kết quả nếu có;
      :Nhấn nút "Cập nhật";
      :Hệ thống cập nhật LịchPhỏngVấn thành hoàn thành, kết quả đạt;
      :Hệ thống cập nhật HồSơỨngTuyển thành đạt;
      :Gửi ThôngBáo kết quả phỏng vấn cho ứng viên;
      :Hiển thị cập nhật thành công;
    else (Không đạt)
      :Nhấn nút "Không đạt";
      :Nhập ghi chú kết quả nếu có;
      :Nhấn nút "Cập nhật";
      :Hệ thống cập nhật LịchPhỏngVấn thành hoàn thành, kết quả không đạt;
      :Hệ thống cập nhật HồSơỨngTuyển thành từ chối;
      :Gửi ThôngBáo kết quả phỏng vấn cho ứng viên;
      :Hiển thị cập nhật thành công;
    endif
  else (Không)
    :Hiển thị thông báo lịch chưa thể cập nhật kết quả;
  endif
else (Sai)
  :Hiển thị thông báo không có quyền cập nhật lịch;
endif
:Lưu DanhGiaPhongVan nếu có điểm/nhận xét và ghi LichSuHoSoUngTuyen;
stop
@enduml
