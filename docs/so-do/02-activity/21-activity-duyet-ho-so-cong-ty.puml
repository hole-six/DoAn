@startuml
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam linetype ortho
skinparam activity {
  BackgroundColor White
  BorderColor #222222
  DiamondBackgroundColor White
  DiamondBorderColor #222222
  BarColor #111111
}
start
:Quản trị viên đăng nhập;
:Mở trang quản lý công ty;
:Hệ thống tải danh sách NhàTuyểnDụng;
if (Tải dữ liệu thành công?) then (Đúng)
  :Hiển thị công ty, ngành, trạng thái và ngày tạo;
  fork
    :Nhập từ khóa tìm theo tên công ty;
  fork again
    :Lọc theo trạng thái duyệt;
  end fork
  :Hệ thống lọc động danh sách phía client;
  :Chọn một hồ sơ công ty;
  if (Chọn thao tác?) then (Duyệt)
    :Nhấn nút "Duyệt" hoặc "Duyệt lại";
    :Xác nhận duyệt công ty;
    :Hệ thống cập nhật trạng thái duyệt của NhàTuyểnDụng thành đã duyệt;
    :Gửi ThôngBáo kết quả duyệt cho nhà tuyển dụng;
    :Tải lại danh sách công ty;
  elseif (Chọn từ chối?) then (Từ chối)
    :Nhấn nút "Từ chối";
    :Xác nhận từ chối công ty;
    :Hệ thống cập nhật trạng thái duyệt của NhàTuyểnDụng thành từ chối;
    :Gửi ThôngBáo kết quả từ chối cho nhà tuyển dụng;
    :Tải lại danh sách công ty;
  else (Xóa)
    :Nhấn nút "Xóa";
    :Xác nhận xóa hồ sơ công ty;
    :Hệ thống xóa NhàTuyểnDụng nếu được phép;
    :Tải lại danh sách công ty;
  endif
else (Sai)
  :Hiển thị thông báo không tải được dữ liệu công ty;
endif
stop
@enduml
