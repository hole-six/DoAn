@startuml
skinparam shadowing false
title Activity - Quản lý CV và hồ sơ năng lực

start
:Ứng viên mở trang hồ sơ/CV;
:Xem danh sách hồ sơ năng lực;
if (Tạo CV trong hệ thống?) then (Có)
  :Nhập thông tin cá nhân, kỹ năng, kinh nghiệm, dự án;
  :Lưu HoSoNangLuc;
else (Không)
  :Chọn upload CV PDF;
  :Kiểm tra định dạng và dung lượng;
  if (File hợp lệ?) then (Có)
    :Lưu file CV;
    :Gemini/OCR trích xuất nội dung nếu có cấu hình;
  else (Không)
    :Thông báo file không hợp lệ;
  endif
endif
:Đánh dấu CV chính hoặc công khai;
:Cập nhật hồ sơ ứng viên;
stop
@enduml

