@startuml
skinparam shadowing false
title Activity - Quản trị viên duyệt công ty

start
:Quản trị viên mở danh sách công ty chờ duyệt;
:Chọn một hồ sơ công ty;
:Xem thông tin người phụ trách và hồ sơ công ty;
if (Thông tin đạt yêu cầu?) then (Có)
  :Cập nhật trạng thái công ty "đã duyệt";
  :Tạo thông báo cho nhà tuyển dụng;
  :Cho phép đăng tin tuyển dụng;
else (Không)
  :Nhập lý do từ chối;
  :Cập nhật trạng thái "từ chối";
  :Tạo thông báo yêu cầu bổ sung;
endif
stop
@enduml

