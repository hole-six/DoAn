@startuml
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam linetype ortho
skinparam activity {
  BackgroundColor White
  BorderColor #222222
  DiamondBackgroundColor White
  DiamondBorderColor #222222
  BarColor #111111
}
start
:Người dùng mở danh sách hoặc chi tiết việc làm;
:Chọn một TinTuyenDung;
if (Thao tác ở trang chi tiết?) then (Có)
  if (Đã đăng nhập ứng viên?) then (Có)
    :Nhấn nút "Lưu" hoặc "Đã lưu";
    :Hệ thống gọi ViecLamDaLuu theo NguoiDung và TinTuyenDung;
  else (Không)
    :Điều hướng tới trang đăng nhập với thông báo cần tài khoản ứng viên;
    :Kết thúc nhánh;
  endif
else (Trang danh sách việc làm)
  if (Đã đăng nhập ứng viên?) then (Có)
    :Nhấn icon lưu;
    :Hệ thống gọi ViecLamDaLuu theo NguoiDung và TinTuyenDung;
  else (Không)
    :Nhấn icon lưu;
    :Lưu tạm mã TinTuyenDung vào localStorage;
    :Cập nhật trạng thái nút lưu trên trình duyệt;
    :Kết thúc nhánh;
  endif
endif
if (TinTuyenDung tồn tại?) then (Có)
  if (Đã lưu?) then (Có)
    :Xóa ViecLamDaLuu;
    :Cập nhật trạng thái nút thành chưa lưu;
    :Hiển thị thông báo đã bỏ lưu;
  else (Chưa)
    :Tạo ViecLamDaLuu;
    :Cập nhật trạng thái nút thành đã lưu;
    :Hiển thị thông báo đã lưu việc làm;
  endif
  :Kết thúc nhánh;
else (Không)
  :Hiển thị thông báo tin không tồn tại;
  stop
endif
@enduml
