@startuml
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam linetype ortho
skinparam activity {
  BackgroundColor White
  BorderColor #222222
  DiamondBackgroundColor White
  DiamondBorderColor #222222
  BarColor #111111
}
start
:Người dùng mở danh sách hoặc chi tiết việc làm;
:Chọn một TinTuyểnDụng;
if (Thao tác ở trang chi tiết?) then (Có)
  if (Đã đăng nhập ứng viên?) then (Có)
    :Nhấn nút "Lưu" hoặc "Đã lưu";
    :Hệ thống gọi ViệcLàmĐãLưu theo NgườiDùng và TinTuyểnDụng;
    if (TinTuyểnDụng tồn tại?) then (Có)
      if (Đã lưu?) then (Có)
        :Xóa ViệcLàmĐãLưu;
        :Cập nhật nút thành chưa lưu;
        :Hiển thị thông báo đã bỏ lưu;
      else (Chưa)
        :Tạo ViệcLàmĐãLưu;
        :Cập nhật nút thành đã lưu;
        :Hiển thị thông báo đã lưu việc làm;
      endif
    else (Không)
      :Hiển thị thông báo tin không tồn tại;
    endif
  else (Không)
    :Điều hướng tới trang đăng nhập với thông báo cần tài khoản ứng viên;
  endif
else (Trang danh sách việc làm)
  if (Đã đăng nhập ứng viên?) then (Có)
    :Nhấn biểu tượng lưu;
    :Hệ thống gọi ViệcLàmĐãLưu theo NgườiDùng và TinTuyểnDụng;
    if (TinTuyểnDụng tồn tại?) then (Có)
      if (Đã lưu?) then (Có)
        :Xóa ViệcLàmĐãLưu;
        :Cập nhật nút thành chưa lưu;
      else (Chưa)
        :Tạo ViệcLàmĐãLưu;
        :Cập nhật nút thành đã lưu;
      endif
    else (Không)
      :Hiển thị thông báo tin không tồn tại;
    endif
  else (Không)
    :Nhấn biểu tượng lưu;
    :Lưu tạm mã TinTuyểnDụng vào bộ nhớ trình duyệt;
    :Cập nhật trạng thái nút lưu trên trình duyệt;
  endif
endif
stop
@enduml
