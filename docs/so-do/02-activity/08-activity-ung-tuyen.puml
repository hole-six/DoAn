@startuml
skinparam shadowing false
title Activity - Ứng tuyển việc làm

start
:Ứng viên mở chi tiết việc làm;
if (Đã đăng nhập ứng viên?) then (Có)
  :Bấm ứng tuyển;
  :Chọn hồ sơ năng lực hoặc upload CV mới;
  if (Hồ sơ hợp lệ?) then (Có)
    :Gửi POST /api/hosoungtuyen;
    :Backend kiểm tra đã ứng tuyển chưa;
    if (Chưa ứng tuyển?) then (Có)
      :Tạo HoSoUngTuyen trạng thái mới;
      :Ghi lịch sử trạng thái;
      :Tạo thông báo cho nhà tuyển dụng;
      :Thông báo ứng tuyển thành công;
    else (Không)
      :Thông báo đã ứng tuyển trước đó;
    endif
  else (Không)
    :Yêu cầu chọn hoặc tạo CV;
  endif
else (Không)
  :Điều hướng đến đăng nhập;
endif
stop
@enduml

