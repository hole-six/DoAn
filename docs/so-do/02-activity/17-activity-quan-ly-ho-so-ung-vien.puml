@startuml
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam linetype ortho
skinparam activity {
  BackgroundColor White
  BorderColor #222222
  DiamondBackgroundColor White
  DiamondBorderColor #222222
  BarColor #111111
}
start
:Nhà tuyển dụng đăng nhập;
:Mở trang luồng xử lý ứng viên;
fork
  :Hệ thống tải HồSơỨngTuyển của công ty;
fork again
  :Hệ thống tải TinTuyểnDụng;
fork again
  :Hệ thống tải ỨngViên và HồSơNăngLực liên quan;
fork again
  :Hệ thống tải LịchPhỏngVấn nếu có;
end fork
if (Có quyền xem hồ sơ?) then (Có)
  :Hiển thị danh sách hồ sơ ứng tuyển;
  :Chọn một HồSơỨngTuyển;
  :Mở khung chi tiết ứng viên;
  fork
    :Xem tổng quan hồ sơ ứng tuyển;
  fork again
    :Xem CV tạo trên hệ thống hoặc CV PDF đã nộp;
  fork again
    :Xem lịch sử trạng thái;
  end fork
  if (Chọn hành động?) then (Đánh dấu đã xem)
    :Gọi HoSoUngTuyen/xem;
    :Cập nhật trạng thái từ đã nộp sang đã xem;
    :Gửi ThôngBáo hồ sơ đã được xem cho ứng viên;
  elseif (Chuyển xét duyệt?) then (Xét duyệt)
    :Gọi chức năng đánh giá hồ sơ ứng tuyển với trạng thái đang xét duyệt;
    :Ghi lịch sử hồ sơ ứng tuyển;
  elseif (Từ chối sàng lọc?) then (Từ chối)
    :Nhập lý do từ chối sàng lọc;
    :Gọi chức năng đánh giá hồ sơ ứng tuyển với trạng thái từ chối;
    :Gửi ThôngBáo kết quả cho ứng viên;
  elseif (Mời phỏng vấn?) then (Mời phỏng vấn)
    :Mở form mời phỏng vấn;
  elseif (Cập nhật kết quả phỏng vấn?) then (Đạt/Không đạt)
    :Gọi LichPhongVan/hoan-thanh để cập nhật kết quả;
  else (Nhắn tin)
    :Mở cuộc trò chuyện với ứng viên nếu trạng thái cho phép;
  endif
  :Tải lại dữ liệu luồng xử lý ứng viên;
else (Không)
  :Hiển thị thông báo không có quyền xem hồ sơ;
endif
:Mỗi lần đổi trạng thái đều ghi LichSuHoSoUngTuyen;
stop
@enduml
