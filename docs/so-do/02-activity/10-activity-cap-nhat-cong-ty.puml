@startuml
skinparam shadowing false
title Activity - Nhà tuyển dụng cập nhật hồ sơ công ty

start
:Nhà tuyển dụng mở trang thông tin công ty;
:Nhập logo, website, ngành, quy mô, địa chỉ, mô tả;
if (Dữ liệu hợp lệ?) then (Có)
  :Gửi PATCH /api/nhatuyendung/{id};
  :Cập nhật thông tin công ty;
  if (Công ty từng bị từ chối?) then (Có)
    :Đưa trạng thái về chờ duyệt;
    :Tạo thông báo cho quản trị viên;
  endif
  :Hiển thị lưu thành công;
else (Không)
  :Hiển thị lỗi nhập liệu;
endif
stop
@enduml

