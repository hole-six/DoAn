@startuml
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam linetype ortho
skinparam activity {
  BackgroundColor White
  BorderColor #222222
  DiamondBackgroundColor White
  DiamondBorderColor #222222
  BarColor #111111
}
start
:Ứng viên đăng nhập;
:Mở trang hồ sơ năng lực;
:Hệ thống tải ỨngViên và danh sách HồSơNăngLực;
if (Đã có hồ sơ?) then (Có)
  :Hiển thị danh sách CV và CV chính;
else (Không)
  :Hiển thị trạng thái chưa có hồ sơ;
endif
if (Chọn thao tác?) then (Tạo mới)
  :Nhấn nút "Tạo CV";
  fork
    :Nhập tiêu đề CV;
  fork again
    :Nhập thông tin cá nhân hiển thị;
  fork again
    :Nhập học vấn, kinh nghiệm, chứng chỉ;
  fork again
    :Nhập kỹ năng mềm và kỹ năng lập trình;
  fork again
    :Nhập dự án và liên kết portfolio;
  fork again
    :Tải ảnh đại diện hoặc file CV nếu có;
  end fork
  if (Đặt làm CV chính?) then (Có)
    :Đánh dấu HồSơNăngLực là CV chính;
  else (Không)
    :Giữ trạng thái CV phụ;
  endif
  :Nhấn nút "Lưu";
  :Hệ thống kiểm tra dữ liệu hồ sơ;
  if (Hợp lệ?) then (Đúng)
    :Tạo HồSơNăngLực;
    :Hiển thị thông báo lưu thành công;
  else (Sai)
    :Hiển thị thông báo lỗi;
  endif
elseif (Chọn chỉnh sửa?) then (Chỉnh sửa)
  :Chọn một HồSơNăngLực;
  fork
    :Cập nhật tiêu đề và thông tin cá nhân;
  fork again
    :Cập nhật học vấn, kinh nghiệm, chứng chỉ;
  fork again
    :Cập nhật kỹ năng, dự án và liên kết;
  end fork
  :Nhấn nút "Lưu";
  :Hệ thống kiểm tra dữ liệu hồ sơ;
  if (Hợp lệ?) then (Đúng)
    :Cập nhật HồSơNăngLực;
    :Hiển thị thông báo lưu thành công;
  else (Sai)
    :Hiển thị thông báo lỗi;
  endif
else (Xóa)
  :Chọn HồSơNăngLực cần xóa;
  if (Xác nhận xóa?) then (Có)
    :Hệ thống xóa HồSơNăngLực;
    :Hiển thị thông báo thành công;
  else (Không)
    :Đóng hộp xác nhận;
  endif
endif
:Nếu hồ sơ/CV có kỹ năng ứng viên thì đồng bộ UngVienKyNang;
stop
@enduml
