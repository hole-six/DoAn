@startuml
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam linetype ortho
skinparam activity {
  BackgroundColor White
  BorderColor #222222
  DiamondBackgroundColor White
  DiamondBorderColor #222222
  BarColor #111111
}
start
:Quản trị viên đăng nhập;
:Mở trang duyệt tin tuyển dụng;
:Hệ thống tải TinTuyểnDụng và NhàTuyểnDụng liên quan;
if (Tải dữ liệu thành công?) then (Đúng)
  :Hiển thị danh sách tin, công ty, trạng thái và hạn nộp;
  if (Chọn thao tác?) then (Xem chi tiết)
    :Mở ngăn chi tiết TinTuyểnDụng;
    :Xem tiêu đề, mô tả, yêu cầu, quyền lợi, kỹ năng và công ty đăng;
    if (Tin đang chờ duyệt?) then (Có)
      if (Quyết định?) then (Duyệt)
        :Nhấn nút "Duyệt";
        :Xác nhận duyệt tin;
        :Hệ thống cập nhật TinTuyểnDụng thành đang mở và ngày đăng hiện tại;
        :Gửi ThôngBáo kết quả duyệt tin cho nhà tuyển dụng;
      else (Từ chối)
        :Nhấn nút "Từ chối";
        :Xác nhận từ chối tin;
        :Hệ thống cập nhật TinTuyểnDụng thành từ chối;
        :Gửi ThôngBáo kết quả từ chối cho nhà tuyển dụng;
      endif
    else (Không)
      :Chỉ xem chi tiết hoặc đóng ngăn chi tiết;
    endif
  elseif (Chọn xóa tin?) then (Xóa tin)
    :Nhấn nút "Xóa";
    :Xác nhận xóa tin tuyển dụng;
    :Hệ thống xóa TinTuyểnDụng nếu được phép;
  else (Gửi gợi ý việc làm)
    :Nhấn nút "Gửi gợi ý việc làm";
    :Hệ thống xem trước danh sách ứng viên có CV chính phù hợp;
    :Xác nhận gửi email hàng loạt;
    :Hệ thống gửi email gợi ý việc làm cho ứng viên phù hợp;
  endif
  :Tải lại danh sách tin tuyển dụng;
else (Sai)
  :Hiển thị thông báo không tải được dữ liệu;
endif
stop
@enduml
