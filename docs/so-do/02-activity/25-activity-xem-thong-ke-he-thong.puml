@startuml
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam linetype ortho
skinparam activity {
  BackgroundColor White
  BorderColor #222222
  DiamondBackgroundColor White
  DiamondBorderColor #222222
  BarColor #111111
}
start
:Quản trị viên đăng nhập;
:Mở bảng điều khiển quản trị;
if (Phiên đăng nhập hợp lệ và vai trò quản trị viên?) then (Đúng)
  fork
    :Hệ thống tải NgườiDùng;
  fork again
    :Hệ thống tải NhàTuyểnDụng;
  fork again
    :Hệ thống tải TinTuyểnDụng;
  fork again
    :Hệ thống tải HồSơỨngTuyển;
  fork again
    :Hệ thống tải CảnhBáoQuảnTrị;
  end fork
  if (Tải dữ liệu thành công?) then (Đúng)
    :Tổng hợp tổng người dùng và tài khoản hoạt động;
    :Tổng hợp việc làm đang mở và tin chờ duyệt;
    :Tổng hợp công ty chờ duyệt;
    :Tổng hợp hồ sơ ứng tuyển mới trong 24 giờ;
    :Hiển thị cảnh báo vận hành từ CảnhBáoQuảnTrị;
    :Hiển thị danh sách tin tuyển dụng chờ duyệt;
    if (Quản trị viên chọn thao tác nhanh?) then (Người dùng)
      :Điều hướng tới trang quản lý người dùng;
    elseif (Chọn công ty?) then (Công ty)
      :Điều hướng tới trang quản lý công ty;
    elseif (Chọn tin tuyển dụng?) then (Tin tuyển dụng)
      :Điều hướng tới trang duyệt tin tuyển dụng;
    else (Cài đặt)
      :Điều hướng tới trang cài đặt quản trị;
    endif
  else (Sai)
    :Hiển thị thông báo không tải được dữ liệu bảng điều khiển;
    :Cho phép nhấn tải lại;
  endif
else (Sai)
  :Điều hướng tới trang đăng nhập hoặc báo không có quyền;
endif
:Thống kê đọc HoSoUngTuyen, LichSuHoSoUngTuyen, TinTuyenDungKyNang và DanhGiaPhongVan khi cần;
stop
@enduml
