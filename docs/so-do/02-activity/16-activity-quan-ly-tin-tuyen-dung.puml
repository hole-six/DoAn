@startuml
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam linetype ortho
skinparam activity {
  BackgroundColor White
  BorderColor #222222
  DiamondBackgroundColor White
  DiamondBorderColor #222222
  BarColor #111111
}
start
:Nhà tuyển dụng đăng nhập;
:Mở trang quản lý tin tuyển dụng;
fork
  :Hệ thống tải NhàTuyểnDụng của tài khoản;
fork again
  :Hệ thống tải danh sách TinTuyểnDụng;
fork again
  :Hệ thống tải DanhMụcKỹNăng;
end fork
if (Có quyền quản lý tin?) then (Có)
  :Hiển thị danh sách tin của công ty;
  if (Chọn thao tác?) then (Sửa tin)
    :Chọn TinTuyểnDụng cần sửa;
    :Mở form sửa tin;
    fork
      :Cập nhật tiêu đề, mô tả, yêu cầu;
    fork again
      :Cập nhật lương, hạn nộp, địa điểm;
    fork again
      :Cập nhật kỹ năng;
    end fork
    :Nhấn nút "Lưu";
    :Hệ thống cập nhật TinTuyểnDụng;
    :Hiển thị thông báo lưu thành công;
  elseif (Chọn tạm đóng hoặc mở lại?) then (Tạm đóng hoặc mở lại)
    :Chọn trạng thái mới;
    :Hệ thống cập nhật trạng thái TinTuyểnDụng;
    :Hiển thị thông báo thành công;
  elseif (Chọn xóa tin?) then (Xóa tin)
    :Nhấn biểu tượng "Xóa";
    if (Xác nhận xóa?) then (Có)
      :Hệ thống xóa TinTuyểnDụng;
      :Hiển thị thông báo đã xóa;
    else (Không)
      :Đóng hộp xác nhận;
    endif
  else (Xem ứng viên)
    :Điều hướng tới luồng xử lý ứng viên theo tin;
  endif
else (Không)
  :Hiển thị thông báo công ty chưa được duyệt hoặc không có quyền;
endif
:Khi sửa kỹ năng thì đồng bộ TinTuyenDungKyNang;
stop
@enduml
