@startuml
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam linetype ortho
skinparam activity {
  BackgroundColor White
  BorderColor #222222
  DiamondBackgroundColor White
  DiamondBorderColor #222222
  BarColor #111111
}
start
:Nhà tuyển dụng đăng nhập;
:Mở trang quản lý tin tuyển dụng;
:Hệ thống kiểm tra hồ sơ NhaTuyenDung;
if (Công ty đã được duyệt?) then (Đúng)
  :Nhấn nút "Đăng tin";
  :Hệ thống tải DanhMucKyNang;
  fork
    :Nhập tiêu đề tin tuyển dụng;
  fork again
    :Nhập mô tả công việc;
  fork again
    :Nhập yêu cầu ứng viên;
  fork again
    :Nhập quyền lợi;
  fork again
    :Chọn cấp bậc, loại hình và địa điểm;
  fork again
    :Nhập lương, hạn nộp và số lượng;
  fork again
    :Chọn kỹ năng bắt buộc;
  fork again
    :Tải ảnh đại diện tin nếu có;
  end fork
  if (Muốn thoát?) then (Có)
    :Nhấn nút "Đóng";
    :Kết thúc nhánh;
  else (Không)
    :Nhấn nút "Lưu tin";
  endif
  :Hệ thống kiểm tra dữ liệu TinTuyenDung;
  if (Dữ liệu hợp lệ?) then (Đúng)
    :Tạo TinTuyenDung trạng thái cho_duyet;
    :Gửi ThongBao cho quản trị viên duyệt tin;
    :Hiển thị đăng tin thành công và chờ duyệt;
    :Kết thúc nhánh;
  else (Sai)
    :Hiển thị thông báo lỗi;
    :Kết thúc nhánh;
  endif
else (Sai)
  :Hiển thị yêu cầu cập nhật hoặc chờ duyệt hồ sơ công ty;
  stop
endif
@enduml
