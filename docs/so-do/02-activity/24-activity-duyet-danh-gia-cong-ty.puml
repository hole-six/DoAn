@startuml
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam linetype ortho
skinparam activity {
  BackgroundColor White
  BorderColor #222222
  DiamondBackgroundColor White
  DiamondBorderColor #222222
  BarColor #111111
}
start
:Quản trị viên đăng nhập;
:Mở trang duyệt đánh giá công ty;
:Hệ thống tải danh sách ĐánhGiáCôngTy;
if (Có đánh giá?) then (Có)
  :Chọn một đánh giá công ty;
  :Xem điểm sao, nội dung, ngày tạo và trạng thái duyệt;
  if (Quyết định xử lý?) then (Duyệt)
    :Nhấn nút "Duyệt";
    :Xác nhận duyệt đánh giá;
    :Hệ thống cập nhật ĐánhGiáCôngTy daDuyet = true;
    :Hiển thị đánh giá đã được duyệt;
  else (Xóa)
    :Nhấn nút "Xóa";
    if (Xác nhận thao tác?) then (Có)
      :Hệ thống xóa ĐánhGiáCôngTy;
      :Hiển thị thông báo đã xử lý đánh giá;
    else (Không)
      :Đóng hộp xác nhận;
    endif
  endif
else (Không)
  :Hiển thị trạng thái không có đánh giá;
endif
stop
@enduml
