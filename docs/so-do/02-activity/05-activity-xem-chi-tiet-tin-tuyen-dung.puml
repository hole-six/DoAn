@startuml
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam linetype ortho
skinparam activity {
  BackgroundColor White
  BorderColor #222222
  DiamondBackgroundColor White
  DiamondBorderColor #222222
  BarColor #111111
}
start
:Khách vãng lai hoặc ứng viên chọn một tin tuyển dụng;
:Hệ thống tải TinTuyenDung theo mã;
if (Tin tồn tại?) then (Có)
  fork
    :Tải NhaTuyenDung liên quan;
  fork again
    :Tải danh sách TinTuyenDung để gợi ý việc tương tự;
  end fork
  :Hiển thị mô tả, yêu cầu, quyền lợi, mức lương, địa điểm và kỹ năng của tin;
  if (Người dùng đăng nhập ứng viên?) then (Có)
    fork
      :Kiểm tra HoSoUngTuyen đã nộp;
    fork again
      :Kiểm tra ViecLamDaLuu;
    fork again
      :Tải HoSoNangLuc để ứng tuyển;
    end fork
    if (Chọn thao tác?) then (Ứng tuyển)
      :Mở form ứng tuyển;
      :Chọn CV có sẵn hoặc upload CV PDF mới;
      :Nhập thư xin việc nếu có;
    elseif (Chọn lưu việc?) then (Lưu việc)
      :Gọi chức năng lưu hoặc bỏ lưu việc làm;
    else (Xem công ty)
      :Mở trang chi tiết công ty;
    endif
  else (Không)
    if (Chọn ứng tuyển hoặc lưu việc?) then (Có)
      :Điều hướng tới trang đăng nhập;
    else (Không)
      :Tiếp tục xem thông tin tin tuyển dụng;
    endif
  endif
  :Kết thúc nhánh;
else (Không)
  :Hiển thị thông báo không tìm thấy tin tuyển dụng;
  stop
endif
@enduml
