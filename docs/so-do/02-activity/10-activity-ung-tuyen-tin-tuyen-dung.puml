@startuml
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam linetype ortho
skinparam activity {
  BackgroundColor White
  BorderColor #222222
  DiamondBackgroundColor White
  DiamondBorderColor #222222
  BarColor #111111
}
start
:Ứng viên đăng nhập vào hệ thống;
:Mở chi tiết TinTuyểnDụng;
:Hệ thống tải TinTuyểnDụng, NhàTuyểnDụng và trạng thái ứng tuyển;
if (Tin đang mở?) then (Đúng)
  if (Ứng viên đã có ỨngViên?) then (Có)
    :Nhấn nút "Ứng tuyển ngay";
    :Hệ thống tải HồSơNăngLực của ứng viên;
    if (Đã từng ứng tuyển tin này và chưa rút?) then (Có)
      :Hiển thị thông báo đã ứng tuyển tin này;
    else (Chưa)
      :Mở form ứng tuyển;
      fork
        :Chọn CV có sẵn nếu có;
      fork again
        :Upload CV PDF mới nếu muốn hoặc chưa có CV;
      fork again
        :Nhập thư xin việc nếu cần;
      end fork
      if (Muốn thoát?) then (Có)
        :Nhấn nút "Hủy" hoặc đóng form;
      else (Không)
        :Nhấn nút "Gửi ứng tuyển";
        if (Tải lên CV PDF mới?) then (Có)
          :Tải file qua chức năng tải hồ sơ năng lực;
          :Tạo HồSơNăngLực loại file tải lên;
        else (Không)
          :Dùng HồSơNăngLực đã chọn;
        endif
        :Hệ thống kiểm tra CV hợp lệ;
        if (Có HồSơNăngLực hợp lệ?) then (Có)
          :Tạo HồSơỨngTuyển trạng thái đã nộp;
          :Ghi LichSửHồSơỨngTuyển trạng thái da_nop;
          :Gửi ThôngBáo hồ sơ mới cho nhà tuyển dụng;
          :Hiển thị ứng tuyển thành công;
        else (Không)
          :Hiển thị lỗi cần chọn hoặc tải lên CV;
        endif
      endif
    endif
  else (Không)
    :Hiển thị lỗi cần hoàn thiện hồ sơ ứng viên;
    :Điều hướng tới trang hồ sơ ứng viên;
  endif
else (Sai)
  :Hiển thị lỗi tin đã đóng, hết hạn hoặc không khả dụng;
endif
stop
@enduml
