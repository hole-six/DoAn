@startuml
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam linetype ortho
skinparam activity {
  BackgroundColor White
  BorderColor #222222
  DiamondBackgroundColor White
  DiamondBorderColor #222222
  BarColor #111111
}
start
:Ứng viên đăng nhập vào hệ thống;
:Mở chi tiết TinTuyenDung;
:Hệ thống tải TinTuyenDung, NhaTuyenDung và trạng thái ứng tuyển;
if (Tin đang mở?) then (Đúng)
  if (Ứng viên đã có UngVien?) then (Có)
    :Nhấn nút "Ứng tuyển ngay";
    :Hệ thống tải HoSoNangLuc của ứng viên;
    if (Đã từng ứng tuyển tin này và chưa rút?) then (Có)
      :Hiển thị thông báo đã ứng tuyển tin này;
      :Kết thúc nhánh;
    else (Chưa)
      :Mở form ứng tuyển;
    endif
    fork
      :Chọn CV có sẵn nếu có;
    fork again
      :Upload CV PDF mới nếu muốn hoặc chưa có CV;
    fork again
      :Nhập thư xin việc nếu cần;
    end fork
    if (Muốn thoát?) then (Có)
      :Nhấn nút "Hủy" hoặc đóng form;
      :Kết thúc nhánh;
    else (Không)
      :Nhấn nút "Gửi ứng tuyển";
    endif
    if (Upload CV PDF mới?) then (Có)
      :Upload file qua HoSoNangLuc/upload-file;
      :Tạo HoSoNangLuc loại file_upload;
    else (Không)
      :Dùng HoSoNangLuc đã chọn;
    endif
    :Hệ thống kiểm tra CV hợp lệ;
    if (Có HoSoNangLuc hợp lệ?) then (Có)
      :Tạo HoSoUngTuyen trạng thái da_nop;
      :Ghi LichSuHoSoUngTuyen;
      :Gửi ThongBao hồ sơ mới cho nhà tuyển dụng;
      :Hiển thị ứng tuyển thành công;
      :Kết thúc nhánh;
    else (Không)
      :Hiển thị lỗi cần chọn hoặc upload CV;
      :Kết thúc nhánh;
    endif
  else (Không)
    :Hiển thị lỗi cần hoàn thiện hồ sơ ứng viên;
    :Điều hướng tới trang hồ sơ ứng viên;
    :Kết thúc nhánh;
  endif
else (Sai)
  :Hiển thị lỗi tin đã đóng, hết hạn hoặc không khả dụng;
  stop
endif
@enduml
