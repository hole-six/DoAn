@startuml
skinparam shadowing false
title Activity - Google Login

start
:Người dùng bấm đăng nhập Google;
:Frontend nhận Google credential;
:Gửi credential đến /api/xacthuc/dang-nhap-google;
if (GOOGLE_CLIENT_ID cấu hình đúng?) then (Có)
  :Backend xác minh credential với Google;
  if (Token hợp lệ?) then (Có)
    :Tìm hoặc tạo NgườiDùng theo email Google;
    :Gắn vai trò mặc định nếu tài khoản mới;
    :Tạo JWT;
    :Frontend lưu phiên và điều hướng;
  else (Không)
    :Trả lỗi token Google không hợp lệ;
  endif
else (Không)
  :Trả lỗi chưa cấu hình Google;
endif
stop
@enduml

