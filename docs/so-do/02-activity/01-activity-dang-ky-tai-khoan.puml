@startuml
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam linetype ortho
skinparam activity {
  BackgroundColor White
  BorderColor #222222
  DiamondBackgroundColor White
  DiamondBorderColor #222222
  BarColor #111111
}
start
:Khách vãng lai mở trang hệ thống;
:Nhấn nút "Đăng ký";
:Chọn vai trò đăng ký;
if (Vai trò?) then (Ứng viên)
  :Hệ thống hiển thị form ứng viên;
  fork
    :Nhập họ tên;
  fork again
    :Nhập email;
  fork again
    :Nhập số điện thoại;
  fork again
    :Nhập mật khẩu;
  fork again
    :Nhập xác nhận mật khẩu;
  end fork
else (Nhà tuyển dụng)
  :Hệ thống hiển thị form nhà tuyển dụng;
  fork
    :Nhập họ tên người phụ trách;
  fork again
    :Nhập email;
  fork again
    :Nhập số điện thoại;
  fork again
    :Nhập mật khẩu;
  fork again
    :Nhập tên công ty;
  end fork
  :Hệ thống nhắc sẽ hoàn thiện mã số thuế, website, địa chỉ, logo và mô tả sau đăng ký;
endif
if (Muốn thoát?) then (Có)
  :Quay lại trang chủ hoặc mở trang đăng nhập;
  :Kết thúc nhánh;
else (Không)
  :Nhấn nút "Đăng ký";
endif
:Hệ thống kiểm tra email, mật khẩu, xác nhận mật khẩu, vai trò và tên công ty nếu là nhà tuyển dụng;
if (Dữ liệu hợp lệ?) then (Đúng)
  :Tạo NguoiDung với trạng thái hoạt động;
  if (Đăng ký nhà tuyển dụng?) then (Có)
    :Tạo NhaTuyenDung tối thiểu với tên công ty và trạng thái chờ duyệt;
    :Gửi ThongBao cho quản trị viên về hồ sơ công ty chờ duyệt;
  else (Không)
    :Tạo hồ sơ UngVien mặc định;
  endif
  :Điều hướng sang trang đăng nhập;
  :Kết thúc nhánh;
else (Sai)
  :Hệ thống hiển thị thông báo lỗi;
  :Người dùng chỉnh lại thông tin;
  stop
endif
@enduml
