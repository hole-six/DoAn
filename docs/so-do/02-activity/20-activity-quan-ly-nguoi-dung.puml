@startuml
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam linetype ortho
skinparam activity {
  BackgroundColor White
  BorderColor #222222
  DiamondBackgroundColor White
  DiamondBorderColor #222222
  BarColor #111111
}
start
:Quản trị viên đăng nhập;
:Mở trang quản lý người dùng;
:Hệ thống tải danh sách NgườiDùng;
if (Tải dữ liệu thành công?) then (Đúng)
  :Hiển thị bảng người dùng;
  fork
    :Tìm theo họ tên hoặc email;
  fork again
    :Lọc theo vai trò;
  fork again
    :Lọc theo trạng thái tài khoản;
  end fork
  if (Chọn thao tác?) then (Thêm mới)
    :Nhấn nút "Thêm người dùng";
    fork
      :Nhập họ tên;
    fork again
      :Nhập email;
    fork again
      :Nhập mật khẩu;
    fork again
      :Nhập số điện thoại;
    fork again
      :Chọn vai trò;
    fork again
      :Chọn trạng thái;
    end fork
    :Nhấn nút "Lưu";
    :Hệ thống kiểm tra email trùng và dữ liệu bắt buộc;
    if (Dữ liệu hợp lệ?) then (Đúng)
      :Tạo NgườiDùng;
      :Hiển thị thông báo tạo thành công;
    else (Sai)
      :Hiển thị thông báo lỗi;
    endif
  elseif (Chọn chỉnh sửa?) then (Chỉnh sửa)
    :Chọn người dùng cần sửa;
    :Cập nhật họ tên, số điện thoại, vai trò, trạng thái hoặc mật khẩu;
    :Nhấn nút "Cập nhật";
    :Hệ thống kiểm tra dữ liệu và email trùng;
    if (Hợp lệ?) then (Đúng)
      :Cập nhật NgườiDùng;
      :Hiển thị thông báo cập nhật thành công;
    else (Sai)
      :Hiển thị thông báo lỗi;
    endif
  else (Xóa)
    :Chọn người dùng cần xóa;
    if (Là quản trị viên cuối cùng?) then (Có)
      :Hiển thị lỗi không thể xóa quản trị viên cuối cùng;
    else (Không)
      :Xác nhận xóa;
      :Hệ thống xóa NgườiDùng;
      :Hiển thị thông báo đã xóa;
    endif
  endif
else (Sai)
  :Hiển thị thông báo không tải được người dùng;
endif
stop
@enduml
