start
:Quản trị viên mở trang danh mục kỹ năng;
:Hệ thống tải danh sách kỹ năng;
fork
  :Tìm kiếm kỹ năng;
fork again
  :Lọc theo nhóm kỹ năng;
fork again
  :Lọc theo trạng thái;
end fork
if (Chọn thêm kỹ năng?) then (Có)
  :Nhập thông tin kỹ năng mới;
else (Khóa hoặc mở khóa)
  if (Chọn sửa kỹ năng?) then (Có)
    :Cập nhật tên, nhóm hoặc mô tả kỹ năng;
  else (Không)
    :Chọn trạng thái kỹ năng;
  endif
endif
:Hệ thống kiểm tra dữ liệu kỹ năng;
