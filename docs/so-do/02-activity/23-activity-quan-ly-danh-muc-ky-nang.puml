@startuml
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam linetype ortho
skinparam activity {
  BackgroundColor White
  BorderColor #222222
  DiamondBackgroundColor White
  DiamondBorderColor #222222
  BarColor #111111
}
start
:Quản trị viên đăng nhập;
:Mở trang quản lý kỹ năng;
:Hệ thống tải DanhMụcKỹNăng;
if (Tải dữ liệu thành công?) then (Đúng)
  :Hiển thị danh sách kỹ năng và loại kỹ năng;
  fork
    :Nhập từ khóa tìm theo tên kỹ năng;
  fork again
    :Lọc theo loại kỹ năng;
  end fork
  :Hệ thống lọc động danh sách phía client;
  if (Chọn thao tác?) then (Thêm hoặc sửa)
    :Mở form kỹ năng;
    fork
      :Nhập tên kỹ năng;
    fork again
      :Nhập loại kỹ năng;
    fork again
      :Nhập mô tả (tùy chọn);
    end fork
    :Nhấn nút "Lưu";
    :Hệ thống kiểm tra zod tên kỹ năng và loại kỹ năng;
    if (Dữ liệu hợp lệ?) then (Đúng)
      :Tạo hoặc cập nhật DanhMụcKỹNăng (CRUD thuần);
      :Hiển thị thông báo lưu thành công;
      :Tải lại danh sách kỹ năng;
    else (Sai)
      :Hiển thị thông báo dữ liệu không hợp lệ;
    endif
  else (Xóa)
    :Chọn kỹ năng cần xóa;
    :Xác nhận xóa kỹ năng;
    :Hệ thống xóa DanhMụcKỹNăng;
    :Hiển thị thông báo đã xóa;
    :Tải lại danh sách kỹ năng;
  endif
else (Sai)
  :Hiển thị thông báo không tải được danh mục kỹ năng;
endif
stop
@enduml
