@startuml
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam linetype ortho
skinparam nodesep 50
skinparam ranksep 80
top to bottom direction
skinparam actorStyle stick
skinparam roundcorner 8
skinparam ArrowColor #333333
skinparam rectangleBorderColor #333333
skinparam boundary {
  BackgroundColor White
  BorderColor #333333
}
skinparam control {
  BackgroundColor White
  BorderColor #333333
}
skinparam entity {
  BackgroundColor White
  BorderColor #333333
}

actor "Nhà tuyển dụng\n(from Usecase Diagram)" as Actor

together {
  boundary "lich-phong-van-ntd" as UI
  boundary "form-ket-qua-phong-van" as Form
}

together {
  control "cap-nhat-ket-qua-phong-van" as Controller
}

together {
  entity "LichPhongVan" as LichPhongVan
  entity "HoSoUngTuyen" as HoSoUngTuyen
  entity "LichSuHoSoUngTuyen" as LichSuHoSoUngTuyen
  entity "NhaTuyenDung" as NhaTuyenDung
  entity "TinTuyenDung" as TinTuyenDung
  entity "ThongBao" as ThongBao
}

Actor <--> UI
UI <--> Form
Form <--> Controller

Controller <--> LichPhongVan
Controller <--> HoSoUngTuyen
Controller <--> NhaTuyenDung
Controller <--> TinTuyenDung
Controller <--> LichSuHoSoUngTuyen
Controller <--> ThongBao
@enduml
