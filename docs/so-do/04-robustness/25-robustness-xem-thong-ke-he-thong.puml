@startuml
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam linetype ortho
skinparam nodesep 45
skinparam ranksep 70
top to bottom direction
skinparam actorStyle stick
skinparam roundcorner 8
skinparam ArrowColor #333333
skinparam rectangleBorderColor #333333
skinparam boundary {
  BackgroundColor White
  BorderColor #333333
}
skinparam control {
  BackgroundColor White
  BorderColor #333333
}
skinparam entity {
  BackgroundColor White
  BorderColor #333333
}

actor "Quản trị viên\n(from Usecase Diagram)" as Actor

' ── Lớp boundary (màn hình) ──
together {
  boundary "quan-tri-dashboard" as UI
}

' ── Lớp control (xử lý) ──
together {
  control "thong-ke-quan-tri" as Controller
  control "canh-bao-quan-tri" as AlertController
}

' ── Lớp entity (dữ liệu) ──
together {
  entity "NguoiDung" as NguoiDung
  entity "TinTuyenDung" as TinTuyenDung
  entity "NhaTuyenDung" as NhaTuyenDung
  entity "HoSoUngTuyen" as HoSoUngTuyen
}

' ── Quan hệ actor ↔ boundary ──
Actor <--> UI

' ── boundary ↔ control ──
UI <--> Controller
UI <--> AlertController

' ── control thống kê đọc 4 danh sách ──
Controller <--> NguoiDung
Controller <--> TinTuyenDung
Controller <--> NhaTuyenDung
Controller <--> HoSoUngTuyen

' ── control cảnh báo đếm 4 nguồn ──
AlertController <--> TinTuyenDung
AlertController <--> NhaTuyenDung
AlertController <--> HoSoUngTuyen
AlertController <--> NguoiDung
@enduml
