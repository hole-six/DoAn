@startuml
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam linetype ortho
skinparam nodesep 50
skinparam ranksep 80
left to right direction
skinparam actorStyle stick
skinparam roundcorner 8
skinparam ArrowColor #333333
skinparam rectangleBorderColor #333333
skinparam boundary {
  BackgroundColor White
  BorderColor #333333
}
skinparam control {
  BackgroundColor White
  BorderColor #333333
}
skinparam entity {
  BackgroundColor White
  BorderColor #333333
}

actor "Quản trị viên\n(from Usecase Diagram)" as Actor

together {
  boundary "quan-tri-dashboard" as UI
}

together {
  control "thong-ke-quan-tri" as StatsCtrl
  control "canh-bao-quan-tri" as AlertCtrl
}

together {
  entity "NguoiDung" as NguoiDung
  entity "TinTuyenDung" as TinTuyenDung
  entity "NhaTuyenDung" as NhaTuyenDung
  entity "HoSoUngTuyen" as HoSoUngTuyen
}

Actor <--> UI

UI <--> StatsCtrl
UI <--> AlertCtrl

StatsCtrl <--> NguoiDung
StatsCtrl <--> TinTuyenDung
StatsCtrl <--> NhaTuyenDung
StatsCtrl <--> HoSoUngTuyen

AlertCtrl <--> TinTuyenDung
AlertCtrl <--> NhaTuyenDung
AlertCtrl <--> HoSoUngTuyen
AlertCtrl <--> NguoiDung
@enduml
