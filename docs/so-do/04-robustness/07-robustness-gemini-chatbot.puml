@startuml
left to right direction
skinparam shadowing false
title Robustness - Gemini chatbot và fallback database

actor "Người dùng" as User
boundary "AIWidget" as AIWidget
control "AiController" as AiController
control "AiService" as AiService
control "Gemini API" as Gemini
entity "TinTuyểnDụng" as Job
entity "HồSơNăngLực" as CV
database "MongoDB" as DB

User --> AIWidget : nhập câu hỏi
AIWidget --> AiController : POST /ai/chatbot
AiController --> AiService : xử lý câu hỏi
AiService --> Job : tìm việc phù hợp
Job --> DB : truy vấn tin đang mở
AiService --> CV : lấy ngữ cảnh CV nếu có
AiService --> Gemini : sinh câu trả lời
Gemini --> AiService : trả lời hoặc lỗi
AiService --> AiController : kết quả Gemini hoặc fallback DB
AiController --> AIWidget : trả nội dung hiển thị
@enduml

