@startuml
left to right direction
skinparam shadowing false
title Robustness - Ứng tuyển

actor "Ứng viên" as Candidate
boundary "ChiTiếtViệcLàm" as JobDetail
boundary "ModalỨngTuyển" as ApplyModal
control "ỨngTuyểnController" as ApplyController
control "ThôngBáoService" as NotifyService
entity "TinTuyểnDụng" as Job
entity "HồSơNăngLực" as CV
entity "HồSơỨngTuyển" as Application
entity "ThôngBáo" as Notify
database "MongoDB" as DB

Candidate --> JobDetail : chọn việc làm
JobDetail --> ApplyModal : mở form ứng tuyển
ApplyModal --> ApplyController : gửi CV/hồ sơ
ApplyController --> Job : kiểm tra tin đang mở
ApplyController --> CV : kiểm tra hồ sơ ứng viên
ApplyController --> Application : tạo hồ sơ ứng tuyển
Application --> DB : lưu
ApplyController --> NotifyService : thông báo nhà tuyển dụng
NotifyService --> Notify : tạo thông báo
Notify --> DB : lưu
@enduml

