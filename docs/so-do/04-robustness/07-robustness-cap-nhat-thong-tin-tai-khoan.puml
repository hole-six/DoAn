@startuml
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam linetype ortho
left to right direction
skinparam actorStyle stick
skinparam roundcorner 8
skinparam ArrowColor #333333
skinparam rectangleBorderColor #333333
skinparam boundary {
  BackgroundColor White
  BorderColor #333333
}
skinparam control {
  BackgroundColor White
  BorderColor #333333
}
skinparam entity {
  BackgroundColor White
  BorderColor #333333
}

actor "Ứng viên / Nhà tuyển dụng / Quản trị viên\n(from Usecase Diagram)" as Actor
boundary "cai-dat-tai-khoan" as UI
boundary "form-cap-nhat-tai-khoan" as Form
control "cap-nhat-thong-tin-tai-khoan" as Controller

entity "NguoiDung" as MainEntity
entity "UngVien" as E1
entity "NhaTuyenDung" as E2

Actor <--> UI
UI <--> Form
Form <--> Controller
Controller <--> MainEntity
Controller <--> E1
Controller <--> E2
entity "UngVienKyNang" as UngVienKyNang
Controller -right-> UngVienKyNang
@enduml
