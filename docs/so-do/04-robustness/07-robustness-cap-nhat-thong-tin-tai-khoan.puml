@startuml
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam linetype ortho
skinparam nodesep 50
skinparam ranksep 80
left to right direction
skinparam actorStyle stick
skinparam roundcorner 8
skinparam ArrowColor #333333
skinparam rectangleBorderColor #333333
skinparam boundary {
  BackgroundColor White
  BorderColor #333333
}
skinparam control {
  BackgroundColor White
  BorderColor #333333
}
skinparam entity {
  BackgroundColor White
  BorderColor #333333
}

actor "Ứng viên / Nhà tuyển dụng / Quản trị viên\n(from Usecase Diagram)" as Actor

together {
  boundary "cai-dat-tai-khoan" as UI
  boundary "form-cap-nhat-tai-khoan" as Form
}

together {
  control "cap-nhat-thong-tin-tai-khoan" as AccountController
  control "luu-tuy-chon-thong-bao" as SettingController
}

together {
  entity "NguoiDung" as NguoiDung
  entity "LocalStorage" as LocalStorage
}

Actor <--> UI
UI <--> Form
Form <--> AccountController
AccountController <--> NguoiDung
Form <--> SettingController
SettingController <--> LocalStorage
@enduml
