@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam titleFontSize 18
skinparam shadowing false
skinparam linetype ortho
left to right direction
skinparam actorStyle stick
skinparam roundcorner 12
skinparam rectangleBorderColor #222222
skinparam boundary {
  BackgroundColor White
  BorderColor #222222
}
skinparam control {
  BackgroundColor White
  BorderColor #222222
}
skinparam entity {
  BackgroundColor White
  BorderColor #222222
}
title Robustness Usecase - "Quản lý danh mục kỹ năng"

actor "Actor: Quản trị viên\n(from Usecase Diagram)" as Actor
boundary "UI: quan-tri-ky-nang" as UI
boundary "UI: form-ky-nang" as Form
control "Controller: KyNangController" as Controller
entity "Entity: KyNang" as MainEntity
entity "Entity: TinTuyenDung" as E1
entity "Entity: UngVien" as E2

Actor --> UI : Mở trang danh mục kỹ năng
UI <--> Form : mở form / hiển thị dữ liệu
Actor --> Form : Thêm, sửa, xóa hoặc gộp kỹ năng
Form --> Controller : quanLyKyNang(request)
UI --> Controller : tải dữ liệu hiện có
Controller <--> MainEntity : Kiểm tra tên kỹ năng, loại kỹ năng và ràng buộc sử dụng\nCập nhật danh mục kỹ năng
Controller <--> E1 : Kiểm tra tin tuyển dụng và hồ sơ đang tham chiếu
Controller --> Form : Trả danh mục kỹ năng mới / Thông báo kỹ năng trùng hoặc đang được sử dụng
Controller --> UI : trả dữ liệu mới
@enduml
