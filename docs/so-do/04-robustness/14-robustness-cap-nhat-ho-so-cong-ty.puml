@startuml
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam linetype ortho
left to right direction
skinparam actorStyle stick
skinparam roundcorner 8
skinparam ArrowColor #333333
skinparam rectangleBorderColor #333333
skinparam boundary {
  BackgroundColor White
  BorderColor #333333
}
skinparam control {
  BackgroundColor White
  BorderColor #333333
}
skinparam entity {
  BackgroundColor White
  BorderColor #333333
}

actor "Nhà tuyển dụng\n(from Usecase Diagram)" as Actor
boundary "thong-tin-cong-ty" as UI
boundary "form-ho-so-cong-ty" as Form
control "cap-nhat-ho-so-cong-ty" as Controller

entity "NhaTuyenDung" as MainEntity
entity "NguoiDung" as E1
entity "ThongBao" as E2

Actor <--> UI
UI <--> Form
Form <--> Controller
Controller <--> MainEntity
Controller <--> E1
Controller <--> E2
@enduml
