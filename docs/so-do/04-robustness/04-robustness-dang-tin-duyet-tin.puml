@startuml
left to right direction
skinparam shadowing false
title Robustness - Đăng tin và duyệt tin tuyển dụng

actor "Nhà tuyển dụng" as Employer
actor "Quản trị viên" as Admin
boundary "TrangQuảnLýTin" as JobPage
boundary "DashboardQuảnTrị" as AdminPage
control "TinTuyểnDụngController" as JobController
control "AdminTinController" as AdminJobController
control "ThôngBáoService" as NotifyService
entity "NhàTuyểnDụng" as Company
entity "TinTuyểnDụng" as Job
entity "ThôngBáo" as Notify
database "MongoDB" as DB

Employer --> JobPage : nhập tin tuyển dụng
JobPage --> JobController : tạo tin
JobController --> Company : kiểm tra đã duyệt
JobController --> Job : lưu tin chờ duyệt
Job --> DB : insert
JobController --> NotifyService : báo admin
NotifyService --> Notify : tạo thông báo
Admin --> AdminPage : mở tin chờ duyệt
AdminPage --> AdminJobController : duyệt/từ chối
AdminJobController --> Job : cập nhật trạng thái
AdminJobController --> NotifyService : báo nhà tuyển dụng
@enduml

