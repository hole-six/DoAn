@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam titleFontSize 18
skinparam shadowing false
skinparam linetype ortho
left to right direction
skinparam actorStyle stick
skinparam roundcorner 12
skinparam rectangleBorderColor #222222
skinparam boundary {
  BackgroundColor White
  BorderColor #222222
}
skinparam control {
  BackgroundColor White
  BorderColor #222222
}
skinparam entity {
  BackgroundColor White
  BorderColor #222222
}
title Robustness Usecase - "Đăng tin tuyển dụng"

actor "Actor: Nhà tuyển dụng\n(from Usecase Diagram)" as Actor
boundary "UI: quan-ly-tin" as UI
boundary "UI: form-dang-tin" as Form
control "Controller: TinTuyenDungController" as Controller
entity "Entity: TinTuyenDung" as MainEntity
entity "Entity: NhaTuyenDung" as E1
entity "Entity: KyNang" as E2
entity "Entity: ThongBao" as E3

Actor --> UI : Nhấn Đăng tin tuyển dụng
UI <--> Form : mở form / hiển thị dữ liệu
Actor --> Form : Nhập tiêu đề, mô tả, kỹ năng, lương và hạn nộp
Form --> Controller : taoTinTuyenDung(request)
UI --> Controller : tải dữ liệu hiện có
Controller <--> MainEntity : Kiểm tra công ty đã duyệt và dữ liệu tin\nTạo tin tuyển dụng chờ duyệt
Controller <--> E1 : Lưu kỹ năng và gửi thông báo cho admin
Controller --> Form : Thông báo tin đã gửi duyệt / Thông báo công ty chưa được duyệt hoặc dữ liệu lỗi
Controller --> UI : trả dữ liệu mới
@enduml
