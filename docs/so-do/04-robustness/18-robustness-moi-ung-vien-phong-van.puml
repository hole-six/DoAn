@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam titleFontSize 18
skinparam shadowing false
skinparam linetype ortho
left to right direction
skinparam actorStyle stick
skinparam roundcorner 12
skinparam rectangleBorderColor #222222
skinparam boundary {
  BackgroundColor White
  BorderColor #222222
}
skinparam control {
  BackgroundColor White
  BorderColor #222222
}
skinparam entity {
  BackgroundColor White
  BorderColor #222222
}
title Robustness Usecase - "Mời ứng viên phỏng vấn"

actor "Actor: Nhà tuyển dụng\n(from Usecase Diagram)" as Actor
boundary "UI: pipeline-ung-vien" as UI
boundary "UI: form-moi-phong-van" as Form
control "Controller: LichPhongVanController" as Controller
entity "Entity: LichPhongVan" as MainEntity
entity "Entity: HoSoUngTuyen" as E1
entity "Entity: ThongBao" as E2

Actor --> UI : Chọn hồ sơ để mời phỏng vấn
UI <--> Form : mở form / hiển thị dữ liệu
Actor --> Form : Chọn thời gian, hình thức, địa điểm hoặc link online
Form --> Controller : taoLichPhongVan(request)
UI --> Controller : tải dữ liệu hiện có
Controller <--> MainEntity : Kiểm tra hồ sơ đủ điều kiện và thời gian hợp lệ\nTạo lịch phỏng vấn
Controller <--> E1 : Cập nhật hồ sơ sang mời phỏng vấn và báo ứng viên
Controller --> Form : Thông báo đã gửi lời mời phỏng vấn / Thông báo thời gian hoặc hình thức không hợp lệ
Controller --> UI : trả dữ liệu mới
@enduml
