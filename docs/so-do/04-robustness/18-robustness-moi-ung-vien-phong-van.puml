@startuml
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam linetype ortho
skinparam nodesep 45
skinparam ranksep 70
top to bottom direction
skinparam actorStyle stick
skinparam roundcorner 8
skinparam ArrowColor #333333
skinparam rectangleBorderColor #333333
skinparam boundary {
  BackgroundColor White
  BorderColor #333333
}
skinparam control {
  BackgroundColor White
  BorderColor #333333
}
skinparam entity {
  BackgroundColor White
  BorderColor #333333
}

actor "Nhà tuyển dụng\n(from Usecase Diagram)" as Actor

' ── Lớp boundary (màn hình) ──
together {
  boundary "pipeline-ung-vien" as UI
  boundary "form-moi-phong-van" as Form
}

' ── Lớp control (xử lý) ──
together {
  control "moi-ung-vien-phong-van" as Controller
}

' ── Lớp entity (dữ liệu) ──
together {
  entity "LichPhongVan" as LichPhongVan
  entity "HoSoUngTuyen" as HoSoUngTuyen
  entity "UngVien" as UngVien
  entity "TinTuyenDung" as TinTuyenDung
  entity "LichSuHoSoUngTuyen" as LichSuHoSoUngTuyen
  entity "ThongBao" as ThongBao
}

' ── Quan hệ actor ↔ boundary ──
Actor <--> UI

' ── boundary ↔ boundary / control ──
UI <--> Form
Form <--> Controller

' ── control ↔ entity ──
Controller <--> HoSoUngTuyen
Controller <--> TinTuyenDung
Controller <--> UngVien
Controller <--> LichPhongVan
Controller <--> LichSuHoSoUngTuyen
Controller <--> ThongBao
@enduml
