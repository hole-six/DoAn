@startuml
left to right direction
skinparam shadowing false
title Robustness - Quên mật khẩu

actor "Người dùng" as User
boundary "TrangQuênMậtKhẩu" as ForgotPage
boundary "TrangĐặtLạiMậtKhẩu" as ResetPage
control "XácThựcController" as AuthController
control "XácThựcService" as AuthService
control "EmailService" as EmailService
entity "NgườiDùng" as UserEntity
entity "ResetToken" as ResetToken
database "MongoDB" as DB

User --> ForgotPage : nhập email
ForgotPage --> AuthController : yêu cầu reset
AuthController --> AuthService : tạo token
AuthService --> UserEntity : tìm tài khoản
UserEntity --> DB : truy vấn
AuthService --> ResetToken : sinh và hash token
AuthService --> EmailService : gửi link reset
EmailService --> User : email reset
User --> ResetPage : mở link
ResetPage --> AuthController : xác minh token/mật khẩu mới
AuthController --> AuthService : cập nhật mật khẩu
AuthService --> UserEntity : lưu mật khẩu mới
UserEntity --> DB : cập nhật
@enduml

