@startuml
left to right direction
skinparam shadowing false
title Robustness - Lịch phỏng vấn

actor "Nhà tuyển dụng" as Employer
actor "Ứng viên" as Candidate
boundary "PipelineỨngViên" as Pipeline
boundary "TrangLịchPhỏngVấn" as InterviewPage
control "LịchPhỏngVấnController" as InterviewController
control "ThôngBáoService" as NotifyService
entity "HồSơỨngTuyển" as Application
entity "LịchPhỏngVấn" as Interview
entity "ThôngBáo" as Notify
database "MongoDB" as DB

Employer --> Pipeline : chọn ứng viên
Pipeline --> InterviewController : tạo lịch
InterviewController --> Application : kiểm tra quyền
InterviewController --> Interview : tạo lịch phỏng vấn
Interview --> DB : lưu
InterviewController --> NotifyService : báo ứng viên
Candidate --> InterviewPage : xác nhận/yêu cầu đổi lịch
InterviewPage --> InterviewController : cập nhật phản hồi
InterviewController --> Interview : cập nhật trạng thái
Employer --> InterviewPage : cập nhật kết quả
InterviewPage --> InterviewController : đạt/không đạt + ghi chú
InterviewController --> Application : cập nhật kết quả ứng tuyển
NotifyService --> Notify : lưu thông báo
@enduml

