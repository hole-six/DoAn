@startuml
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam linetype polyline
left to right direction
skinparam actorStyle stick
skinparam roundcorner 8
skinparam ArrowColor #333333
skinparam rectangleBorderColor #333333
skinparam boundary {
  BackgroundColor White
  BorderColor #333333
}
skinparam control {
  BackgroundColor White
  BorderColor #333333
}
skinparam entity {
  BackgroundColor White
  BorderColor #333333
}

actor "Khách vãng lai\n(from Usecase Diagram)" as Actor
boundary "dang-ky" as UI
boundary "form-dang-ky" as Form
control "dang-ky-tai-khoan" as Controller

entity "NguoiDung" as NguoiDung
entity "UngVien" as UngVien
entity "NhaTuyenDung" as NhaTuyenDung
entity "ThongBao" as ThongBao

Actor -right-> UI
UI -right-> Form
Form -right-> Controller

Controller -right-> NguoiDung
Controller -right-> UngVien
Controller -right-> NhaTuyenDung
Controller -right-> ThongBao

NguoiDung -down[hidden]-> UngVien
UngVien -down[hidden]-> NhaTuyenDung
NhaTuyenDung -down[hidden]-> ThongBao
@enduml
