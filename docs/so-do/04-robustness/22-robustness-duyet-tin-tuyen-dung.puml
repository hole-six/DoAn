@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam titleFontSize 18
skinparam shadowing false
skinparam linetype ortho
left to right direction
skinparam actorStyle stick
skinparam roundcorner 12
skinparam rectangleBorderColor #222222
skinparam boundary {
  BackgroundColor White
  BorderColor #222222
}
skinparam control {
  BackgroundColor White
  BorderColor #222222
}
skinparam entity {
  BackgroundColor White
  BorderColor #222222
}
title Robustness Usecase - "Duyệt tin tuyển dụng"

actor "Actor: Quản trị viên\n(from Usecase Diagram)" as Actor
boundary "UI: quan-tri-tin-tuyen-dung" as UI
boundary "UI: form-duyet-tin" as Form
control "Controller: TinTuyenDungController" as Controller
entity "Entity: TinTuyenDung" as MainEntity
entity "Entity: NhaTuyenDung" as E1
entity "Entity: ThongBao" as E2

Actor --> UI : Mở danh sách tin chờ duyệt
UI <--> Form : mở form / hiển thị dữ liệu
Actor --> Form : Xem nội dung và chọn duyệt hoặc từ chối
Form --> Controller : duyetTinTuyenDung(request)
UI --> Controller : tải dữ liệu hiện có
Controller <--> MainEntity : Kiểm tra tin và công ty liên quan\nCập nhật trạng thái tin tuyển dụng
Controller <--> E1 : Gửi thông báo cho nhà tuyển dụng
Controller --> Form : Thông báo xử lý tin thành công / Thông báo tin không hợp lệ hoặc thiếu lý do
Controller --> UI : trả dữ liệu mới
@enduml
