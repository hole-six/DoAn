@startuml
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam linetype ortho
skinparam nodesep 50
skinparam ranksep 80
left to right direction
skinparam actorStyle stick
skinparam roundcorner 8
skinparam ArrowColor #333333
skinparam rectangleBorderColor #333333
skinparam boundary {
  BackgroundColor White
  BorderColor #333333
}
skinparam control {
  BackgroundColor White
  BorderColor #333333
}
skinparam entity {
  BackgroundColor White
  BorderColor #333333
}

actor "Quản trị viên\n(from Usecase Diagram)" as Actor

together {
  boundary "quan-tri-tin-tuyen-dung" as UI
  boundary "form-duyet-tin" as Form
}

together {
  control "duyet-tin-tuyen-dung" as Controller
}

together {
  entity "TinTuyenDung" as TinTuyenDung
  entity "TinTuyenDungKyNang" as TinTuyenDungKyNang
  entity "NhaTuyenDung" as NhaTuyenDung
  entity "ThongBao" as ThongBao
}

Actor <--> UI
UI <--> Form
Form <--> Controller

Controller <--> TinTuyenDung
Controller <--> TinTuyenDungKyNang
Controller <--> NhaTuyenDung
Controller <--> ThongBao

TinTuyenDung -[hidden]right-> TinTuyenDungKyNang
TinTuyenDungKyNang -[hidden]right-> NhaTuyenDung
NhaTuyenDung -[hidden]right-> ThongBao
@enduml
