@startuml
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam linetype ortho
skinparam nodesep 50
skinparam ranksep 80
top to bottom direction
skinparam actorStyle stick
skinparam roundcorner 8
skinparam ArrowColor #333333
skinparam rectangleBorderColor #333333
skinparam boundary {
  BackgroundColor White
  BorderColor #333333
}
skinparam control {
  BackgroundColor White
  BorderColor #333333
}
skinparam entity {
  BackgroundColor White
  BorderColor #333333
}

actor "Ứng viên\n(from Usecase Diagram)" as Actor

' ── Lớp boundary ──
' bo-loc-trang-thai nằm trong trang ho-so-ung-tuyen, không phải entry point riêng
together {
  boundary "ho-so-ung-tuyen" as UI
  boundary "bo-loc-trang-thai" as FilterForm
  boundary "section-lich-phong-van" as LichSection
}

' ── Lớp control ──
together {
  control "theo-doi-trang-thai-ung-tuyen" as Controller
  control "xem-lich-phong-van" as LichCtrl
}

' ── Lớp entity ──
together {
  entity "HoSoUngTuyen" as HoSoUngTuyen
  entity "UngVien" as UngVien
  entity "TinTuyenDung" as TinTuyenDung
  entity "NhaTuyenDung" as NhaTuyenDung
  entity "HoSoNangLuc" as HoSoNangLuc
  entity "LichPhongVan" as LichPhongVan
}

' Actor vào trang chính
Actor <--> UI

' Các thành phần con nằm trong trang
UI <--> FilterForm
UI <--> LichSection

' Bộ lọc gọi controller chính để lọc danh sách
FilterForm <--> Controller

' Section lịch phỏng vấn có controller riêng
LichSection <--> LichCtrl

' Controller chính đọc dữ liệu hồ sơ ứng tuyển
Controller <--> HoSoUngTuyen
Controller <--> UngVien
Controller <--> TinTuyenDung
Controller <--> NhaTuyenDung
Controller <--> HoSoNangLuc

' Controller lịch phỏng vấn
LichCtrl <--> LichPhongVan
@enduml
