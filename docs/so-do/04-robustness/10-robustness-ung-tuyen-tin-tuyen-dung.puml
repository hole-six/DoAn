@startuml
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam linetype ortho
skinparam nodesep 45
skinparam ranksep 70
top to bottom direction
skinparam actorStyle stick
skinparam roundcorner 8
skinparam ArrowColor #333333
skinparam rectangleBorderColor #333333
skinparam boundary {
  BackgroundColor White
  BorderColor #333333
}
skinparam control {
  BackgroundColor White
  BorderColor #333333
}
skinparam entity {
  BackgroundColor White
  BorderColor #333333
}

actor "Ứng viên\n(from Usecase Diagram)" as Actor

' ── Lớp boundary (màn hình) ──
together {
  boundary "chi-tiet-viec-lam" as UI
  boundary "form-ung-tuyen" as Form
}

' ── Lớp control (xử lý) ──
together {
  control "ung-tuyen-tin-tuyen-dung" as Controller
}

' ── Lớp entity (dữ liệu) ──
together {
  entity "HoSoUngTuyen" as HoSoUngTuyen
  entity "UngVien" as UngVien
  entity "TinTuyenDung" as TinTuyenDung
  entity "NhaTuyenDung" as NhaTuyenDung
  entity "HoSoNangLuc" as HoSoNangLuc
  entity "LichSuHoSoUngTuyen" as LichSuHoSoUngTuyen
  entity "ThongBao" as ThongBao
}

' ── Quan hệ actor ↔ boundary ──
Actor <--> UI

' ── boundary ↔ boundary / control ──
UI <--> Form
Form <--> Controller

' ── control ↔ entity ──
Controller <--> HoSoUngTuyen
Controller <--> UngVien
Controller <--> TinTuyenDung
Controller <--> NhaTuyenDung
Controller <--> HoSoNangLuc
Controller <--> LichSuHoSoUngTuyen
Controller <--> ThongBao
@enduml
