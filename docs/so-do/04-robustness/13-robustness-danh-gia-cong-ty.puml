@startuml
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam linetype ortho
skinparam nodesep 45
skinparam ranksep 70
top to bottom direction
skinparam actorStyle stick
skinparam roundcorner 8
skinparam ArrowColor #333333
skinparam rectangleBorderColor #333333
skinparam boundary {
  BackgroundColor White
  BorderColor #333333
}
skinparam control {
  BackgroundColor White
  BorderColor #333333
}
skinparam entity {
  BackgroundColor White
  BorderColor #333333
}

actor "Ứng viên\n(from Usecase Diagram)" as Actor

' ── Lớp boundary (màn hình) ──
together {
  boundary "ho-so-ung-tuyen" as UI
  boundary "drawer-chi-tiet-ung-tuyen" as Form
}

' ── Lớp control (xử lý) ──
together {
  control "danh-gia-cong-ty" as Controller
}

' ── Lớp entity (dữ liệu) ──
together {
  entity "DanhGiaCongTy" as MainEntity
  entity "HoSoUngTuyen" as E1
  entity "LichPhongVan" as E2
  entity "NhaTuyenDung" as E3
  entity "UngVien" as E4
}

' ── Quan hệ actor ↔ boundary ──
Actor <--> UI

' ── boundary ↔ boundary / control ──
UI <--> Form
Form <--> Controller

' ── control ↔ entity ──
Controller <--> MainEntity
Controller <--> E1
Controller <--> E2
Controller <--> E3
Controller <--> E4
@enduml
