@startuml
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam linetype ortho
skinparam nodesep 45
skinparam ranksep 70
top to bottom direction
skinparam actorStyle stick
skinparam roundcorner 8
skinparam ArrowColor #333333
skinparam rectangleBorderColor #333333
skinparam boundary {
  BackgroundColor White
  BorderColor #333333
}
skinparam control {
  BackgroundColor White
  BorderColor #333333
}
skinparam entity {
  BackgroundColor White
  BorderColor #333333
}

actor "Khách vãng lai / Ứng viên\n(from Usecase Diagram)" as Actor

' ── Lớp boundary (màn hình) ──
together {
  boundary "viec-lam" as UI
  boundary "bo-loc-viec-lam" as Form
  boundary "goi-y-tim-kiem" as Suggest
  boundary "tro-ly-ai" as AiBox
  boundary "trang-viec-da-luu" as SavedPage
}

' ── Lớp control (xử lý) ──
together {
  control "tim-kiem-viec-lam" as Controller
  control "goi-y-tim-kiem" as SuggestCtrl
  control "tro-ly-ai" as AiCtrl
  control "viec-lam-da-luu" as SavedCtrl
}

' ── Lớp entity (dữ liệu) ──
together {
  entity "TinTuyenDung" as TinTuyenDung
  entity "TinTuyenDungKyNang" as TinTuyenDungKyNang
  entity "DanhMucKyNang" as DanhMucKyNang
  entity "NhaTuyenDung" as NhaTuyenDung
  entity "ViecLamDaLuu" as ViecLamDaLuu
}

' ── Quan hệ actor ↔ boundary ──
Actor <--> UI
Actor <--> Form

' ── boundary ↔ boundary / control ──
UI <--> Controller
UI <--> SavedPage
Form <--> Suggest
Form <--> AiBox
Suggest <--> SuggestCtrl
AiBox <--> AiCtrl
SavedPage <--> SavedCtrl

' ── control ↔ entity ──
Controller <--> TinTuyenDung
Controller <--> TinTuyenDungKyNang
Controller <--> DanhMucKyNang
Controller <--> NhaTuyenDung
SuggestCtrl <--> TinTuyenDung
SuggestCtrl <--> DanhMucKyNang
SuggestCtrl <--> NhaTuyenDung
SavedCtrl <--> ViecLamDaLuu
SavedCtrl <--> TinTuyenDung
@enduml
