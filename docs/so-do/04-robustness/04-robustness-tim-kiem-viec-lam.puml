@startuml
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam linetype ortho
skinparam nodesep 50
skinparam ranksep 80
left to right direction
skinparam actorStyle stick
skinparam roundcorner 8
skinparam ArrowColor #333333
skinparam rectangleBorderColor #333333
skinparam boundary {
  BackgroundColor White
  BorderColor #333333
}
skinparam control {
  BackgroundColor White
  BorderColor #333333
}
skinparam entity {
  BackgroundColor White
  BorderColor #333333
}

actor "Khách vãng lai / Ứng viên\n(from Usecase Diagram)" as Actor

' ── Lớp boundary ──
together {
  boundary "viec-lam" as UI
  boundary "bo-loc-viec-lam" as FilterForm
  boundary "goi-y-tim-kiem" as Suggest
  boundary "trang-viec-da-luu" as SavedPage
}

' ── Lớp control ──
together {
  control "tim-kiem-viec-lam" as Controller
  control "viec-lam-da-luu" as SavedCtrl
}

' ── Lớp entity ──
together {
  entity "TinTuyenDung" as TinTuyenDung
  entity "TinTuyenDungKyNang" as TinTuyenDungKyNang
  entity "DanhMucKyNang" as DanhMucKyNang
  entity "NhaTuyenDung" as NhaTuyenDung
  entity "ViecLamDaLuu" as ViecLamDaLuu
}

' Actor vào trang chính
Actor <--> UI

' Trang chính chứa các boundary con
UI <--> FilterForm
UI <--> Suggest
UI <--> SavedPage

' Tất cả boundary tìm kiếm đều qua Controller chính
FilterForm <--> Controller
Suggest <--> Controller
SavedPage <--> SavedCtrl

' Controller tìm kiếm đọc dữ liệu
Controller <--> TinTuyenDung
Controller <--> TinTuyenDungKyNang
Controller <--> DanhMucKyNang
Controller <--> NhaTuyenDung

' Controller việc đã lưu
SavedCtrl <--> ViecLamDaLuu
SavedCtrl <--> TinTuyenDung
@enduml
