@startuml
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam linetype ortho
skinparam nodesep 45
skinparam ranksep 70
left to right direction
skinparam actorStyle stick
skinparam roundcorner 8
skinparam ArrowColor #333333
skinparam rectangleBorderColor #333333
skinparam boundary {
  BackgroundColor White
  BorderColor #333333
}
skinparam control {
  BackgroundColor White
  BorderColor #333333
}
skinparam entity {
  BackgroundColor White
  BorderColor #333333
}

actor "Quản trị viên\n(from Usecase Diagram)" as Actor

' ── Lớp boundary (màn hình) ──
together {
  boundary "quan-tri-cong-ty" as UI
  boundary "form-duyet-cong-ty" as Form
}

' ── Lớp control (xử lý) ──
together {
  control "duyet-ho-so-cong-ty" as Controller
}

' ── Lớp entity (dữ liệu) ──
together {
  entity "NhaTuyenDung" as NhaTuyenDung
  entity "ThongBao" as ThongBao
}

' ── Quan hệ actor ↔ boundary ──
Actor <--> UI

' ── boundary ↔ boundary / control ──
UI <--> Form
UI <--> Controller
Form <--> Controller

' ── control ↔ entity ──
Controller <--> NhaTuyenDung
Controller <--> ThongBao
@enduml
