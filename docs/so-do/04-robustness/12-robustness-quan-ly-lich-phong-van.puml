@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam titleFontSize 18
skinparam shadowing false
skinparam linetype ortho
left to right direction
skinparam actorStyle stick
skinparam roundcorner 12
skinparam rectangleBorderColor #222222
skinparam boundary {
  BackgroundColor White
  BorderColor #222222
}
skinparam control {
  BackgroundColor White
  BorderColor #222222
}
skinparam entity {
  BackgroundColor White
  BorderColor #222222
}
title Robustness Usecase - "Quản lý lịch phỏng vấn"

actor "Actor: Ứng viên\n(from Usecase Diagram)" as Actor
boundary "UI: lich-phong-van" as UI
boundary "UI: form-phan-hoi-lich" as Form
control "Controller: LichPhongVanController" as Controller
entity "Entity: LichPhongVan" as MainEntity
entity "Entity: HoSoUngTuyen" as E1
entity "Entity: ThongBao" as E2

Actor --> UI : Mở trang lịch phỏng vấn
UI <--> Form : mở form / hiển thị dữ liệu
Actor --> Form : Xác nhận, yêu cầu đổi lịch hoặc xem chi tiết
Form --> Controller : capNhatTrangThaiLich(request)
UI --> Controller : tải dữ liệu hiện có
Controller <--> MainEntity : Kiểm tra lịch thuộc hồ sơ của ứng viên\nCập nhật trạng thái lịch
Controller <--> E1 : Gửi thông báo cho nhà tuyển dụng
Controller --> Form : Thông báo cập nhật lịch thành công / Thông báo lịch không hợp lệ hoặc đã hủy
Controller --> UI : trả dữ liệu mới
@enduml
