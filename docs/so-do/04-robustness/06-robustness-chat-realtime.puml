@startuml
left to right direction
skinparam shadowing false
title Robustness - Chat realtime

actor "Người gửi" as Sender
actor "Người nhận" as Receiver
boundary "TrangChat" as ChatPage
control "ChatController" as ChatController
control "Socket.IO" as Socket
entity "CuộcTròChuyện" as Conversation
entity "TinNhắn" as Message
database "MongoDB" as DB

Sender --> ChatPage : nhập tin nhắn
ChatPage --> ChatController : gửi tin
ChatController --> Conversation : tìm/tạo cuộc trò chuyện
Conversation --> DB : truy vấn/lưu
ChatController --> Message : tạo tin nhắn
Message --> DB : lưu
ChatController --> Socket : phát sự kiện realtime
Socket --> Receiver : nhận tin mới
@enduml

