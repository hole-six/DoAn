@startuml
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam linetype ortho
skinparam nodesep 50
skinparam ranksep 80
left to right direction
skinparam actorStyle stick
skinparam roundcorner 8
skinparam ArrowColor #333333
skinparam rectangleBorderColor #333333
skinparam boundary {
  BackgroundColor White
  BorderColor #333333
}
skinparam control {
  BackgroundColor White
  BorderColor #333333
}
skinparam entity {
  BackgroundColor White
  BorderColor #333333
}

actor "Khách vãng lai / Ứng viên\n(from Usecase Diagram)" as Actor

' ── Lớp boundary ──
' chi-tiet-cong-ty là trang chính, 3 section con nằm trong trang
together {
  boundary "chi-tiet-cong-ty" as UI
  boundary "section-thong-tin-cong-ty" as InfoSection
  boundary "section-danh-sach-tin" as TinSection
  boundary "section-danh-gia" as ReviewSection
}

' ── Lớp control ──
together {
  control "xem-chi-tiet-cong-ty" as Controller
  control "danh-sach-tin-cong-ty" as TinCtrl
  control "danh-gia-cong-ty" as DanhGiaCtrl
}

' ── Lớp entity ──
together {
  entity "NhaTuyenDung" as NhaTuyenDung
  entity "NguoiDung" as NguoiDung
  entity "TinTuyenDung" as TinTuyenDung
  entity "DanhGiaCongTy" as DanhGiaCongTy
}

' Actor vào trang chính
Actor <--> UI

' Trang chứa các section con
UI <--> InfoSection
UI <--> TinSection
UI <--> ReviewSection

' Mỗi section nối controller tương ứng
InfoSection <--> Controller
TinSection <--> TinCtrl
ReviewSection <--> DanhGiaCtrl

' Controller đọc dữ liệu
Controller <--> NhaTuyenDung
Controller <--> NguoiDung
TinCtrl <--> TinTuyenDung
DanhGiaCtrl <--> DanhGiaCongTy

NhaTuyenDung -[hidden]right-> NguoiDung
NguoiDung -[hidden]right-> TinTuyenDung
TinTuyenDung -[hidden]right-> DanhGiaCongTy
@enduml
