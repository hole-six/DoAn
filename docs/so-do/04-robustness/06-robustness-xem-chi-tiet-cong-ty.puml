@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam titleFontSize 18
skinparam shadowing false
skinparam linetype ortho
left to right direction
skinparam actorStyle stick
skinparam roundcorner 12
skinparam rectangleBorderColor #222222
skinparam boundary {
  BackgroundColor White
  BorderColor #222222
}
skinparam control {
  BackgroundColor White
  BorderColor #222222
}
skinparam entity {
  BackgroundColor White
  BorderColor #222222
}
title Robustness Usecase - "Xem chi tiết công ty"

actor "Actor: Khách vãng lai / Ứng viên\n(from Usecase Diagram)" as Actor
boundary "UI: chi-tiet-cong-ty" as UI
boundary "UI: khung-thong-tin-cong-ty" as Form
control "Controller: NhaTuyenDungController" as Controller
entity "Entity: NhaTuyenDung" as MainEntity
entity "Entity: TinTuyenDung" as E1
entity "Entity: ReviewCongTy" as E2

Actor --> UI : Mở trang chi tiết công ty
UI <--> Form : mở form / hiển thị dữ liệu
Actor --> Form : Xem hồ sơ, đánh giá và tin đang mở
Form --> Controller : layChiTietCongTy(maCongTy)
UI --> Controller : tải dữ liệu hiện có
Controller <--> MainEntity : Kiểm tra công ty đã được duyệt\nLấy hồ sơ công ty
Controller <--> E1 : Lấy tin tuyển dụng và đánh giá liên quan
Controller --> Form : Hiển thị chi tiết công ty / Thông báo công ty không tồn tại hoặc chưa được duyệt
Controller --> UI : trả dữ liệu mới
@enduml
