@startuml
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam linetype ortho
skinparam nodesep 45
skinparam ranksep 70
top to bottom direction
skinparam actorStyle stick
skinparam roundcorner 8
skinparam ArrowColor #333333
skinparam rectangleBorderColor #333333
skinparam boundary {
  BackgroundColor White
  BorderColor #333333
}
skinparam control {
  BackgroundColor White
  BorderColor #333333
}
skinparam entity {
  BackgroundColor White
  BorderColor #333333
}

actor "Khách vãng lai / Ứng viên\n(from Usecase Diagram)" as Actor

' ── Lớp boundary (màn hình) ──
together {
  boundary "chi-tiet-cong-ty" as UI
  boundary "khung-thong-tin-cong-ty" as Form
}

' ── Lớp control (xử lý) ──
together {
  control "xem-chi-tiet-cong-ty" as Controller
  control "danh-sach-tin-cong-ty" as TinCtrl
  control "danh-gia-cong-ty" as DanhGiaCtrl
}

' ── Lớp entity (dữ liệu) ──
together {
  entity "NhaTuyenDung" as NhaTuyenDung
  entity "NguoiDung" as NguoiDung
  entity "TinTuyenDung" as TinTuyenDung
  entity "DanhGiaCongTy" as DanhGiaCongTy
}

' ── Quan hệ actor ↔ boundary ──
Actor <--> UI

' ── boundary ↔ boundary / control ──
UI <--> Form
Form <--> Controller
Form <--> TinCtrl
Form <--> DanhGiaCtrl

' ── control ↔ entity ──
Controller <--> NhaTuyenDung
Controller <--> NguoiDung
TinCtrl <--> TinTuyenDung
DanhGiaCtrl <--> DanhGiaCongTy
@enduml
