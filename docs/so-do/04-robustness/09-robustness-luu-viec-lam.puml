@startuml
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam linetype ortho
skinparam nodesep 50
skinparam ranksep 80
left to right direction
skinparam actorStyle stick
skinparam roundcorner 8
skinparam ArrowColor #333333
skinparam rectangleBorderColor #333333
skinparam boundary {
  BackgroundColor White
  BorderColor #333333
}
skinparam control {
  BackgroundColor White
  BorderColor #333333
}
skinparam entity {
  BackgroundColor White
  BorderColor #333333
}

actor "Ứng viên\n(from Usecase Diagram)" as Actor

' ── Lớp boundary ──
' nut-luu-viec-lam là action nằm trong trang chi-tiet-viec-lam, không phải trang riêng
together {
  boundary "chi-tiet-viec-lam" as UI
}

' ── Lớp control ──
together {
  control "luu-viec-lam" as Controller
}

' ── Lớp entity ──
together {
  entity "ViecLamDaLuu" as ViecLamDaLuu
  entity "NguoiDung" as NguoiDung
  entity "TinTuyenDung" as TinTuyenDung
}

Actor <--> UI
UI <--> Controller

Controller <--> ViecLamDaLuu
Controller <--> NguoiDung
Controller <--> TinTuyenDung

ViecLamDaLuu -[hidden]right-> NguoiDung
NguoiDung -[hidden]right-> TinTuyenDung
@enduml
