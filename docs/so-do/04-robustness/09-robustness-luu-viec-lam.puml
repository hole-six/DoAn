@startuml
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam linetype ortho
skinparam nodesep 45
skinparam ranksep 70
left to right direction
skinparam actorStyle stick
skinparam roundcorner 8
skinparam ArrowColor #333333
skinparam rectangleBorderColor #333333
skinparam boundary {
  BackgroundColor White
  BorderColor #333333
}
skinparam control {
  BackgroundColor White
  BorderColor #333333
}
skinparam entity {
  BackgroundColor White
  BorderColor #333333
}

actor "Ứng viên\n(from Usecase Diagram)" as Actor

' ── Lớp boundary (màn hình) ──
together {
  boundary "chi-tiet-viec-lam" as UI
  boundary "nut-luu-viec-lam" as Form
}

' ── Lớp control (xử lý) ──
together {
  control "luu-viec-lam" as Controller
}

' ── Lớp entity (dữ liệu) ──
together {
  entity "ViecLamDaLuu" as ViecLamDaLuu
  entity "NguoiDung" as NguoiDung
  entity "TinTuyenDung" as TinTuyenDung
}

' ── Quan hệ actor ↔ boundary ──
Actor <--> UI

' ── boundary ↔ boundary / control ──
UI <--> Form
Form <--> Controller

' ── control ↔ entity ──
Controller <--> ViecLamDaLuu
Controller <--> NguoiDung
Controller <--> TinTuyenDung
@enduml
