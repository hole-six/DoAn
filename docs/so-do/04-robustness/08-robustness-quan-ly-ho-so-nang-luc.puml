@startuml
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam linetype ortho
left to right direction
skinparam actorStyle stick
skinparam roundcorner 8
skinparam ArrowColor #333333
skinparam rectangleBorderColor #333333
skinparam boundary {
  BackgroundColor White
  BorderColor #333333
}
skinparam control {
  BackgroundColor White
  BorderColor #333333
}
skinparam entity {
  BackgroundColor White
  BorderColor #333333
}

actor "Ứng viên\n(from Usecase Diagram)" as Actor
boundary "ho-so-nang-luc" as UI
boundary "form-cv-studio" as Form
control "quan-ly-ho-so-nang-luc" as Controller

entity "HoSoNangLuc" as MainEntity
entity "UngVien" as E1

Actor <--> UI
UI <--> Form
Form <--> Controller
Controller <--> MainEntity
Controller <--> E1
entity "UngVienKyNang" as UngVienKyNang
Controller -right-> UngVienKyNang
@enduml
