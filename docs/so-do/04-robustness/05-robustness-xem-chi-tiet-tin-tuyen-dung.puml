@startuml
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam linetype ortho
skinparam nodesep 45
skinparam ranksep 70
top to bottom direction
skinparam actorStyle stick
skinparam roundcorner 8
skinparam ArrowColor #333333
skinparam rectangleBorderColor #333333
skinparam boundary {
  BackgroundColor White
  BorderColor #333333
}
skinparam control {
  BackgroundColor White
  BorderColor #333333
}
skinparam entity {
  BackgroundColor White
  BorderColor #333333
}

actor "Khách vãng lai / Ứng viên\n(from Usecase Diagram)" as Actor

' ── Lớp boundary (màn hình) ──
together {
  boundary "chi-tiet-viec-lam" as UI
  boundary "khung-thao-tac-viec-lam" as Form
}

' ── Lớp control (xử lý) ──
together {
  control "xem-chi-tiet-tin-tuyen-dung" as Controller
}

' ── Lớp entity (dữ liệu) ──
together {
  entity "TinTuyenDung" as TinTuyenDung
  entity "NhaTuyenDung" as NhaTuyenDung
  entity "TinTuyenDungKyNang" as TinTuyenDungKyNang
  entity "DanhMucKyNang" as DanhMucKyNang
}

' ── Quan hệ actor ↔ boundary ──
Actor <--> UI

' ── boundary ↔ boundary / control ──
UI <--> Form
Form <--> Controller

' ── control ↔ entity ──
Controller <--> TinTuyenDung
Controller <--> NhaTuyenDung
Controller <--> TinTuyenDungKyNang
Controller <--> DanhMucKyNang
@enduml
