@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam titleFontSize 18
skinparam shadowing false
skinparam linetype ortho
left to right direction
skinparam actorStyle stick
skinparam roundcorner 12
skinparam rectangleBorderColor #222222
skinparam boundary {
  BackgroundColor White
  BorderColor #222222
}
skinparam control {
  BackgroundColor White
  BorderColor #222222
}
skinparam entity {
  BackgroundColor White
  BorderColor #222222
}
title Robustness Usecase - "Quản lý tin tuyển dụng"

actor "Actor: Nhà tuyển dụng\n(from Usecase Diagram)" as Actor
boundary "UI: quan-ly-tin" as UI
boundary "UI: form-sua-tin" as Form
control "Controller: TinTuyenDungController" as Controller
entity "Entity: TinTuyenDung" as MainEntity
entity "Entity: NhaTuyenDung" as E1
entity "Entity: KyNang" as E2

Actor --> UI : Mở trang quản lý tin
UI <--> Form : mở form / hiển thị dữ liệu
Actor --> Form : Tìm kiếm, sửa, đóng, mở hoặc xóa tin
Form --> Controller : capNhatTinTuyenDung(request)
UI --> Controller : tải dữ liệu hiện có
Controller <--> MainEntity : Kiểm tra tin thuộc công ty và trạng thái cho phép\nCập nhật trạng thái hoặc nội dung tin
Controller <--> E1 : Cập nhật kỹ năng liên quan nếu có
Controller --> Form : Trả danh sách tin mới / Thông báo không có quyền hoặc trạng thái không hợp lệ
Controller --> UI : trả dữ liệu mới
@enduml
