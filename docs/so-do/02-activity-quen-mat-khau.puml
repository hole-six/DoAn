@startuml
skinparam shadowing false
skinparam activity {
  BackgroundColor White
  BorderColor Black
  ArrowColor Black
}

title Activity Diagram - Quen mat khau bang Email Token

start
:User chon "Quen mat khau";
:Hien thi form nhap email;
:User nhap email dang ky;

if (Email hop le?) then (Co)
  :Gui POST /api/xacthuc/quen-mat-khau;
  if (Email ton tai trong he thong?) then (Co)
    :Tao token reset mat khau;
    :Hash token va luu thoi han 30 phut;
    :Gui email chua link reset;
    if (Gui email thanh cong?) then (Co)
      :Thong bao da gui email reset;
      :User mo email va click link reset;
      :Frontend mo trang dat lai mat khau;
      :GET /api/xacthuc/dat-lai-mat-khau/:token;
      if (Token hop le va chua het han?) then (Co)
        :Hien thi form nhap mat khau moi;
        :User nhap mat khau moi va xac nhan;
        if (Mat khau hop le?) then (Co)
          :POST /api/xacthuc/dat-lai-mat-khau;
          :Cap nhat mat khau moi;
          :Xoa token reset;
          :Thong bao dat lai mat khau thanh cong;
          :Chuyen huong ve trang dang nhap;
          stop
        else (Khong)
          :Thong bao loi mat khau;
          :Nhap lai mat khau moi;
        endif
      else (Khong)
        :Thong bao token khong hop le hoac het han;
        :Yeu cau thuc hien quen mat khau lai;
        stop
      endif
    else (Khong)
      :Thong bao gui email that bai;
      stop
    endif
  else (Khong)
    :Thong bao email khong ton tai;
    :Nhap lai email;
  endif
else (Khong)
  :Thong bao loi du lieu email;
  :Nhap lai email;
endif
@enduml

