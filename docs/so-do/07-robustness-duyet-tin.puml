@startuml
left to right direction
skinparam shadowing false
title Robustness Diagram - Duyet tin tuyen dung

actor "Nha tuyen dung" as Employer
actor "Quan tri vien" as Admin
boundary "QuanLyTinPage" as EmployerJobPage
boundary "DuyetTinAdminPage" as AdminJobPage
control "TinTuyenDungController" as JobController
control "TinTuyenDungService" as JobService
entity "NhaTuyenDungModel" as EmployerModel
entity "TinTuyenDungModel" as JobModel
entity "ThongBaoModel" as NotificationModel
database "MongoDB" as DB

Employer --> EmployerJobPage : nhap tin tuyen dung
EmployerJobPage --> JobController : POST /tintuyendung
JobController --> JobService : tao tin
JobService --> EmployerModel : kiem tra cong ty da duyet
JobService --> JobModel : luu tin cho_duyet
JobModel --> DB : insert tin
JobService --> NotificationModel : thong bao admin

Admin --> AdminJobPage : xem tin cho duyet
AdminJobPage --> JobController : PATCH trang thai
JobController --> JobService : duyet/tu choi tin
JobService --> JobModel : cap nhat trang thai
JobService --> NotificationModel : thong bao nha tuyen dung
NotificationModel --> DB : luu thong bao
@enduml

