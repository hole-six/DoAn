@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 14
skinparam titleFontSize 20
left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam actorStyle stick
skinparam usecase {
  BackgroundColor White
  BorderColor #222222
}
title Use Case - Nhà tuyển dụng

actor "Nhà tuyển dụng" as Employer

rectangle "Dashboard nhà tuyển dụng EffortIT" {
  usecase "Đăng nhập" as Login
  usecase "Cập nhật thông tin tài khoản" as UpdateAccount
  usecase "Cập nhật hồ sơ công ty" as UpdateCompany
  usecase "Đăng tin tuyển dụng" as PostJob
  usecase "Quản lý tin tuyển dụng" as ManageJob
  usecase "Quản lý hồ sơ ứng viên" as Applications
  usecase "Mời ứng viên phỏng vấn" as InviteInterview
  usecase "Cập nhật kết quả phỏng vấn" as InterviewResult
}

Employer --> Login
Employer --> UpdateAccount
Employer --> UpdateCompany
Employer --> PostJob
Employer --> ManageJob
Employer --> Applications
Employer --> InviteInterview
Employer --> InterviewResult

PostJob ..> UpdateCompany : <<precondition>>
ManageJob ..> PostJob : <<extend>>
InviteInterview ..> Applications : <<include>>
InterviewResult ..> InviteInterview : <<extend>>
@enduml
