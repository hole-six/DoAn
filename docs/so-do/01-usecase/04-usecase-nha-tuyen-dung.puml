@startuml
left to right direction
skinparam shadowing false
title Use Case - Nhà tuyển dụng

actor "Nhà tuyển dụng" as Employer
actor "Ứng viên" as Candidate
actor "Quản trị viên" as Admin

rectangle "Dashboard nhà tuyển dụng" {
  usecase "Cập nhật hồ sơ công ty" as Company
  usecase "Gửi công ty chờ duyệt" as SubmitCompany
  usecase "Đăng tin tuyển dụng" as PostJob
  usecase "Quản lý tin tuyển dụng" as ManageJob
  usecase "Tạm đóng/Mở lại tin" as ToggleJob
  usecase "Xem hồ sơ ứng viên" as ViewCandidate
  usecase "Cập nhật pipeline ứng tuyển" as Pipeline
  usecase "Mời phỏng vấn" as Schedule
  usecase "Cập nhật kết quả phỏng vấn" as Result
  usecase "Chat với ứng viên" as ChatCandidate
  usecase "Chat hỗ trợ với quản trị viên" as ChatAdmin
  usecase "Nhận thông báo duyệt" as Notify
}

Employer --> Company
Employer --> SubmitCompany
Employer --> PostJob
Employer --> ManageJob
Employer --> ToggleJob
Employer --> ViewCandidate
Employer --> Pipeline
Employer --> Schedule
Employer --> Result
Employer --> ChatCandidate
Employer --> ChatAdmin
Employer --> Notify

SubmitCompany --> Admin : yêu cầu duyệt
PostJob ..> Company : <<precondition: công ty đã duyệt>>
PostJob --> Admin : tin chờ duyệt
Schedule --> Candidate : gửi lời mời
Result --> Candidate : gửi kết quả
@enduml

