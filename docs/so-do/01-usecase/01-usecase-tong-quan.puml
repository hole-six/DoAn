@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 14
skinparam titleFontSize 20
left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam actorStyle stick
skinparam usecase {
  BackgroundColor White
  BorderColor #222222
}
title Use Case tổng quan - EffortIT

actor "Khách vãng lai" as Guest
actor "Ứng viên" as Candidate
actor "Nhà tuyển dụng" as Employer
actor "Quản trị viên" as Admin

Candidate --|> Guest
Employer --|> Guest
Admin --|> Guest

rectangle "Effort IT - Website tuyển dụng ngành công nghệ thông tin tại Thành phố Đà Nẵng" {
  usecase "Tìm kiếm việc làm" as UC_SearchJob
  usecase "Xem chi tiết tin tuyển dụng" as UC_JobDetail
  usecase "Xem chi tiết công ty" as UC_CompanyDetail
  usecase "Đăng ký tài khoản" as UC_Register
  usecase "Đăng nhập" as UC_Login
  usecase "Quên mật khẩu" as UC_Forgot

  usecase "Cập nhật thông tin tài khoản" as UC_UpdateAccount
  usecase "Quản lý hồ sơ năng lực" as UC_Profile
  usecase "Chọn hoặc upload CV" as UC_SelectCV
  usecase "Lưu việc làm" as UC_SaveJob
  usecase "Ứng tuyển tin tuyển dụng" as UC_Apply
  usecase "Theo dõi trạng thái ứng tuyển" as UC_TrackApplication
  usecase "Quản lý lịch phỏng vấn" as UC_CandidateInterview
  usecase "Đánh giá công ty" as UC_CompanyReview

  usecase "Cập nhật hồ sơ công ty" as UC_UpdateCompany
  usecase "Đăng tin tuyển dụng" as UC_PostJob
  usecase "Quản lý tin tuyển dụng" as UC_ManageJob
  usecase "Quản lý hồ sơ ứng viên" as UC_ManageApplications
  usecase "Mời ứng viên phỏng vấn" as UC_InviteInterview
  usecase "Cập nhật kết quả phỏng vấn" as UC_UpdateInterviewResult

  usecase "Quản lý người dùng" as UC_ManageUsers
  usecase "Duyệt hồ sơ công ty" as UC_ApproveCompany
  usecase "Duyệt tin tuyển dụng" as UC_ApproveJob
  usecase "Quản lý danh mục kỹ năng" as UC_ManageSkills
  usecase "Duyệt đánh giá công ty" as UC_ApproveReview
  usecase "Xem thống kê hệ thống" as UC_Stats
}

Guest --> UC_SearchJob
Guest --> UC_JobDetail
Guest --> UC_CompanyDetail
Guest --> UC_Register
Guest --> UC_Login
Guest --> UC_Forgot

Candidate --> UC_UpdateAccount
Candidate --> UC_Profile
Candidate --> UC_SaveJob
Candidate --> UC_Apply
Candidate --> UC_TrackApplication
Candidate --> UC_CandidateInterview
Candidate --> UC_CompanyReview

Employer --> UC_UpdateAccount
Employer --> UC_UpdateCompany
Employer --> UC_PostJob
Employer --> UC_ManageJob
Employer --> UC_ManageApplications
Employer --> UC_InviteInterview
Employer --> UC_CandidateInterview
Employer --> UC_UpdateInterviewResult

Admin --> UC_ManageUsers
Admin --> UC_ApproveCompany
Admin --> UC_ApproveJob
Admin --> UC_ManageSkills
Admin --> UC_ApproveReview
Admin --> UC_Stats

UC_Apply ..> UC_SelectCV : <<include>>
UC_SelectCV ..> UC_Profile : <<extend>>
UC_SaveJob ..> UC_JobDetail : <<extend>>
UC_CompanyReview ..> UC_CandidateInterview : <<extend>>
UC_TrackApplication ..> UC_Apply : <<precondition>>
UC_PostJob ..> UC_UpdateCompany : <<precondition>>
UC_InviteInterview ..> UC_ManageApplications : <<extend>>
UC_UpdateInterviewResult ..> UC_CandidateInterview : <<extend>>
UC_ApproveCompany ..> UC_UpdateCompany : <<precondition>>
UC_ApproveJob ..> UC_PostJob : <<precondition>>
UC_ApproveReview ..> UC_CompanyReview : <<precondition>>
@enduml
