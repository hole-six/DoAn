@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 14
skinparam titleFontSize 20
left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam actorStyle stick
skinparam usecase {
  BackgroundColor White
  BorderColor #222222
}
title Use Case - Quản trị viên

actor "Quản trị viên" as Admin

rectangle "Dashboard quản trị EffortIT" {
  usecase "Quản lý người dùng" as Users
  usecase "Duyệt hồ sơ công ty" as ApproveCompany
  usecase "Duyệt tin tuyển dụng" as ApproveJob
  usecase "Quản lý danh mục kỹ năng" as Skills
  usecase "Duyệt đánh giá công ty" as Reviews
  usecase "Xem thống kê hệ thống" as Stats
}

Admin --> Users
Admin --> ApproveCompany
Admin --> ApproveJob
Admin --> Skills
Admin --> Reviews
Admin --> Stats

ApproveJob ..> ApproveCompany : <<precondition>>
Reviews ..> Stats : <<extend>>
@enduml
