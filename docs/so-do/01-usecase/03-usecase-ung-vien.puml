@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 14
skinparam titleFontSize 20
left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam actorStyle stick
skinparam usecase {
  BackgroundColor White
  BorderColor #222222
}
title Use Case - Ứng viên

actor "Ứng viên" as Candidate

rectangle "Dashboard ứng viên EffortIT" {
  usecase "Đăng nhập" as Login
  usecase "Cập nhật thông tin tài khoản" as UpdateAccount
  usecase "Quản lý hồ sơ năng lực" as Profile
  usecase "Lưu việc làm" as SaveJob
  usecase "Ứng tuyển tin tuyển dụng" as Apply
  usecase "Theo dõi trạng thái ứng tuyển" as Track
  usecase "Quản lý lịch phỏng vấn" as Interview
  usecase "Đánh giá công ty" as Review
}

Candidate --> Login
Candidate --> UpdateAccount
Candidate --> Profile
Candidate --> SaveJob
Candidate --> Apply
Candidate --> Track
Candidate --> Interview
Candidate --> Review

Apply ..> Profile : <<include>>
Track ..> Apply : <<extend>>
Interview ..> Track : <<extend>>
Review ..> Interview : <<extend>>
@enduml
