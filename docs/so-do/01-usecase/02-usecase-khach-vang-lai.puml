@startuml
left to right direction
skinparam shadowing false
title Use Case - Khách vãng lai

actor "Khách vãng lai" as Guest

rectangle "Khu vực công khai EffortIT" {
  usecase "Xem trang chủ" as Home
  usecase "Tìm việc làm IT" as SearchJob
  usecase "Lọc theo kỹ năng/cấp bậc/hình thức" as FilterJob
  usecase "Xem chi tiết việc làm" as JobDetail
  usecase "Xem danh sách công ty" as CompanyList
  usecase "Xem hồ sơ công ty" as CompanyDetail
  usecase "Hỏi trợ lý AI công khai" as PublicAI
  usecase "Đăng ký" as Register
  usecase "Đăng nhập" as Login
  usecase "Quên mật khẩu" as Forgot
}

Guest --> Home
Guest --> SearchJob
Guest --> FilterJob
Guest --> JobDetail
Guest --> CompanyList
Guest --> CompanyDetail
Guest --> PublicAI
Guest --> Register
Guest --> Login
Guest --> Forgot

FilterJob ..> SearchJob : <<extend>>
JobDetail ..> SearchJob : <<extend>>
CompanyDetail ..> CompanyList : <<extend>>
PublicAI ..> SearchJob : <<include dữ liệu việc làm>>
@enduml

