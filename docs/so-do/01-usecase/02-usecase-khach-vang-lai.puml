@startuml
skinparam defaultFontName "Segoe UI"
skinparam titleFontName "Segoe UI"
skinparam defaultFontSize 14
skinparam titleFontSize 20
left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam actorStyle stick
skinparam usecase {
  BackgroundColor White
  BorderColor #222222
}
title Use Case - Khách vãng lai

actor "Khách vãng lai" as Guest

rectangle "EffortIT" {
  usecase "Tìm kiếm việc làm" as SearchJob
  usecase "Xem chi tiết tin tuyển dụng" as JobDetail
  usecase "Xem chi tiết công ty" as CompanyDetail
  usecase "Đăng ký tài khoản" as Register
  usecase "Đăng nhập" as Login
  usecase "Quên mật khẩu" as Forgot
}

Guest --> SearchJob
Guest --> JobDetail
Guest --> CompanyDetail
Guest --> Register
Guest --> Login
Guest --> Forgot

JobDetail ..> SearchJob : <<extend>>
CompanyDetail ..> JobDetail : <<extend>>
Forgot ..> Login : <<extend>>
@enduml
