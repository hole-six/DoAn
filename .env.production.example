PORT=5000
NODE_OPTIONS=--max-old-space-size=4096
DATABASE_URL=postgresql://itjob:change-this-password@127.0.0.1:5432/da_nang_it_jobs?schema=public
# Chi dung mot lan khi migrate du lieu cu tu MongoDB sang PostgreSQL.
MONGO_URI=mongodb://127.0.0.1:27017/da_nang_it_jobs
JWT_SECRET=change-this-secret
JWT_REFRESH_SECRET=change-this-refresh-secret
FRONTEND_URL=https://effortit.site
CLIENT_URL=https://effortit.site
CORS_ORIGINS=https://effortit.site,https://www.effortit.site
VITE_API_URL=https://effortit.site/api
VITE_PUBLIC_URL=https://effortit.site
VITE_SOCKET_URL=https://effortit.site

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://effortit.site/api/auth/google/callback

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Effort Job <no-reply@effortit.site>

CRAWLER_INTERVAL_HOURS=6
CRAWLER_BATCH_LIMIT=5

DEPLOY_WEBHOOK_PORT=9001
DEPLOY_WEBHOOK_SECRET=change-this-secret
DEPLOY_REPO_DIR=/var/www/itjob
DEPLOY_BRANCH=main
DEPLOY_BACKEND_DIR=/var/www/itjob/backend
DEPLOY_FRONTEND_DIR=/var/www/itjob/frontend
DEPLOY_NGINX_WEB_ROOT=/var/www/itjob-frontend
DEPLOY_PM2_NAME=itjob-backend
