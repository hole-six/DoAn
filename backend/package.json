{
  "name": "backend",
  "version": "1.0.0",
  "description": "API cho website quản lý tuyển dụng việc làm CNTT tại Đà Nẵng",
  "main": "dist/maychu.js",
  "scripts": {
    "don-port": "node scripts/don-port.cjs",
    "predev": "node scripts/don-port.cjs",
    "dev": "node scripts/chay-dev.cjs",
    "build": "tsc",
    "prestart": "node scripts/don-port.cjs",
    "start": "node --dns-result-order=ipv4first dist/maychu.js",
    "seed": "node --dns-result-order=ipv4first ./node_modules/tsx/dist/cli.mjs src/gieodulieu.ts",
    "sync:relations": "node --dns-result-order=ipv4first ./node_modules/tsx/dist/cli.mjs src/scripts/dongbo-quan-he.ts",
    "preprisma:generate": "node scripts/don-port.cjs",
    "prisma:generate": "node scripts/prisma-cli.cjs generate --schema prisma/schema.prisma",
    "db:push": "node scripts/prisma-cli.cjs db push --schema prisma/schema.prisma --skip-generate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@types/bull": "^3.15.9",
    "@types/nodemailer": "^8.0.0",
    "@types/pdf-parse": "^1.1.5",
    "bcryptjs": "^3.0.3",
    "bull": "^4.16.5",
    "cors": "^2.8.6",
    "doan": "file:..",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.11.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^7.0.13",
    "pdf-parse": "^2.4.5",
    "prisma": "^6.19.3",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.0",
    "nodemon": "^3.1.14",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
