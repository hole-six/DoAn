              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"hr@fptsoft.com\",\n  \"password\": \"Password123!\",\n  \"confirmPassword\": \"Password123!\",\n  \"companyName\": \"FPT Software Da Nang\",\n  \"contactPerson\": \"Nguyễn Văn A\",\n  \"phone\": \"0901234567\",\n  \"role\": \"employer\"\n}"
            },
            "url": {
              "raw": "{{base_url}}{{api_version}}/auth/register/employer",
              "host": ["{{base_url}}{{api_version}}"],
              "path": ["auth", "register", "employer"]
