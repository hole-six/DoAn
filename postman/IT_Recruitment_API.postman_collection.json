  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const token = pm.environment.get(\"auth_token\");",
          "",
          "if (!token && !pm.request.url.path.includes('auth')) {",
          "    console.log(\"⚠️ No auth token found. Please login first.\");",
          "}"
        ]
      }
    }
  ]
