            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Senior Fullstack Developer (React/NodeJS) - Updated\",\n  \"salary\": {\n    \"min\": 2200,\n    \"max\": 3800,\n    \"currency\": \"USD\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}{{api_version}}/jobs/{{job_id}}",
