    {
      "name": "💼 Job Postings",
      "item": [
        {
          "name": "Get All Jobs",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has jobs array\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.jobs).to.be.an('array');",
                  "});",
                  "",
                  "pm.test(\"Response time is less than 500ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(500);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}{{api_version}}/jobs?page=1&limit=10",
              "host": ["{{base_url}}{{api_version}}"],
              "path": ["jobs"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "location",
                  "value": "Đà Nẵng",
                  "disabled": true
                },
                {
                  "key": "level",
                  "value": "Senior",
                  "disabled": true
                }
              ]
            },
            "description": "Lấy danh sách tất cả việc làm với phân trang"
          }
        },
        {
          "name": "Get Job By ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Job has required fields\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.job).to.have.property('_id');",
                  "    pm.expect(jsonData.job).to.have.property('title');",
                  "    pm.expect(jsonData.job).to.have.property('company');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}{{api_version}}/jobs/{{job_id}}",
              "host": ["{{base_url}}{{api_version}}"],
              "path": ["jobs", "{{job_id}}"]
            },
            "description": "Lấy thông tin chi tiết một việc làm"
          }
        },
        {
          "name": "Create Job",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Job created successfully\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.job).to.exist;",
                  "    pm.expect(jsonData.job._id).to.exist;",
                  "});",
                  "",
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set(\"job_id\", jsonData.job._id);",
                  "    console.log(\"✅ Job created. ID:\", jsonData.job._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Senior Fullstack Developer (React/NodeJS)\",\n  \"description\": \"Chúng tôi đang tìm kiếm Senior Fullstack Developer có kinh nghiệm với React và NodeJS để tham gia đội ngũ phát triển sản phẩm công nghệ cao.\",\n  \"requirements\": [\n    \"3+ năm kinh nghiệm với React và NodeJS\",\n    \"Thành thạo TypeScript\",\n    \"Kinh nghiệm với MongoDB\",\n    \"Có kinh nghiệm làm việc với AWS\"\n  ],\n  \"responsibilities\": [\n    \"Phát triển và maintain các tính năng mới\",\n    \"Code review và mentor junior developers\",\n    \"Tham gia thiết kế kiến trúc hệ thống\"\n  ],\n  \"salary\": {\n    \"min\": 2000,\n    \"max\": 3500,\n    \"currency\": \"USD\"\n  },\n  \"location\": \"Hải Châu, Đà Nẵng\",\n  \"level\": \"Senior\",\n  \"type\": \"Full-time\",\n  \"tags\": [\"React\", \"NodeJS\", \"MongoDB\", \"AWS\"],\n  \"benefits\": [\n    \"Lương thưởng cạnh tranh\",\n    \"Bảo hiểm đầy đủ\",\n    \"Làm việc hybrid\"\n  ],\n  \"deadline\": \"2026-06-30\"\n}"
            },
            "url": {
              "raw": "{{base_url}}{{api_version}}/jobs",
              "host": ["{{base_url}}{{api_version}}"],
              "path": ["jobs"]
            },
            "description": "Tạo tin tuyển dụng mới (chỉ dành cho Employer)"
          }
        },
        {
          "name": "Update Job",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
